# =============================================================================
# Daleel production environment — copy to ".env" on the VPS and fill in values.
#   cp .env.example .env && nano .env
# This file is read by docker-compose.yml (env_file) and injected into the
# daleel + caddy containers. NEVER commit the real .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Container image to run (overridable for pinning a specific tag / rollback).
# -----------------------------------------------------------------------------
DALEEL_IMAGE=ghcr.io/hamza-labs-core/daleel:latest

# -----------------------------------------------------------------------------
# LLM provider — OpenRouter is the single LLM backend for Daleel. It routes to
# the underlying providers (Anthropic, OpenAI, etc.), so no per-provider keys
# are needed here. This MUST be set for the agent layer to function.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=          # https://openrouter.ai/keys  (required)

# -----------------------------------------------------------------------------
# Search / data providers
# -----------------------------------------------------------------------------
SERPAPI_KEY=                 # https://serpapi.com/manage-api-key
CONTEXT_DEV_API_KEY=         # context.dev API key
GOOGLE_PLACES_API_KEY=       # Google Cloud -> Places API key
BING_SEARCH_KEY=             # optional — Azure Bing Search v7 key

# -----------------------------------------------------------------------------
# Cloudflare (browser rendering / wildcard-TLS DNS challenge)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=       # Cloudflare account id
CLOUDFLARE_API_TOKEN=        # token used by the app's CloudflareBrowserProvider

# -----------------------------------------------------------------------------
# Apify (social-media scraping actors)
# -----------------------------------------------------------------------------
APIFY_TOKEN=                 # https://console.apify.com/account/integrations

# -----------------------------------------------------------------------------
# Cloudflare R2 — structured error logging (Serilog → S3-compatible sink).
# When ALL of access key + secret + bucket + (endpoint OR account id) are set,
# Warning+ logs are written as JSON Lines to errors/YYYY/MM/DD/errors.jsonl in
# the bucket. Leave blank to fall back to local files at /app/data/logs/.
# The bucket must already exist; the app does not create it.
# Create an R2 API token (Object Read & Write) at:
#   Cloudflare dashboard -> R2 -> Manage R2 API Tokens
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=               # Cloudflare account id (used to derive the endpoint if R2_ENDPOINT is blank)
R2_ACCESS_KEY=               # R2 API token access key id
R2_SECRET_KEY=               # R2 API token secret access key
R2_BUCKET_NAME=              # target R2 bucket (e.g. daleel-logs) — must already exist
R2_ENDPOINT=                 # optional override, e.g. https://<account-id>.r2.cloudflarestorage.com

# Sign-in is email + password (ASP.NET Core Identity) — no OAuth provider secrets needed.

# -----------------------------------------------------------------------------
# Caddy / TLS
# -----------------------------------------------------------------------------
CADDY_DOMAIN=daleel.hamzalabs.dev              # public hostname Caddy serves + certs
CADDY_ACME_EMAIL=admin@daleel.hamzalabs.dev    # Let's Encrypt contact address
CADDY_DNS_TOKEN=             # only needed for WILDCARD TLS (DNS-01); blank for single host
