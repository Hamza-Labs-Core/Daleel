# =============================================================================
# Daleel production environment — copy to ".env" on the VPS and fill in values.
#   cp .env.example .env && nano .env
# This file is read by docker-compose.yml (env_file) and injected into the
# daleel + caddy containers. NEVER commit the real .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Container image to run (overridable for pinning a specific tag / rollback).
# -----------------------------------------------------------------------------
DALEEL_IMAGE=ghcr.io/hamza-labs-core/daleel:latest

# -----------------------------------------------------------------------------
# LLM provider — OpenRouter is the single LLM backend for Daleel. It routes to
# the underlying providers (Anthropic, OpenAI, etc.), so no per-provider keys
# are needed here. This MUST be set for the agent layer to function.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=          # https://openrouter.ai/keys  (required)

# -----------------------------------------------------------------------------
# Search / data providers
# -----------------------------------------------------------------------------
SERPAPI_KEY=                 # https://serpapi.com/manage-api-key
CONTEXT_DEV_API_KEY=         # context.dev API key
GOOGLE_PLACES_API_KEY=       # Google Cloud -> Places API key
BING_SEARCH_KEY=             # optional — Azure Bing Search v7 key

# -----------------------------------------------------------------------------
# PostgreSQL pipeline event store (OPTIONAL)
# The main app DB stays on SQLite (daleel_data volume). This separate Postgres
# store records every pipeline action (provider call, scrape, LLM, cache,
# profile, places, extract) for the admin "Usage" dashboard (/admin/usage).
# Leave BOTH blank to disable — the app then runs SQLite-only and the event
# store is a no-op. Set ONE of the two:
#   • POSTGRES_CONNECTION_STRING — Npgsql keyword form (preferred)
#   • DATABASE_URL               — postgres://user:pass@host:5432/db  (URL form)
# The bundled `postgres` service in docker-compose.yml seeds itself from
# POSTGRES_PASSWORD. In production BOTH POSTGRES_PASSWORD and
# POSTGRES_CONNECTION_STRING come from GitHub secrets (rendered into .env by the
# deploy workflow), so the password in the connection string MUST match
# POSTGRES_PASSWORD exactly. Postgres bakes the password into its data volume on
# first init — to change it you must drop the postgres_data volume so it
# reinitializes (the deploy workflow does this once for the secret migration).
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=changeme               # must match the Password=… in POSTGRES_CONNECTION_STRING below
POSTGRES_CONNECTION_STRING=              # e.g. Host=postgres;Port=5432;Database=daleel_events;Username=daleel;Password=changeme
DATABASE_URL=                            # alternative to the above (managed-Postgres URL form)

# -----------------------------------------------------------------------------
# Cloudflare (browser rendering / wildcard-TLS DNS challenge)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=       # Cloudflare account id
CLOUDFLARE_API_TOKEN=        # token used by the app's CloudflareBrowserProvider

# -----------------------------------------------------------------------------
# Apify (social-media scraping actors)
# -----------------------------------------------------------------------------
APIFY_TOKEN=                 # https://console.apify.com/account/integrations

# -----------------------------------------------------------------------------
# Cloudflare R2 — structured error logging (Serilog → S3-compatible sink).
# When ALL of access key + secret + bucket are set (the endpoint is derived from
# CLOUDFLARE_ACCOUNT_ID above), Warning+ logs are written as JSON Lines to
# errors/YYYY/MM/DD/errors.jsonl in the bucket. Leave blank to fall back to local
# files at /app/data/logs/. The bucket must already exist; the app does not create it.
# Create an R2 API token (Object Read & Write) at:
#   Cloudflare dashboard -> R2 -> Manage R2 API Tokens
# -----------------------------------------------------------------------------
R2_ACCESS_KEY=               # R2 API token access key id
R2_SECRET_KEY=               # R2 API token secret access key
R2_BUCKET_NAME=              # target R2 bucket (e.g. daleel-logs) — must already exist
R2_ENDPOINT=                 # optional override; blank = derive https://${CLOUDFLARE_ACCOUNT_ID}.r2.cloudflarestorage.com
# Public host for R2-stored product images: the bucket's public r2.dev URL or a custom
# domain bound to the bucket (e.g. https://images.daleel.app). REQUIRED to serve images
# from R2 — blank means images are hot-linked from their source instead, because the S3
# API endpoint above 403s the plain GET an <img> tag makes. No trailing slash needed.
R2_PUBLIC_URL=               # e.g. https://pub-xxxx.r2.dev  or  https://images.yourdomain.com

# Sign-in is email + password (ASP.NET Core Identity) — no OAuth provider secrets needed.

# -----------------------------------------------------------------------------
# Resend transactional email (OPTIONAL)
# When RESEND_API_KEY is set, Daleel emails users a summary when their search
# finishes (best-effort — a delivery failure never affects the search). Leave it
# blank to disable: the app then drops outbound email via a no-op service.
#   • RESEND_API_KEY — https://resend.com/api-keys  (starts with "re_")
#   • EMAIL_FROM     — verified sender address (blank = noreply@daleel.hamzalabs.dev)
#   • APP_BASE_URL   — public site URL the email's "View Full Report" links to
#                      (blank = https://daleel.hamzalabs.dev)
# The sender domain must be verified in Resend before delivery will succeed.
# -----------------------------------------------------------------------------
RESEND_API_KEY=              # Resend API key (re_…) — blank disables email
EMAIL_FROM=                  # blank = noreply@daleel.hamzalabs.dev
APP_BASE_URL=                # blank = https://daleel.hamzalabs.dev

# -----------------------------------------------------------------------------
# Caddy / TLS
# -----------------------------------------------------------------------------
CADDY_DOMAIN=daleel.hamzalabs.dev              # public hostname Caddy serves + certs
CADDY_ACME_EMAIL=admin@daleel.hamzalabs.dev    # Let's Encrypt contact address
CADDY_DNS_TOKEN=             # only needed for WILDCARD TLS (DNS-01); blank for single host
