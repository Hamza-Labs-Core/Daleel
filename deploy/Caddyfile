# Caddy reverse proxy for Daleel with automatic HTTPS (Let's Encrypt).
#
# Wildcard host: every *.daleel.yourdomain.com subdomain is proxied to the app.
# A wildcard certificate REQUIRES the DNS-01 challenge, which means Caddy needs a
# DNS-provider plugin and an API token. The default `caddy:2-alpine` image does NOT
# ship DNS plugins — build a custom image with xcaddy if you want wildcard TLS:
#
#   FROM caddy:2-builder AS build
#   RUN xcaddy build --with github.com/caddy-dns/cloudflare
#   FROM caddy:2-alpine
#   COPY --from=build /usr/bin/caddy /usr/bin/caddy
#
# Then set CADDY_DNS_TOKEN in .env (a Cloudflare token with Zone:DNS:Edit).
#
# If you only need a single fixed hostname (e.g. app.daleel.yourdomain.com), delete
# the wildcard block below and use that exact host — Caddy will use HTTP-01 with zero
# extra config and no DNS plugin required.

{
	# ACME account contact — replace with a real address you control.
	email {$CADDY_ACME_EMAIL:admin@daleel.yourdomain.com}
}

# Wildcard: proxy *.daleel.yourdomain.com -> daleel:8080
*.daleel.yourdomain.com {
	encode zstd gzip

	tls {
		dns cloudflare {$CADDY_DNS_TOKEN}
		resolvers 1.1.1.1
	}

	reverse_proxy daleel:8080 {
		health_uri /health
		health_interval 30s
		health_timeout 5s
	}

	log {
		output stdout
		format console
	}
}

# Apex/root host — redirect to the canonical app subdomain.
daleel.yourdomain.com {
	redir https://app.daleel.yourdomain.com{uri}
}
