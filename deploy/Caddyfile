# Caddy reverse proxy for Daleel with automatic HTTPS (Let's Encrypt).
#
# Single fixed host (daleel.hamzalabs.dev): Caddy uses the HTTP-01 challenge with
# zero extra config — no DNS plugin and no API token required, so the stock
# `caddy:2-alpine` image in docker-compose.yml works out of the box. Just point an
# A/AAAA record for the host at the server IP and open ports 80 + 443.
#
# The hostname comes from CADDY_DOMAIN in .env (falls back to the literal below).
#
# Want wildcard TLS (*.daleel.hamzalabs.dev) instead? That REQUIRES the DNS-01
# challenge, which needs a DNS-provider plugin baked into a custom image via xcaddy:
#
#   FROM caddy:2-builder AS build
#   RUN xcaddy build --with github.com/caddy-dns/cloudflare
#   FROM caddy:2-alpine
#   COPY --from=build /usr/bin/caddy /usr/bin/caddy
#
# then set CADDY_DNS_TOKEN in .env and add a `tls { dns cloudflare {$CADDY_DNS_TOKEN} }`
# block to the site.

{
	# ACME account contact — replace with a real address you control.
	email {$CADDY_ACME_EMAIL:admin@daleel.hamzalabs.dev}
}

# Security-response headers, imported by every site below. The app renders LLM- and scraped-derived
# content, so these are a second line behind Blazor's auto-encoding. The CSP allows MudBlazor/Blazor's
# inline styles+scripts and the Google Maps key/script (App.razor); frame-ancestors 'none' plus
# X-Frame-Options blocks clickjacking; nosniff + Referrer-Policy round it out.
(security_headers) {
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://maps.googleapis.com https://maps.gstatic.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https: wss: ws:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}
}

# Public site — proxy daleel.hamzalabs.dev -> daleel:8080 over automatic HTTPS.
# Caddy terminates TLS and forwards X-Forwarded-Proto: https, so the app's
# UseHttpsRedirection() correctly sees a secure request and does not redirect.
{$CADDY_DOMAIN:daleel.hamzalabs.dev} {
	encode zstd gzip
	import security_headers

	reverse_proxy daleel:8080 {
		# Caddy sets these automatically, but make them explicit: the app's UseForwardedHeaders()
		# relies on X-Forwarded-Proto (so UseHttpsRedirection/HSTS see the real https scheme) and
		# X-Forwarded-For (real client IP for analytics + rate limiting). Without the correct scheme
		# the auth pages can mis-render and SignInManager fails with "response has already started".
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Host {host}

		health_uri /health
		health_interval 30s
		health_timeout 5s
	}

	log {
		output stdout
		format console
	}
}

# Plain-HTTP catch-all (port 80, any host) so the app is also reachable by the
# raw VPS IP — handy before DNS for the domain has propagated, or for a quick
# smoke test. This block has NO host matcher, so Caddy inserts the domain's
# automatic HTTP->HTTPS redirect and the ACME HTTP-01 challenge handler ahead of
# it: requests for daleel.hamzalabs.dev still redirect to HTTPS and certificate
# issuance is unaffected — only unmatched hosts (the IP) fall through to here.
#
# There is intentionally no HTTPS-by-IP: public CAs (Let's Encrypt) won't issue
# certs for a bare IP, so reach the box by IP over http:// only; use the domain
# for TLS.
#
# X-Forwarded-Proto is forced to https here so the app's UseHttpsRedirection()
# treats IP traffic as already-secure and serves content, instead of 307'ing to
# a nonexistent https://<ip>. The domain site above keeps Caddy's real scheme.
http:// {
	encode zstd gzip
	import security_headers

	reverse_proxy daleel:8080 {
		header_up X-Forwarded-Proto https
		health_uri /health
		health_interval 30s
		health_timeout 5s
	}

	log {
		output stdout
		format console
	}
}
