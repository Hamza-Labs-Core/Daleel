@* App-bar controls: language and theme. MainLayout is InteractiveServer now, so these click handlers
   fire as plain children. They share the circuit's LayoutState with InteractiveProviders, so toggling
   theme here re-renders the MudThemeProvider there. Text direction is automatic — it follows the
   selected language's culture (Arabic = RTL, English = LTR), so there's no manual toggle. *@
@implements IDisposable
@inject LayoutState State
@inject BrowserStore Store

<div class="mr-2"><LanguageSwitcher /></div>

<MudTooltip Text="@(State.IsDarkMode ? "Light theme" : "Dark theme")">
    <MudIconButton Icon="@(State.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                   Color="Color.Inherit"
                   OnClick="ToggleTheme" aria-label="Toggle theme" />
</MudTooltip>

@code {
    protected override void OnInitialized() => State.Changed += OnStateChanged;

    private async Task ToggleTheme()
    {
        State.ToggleDarkMode();
        await Store.SetAsync("theme", State.IsDarkMode ? "dark" : "light");
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}
