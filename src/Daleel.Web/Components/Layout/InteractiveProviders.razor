@* MudBlazor's global providers. MainLayout is InteractiveServer (App.razor sets the render mode
   globally), so this renders interactively as a plain child: the MudThemeProvider gets the brand
   theme and the dialog/snackbar/popover overlays fire for interactive pages. Theme policy: DARK is
   the default; a user's explicit toggle choice (persisted by AppBarControls in localStorage) wins
   on the next visit. The app deliberately does NOT follow the OS setting — the old OS adoption
   overwrote the dark default on every circuit start and silently discarded the persisted choice,
   which was written but never read. *@
@implements IDisposable
@inject LayoutState State
@inject BrowserStore Store

<MudThemeProvider Theme="_theme" IsDarkMode="State.IsDarkMode" IsDarkModeChanged="State.SetDarkMode" />
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" CloseButton="true" />

@code {
    private readonly MudTheme _theme = DaleelTheme.Build();

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // localStorage needs a live circuit (JS interop), so the saved choice is read here. No
        // saved value (or anything unparsable) leaves the LayoutState default standing: dark.
        var saved = await Store.GetAsync("theme");
        if (saved is "dark" or "light")
        {
            State.SetDarkMode(saved == "dark");
        }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}
