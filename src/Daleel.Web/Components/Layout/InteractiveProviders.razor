@* MudBlazor's global providers. MainLayout is now InteractiveServer (App.razor sets the render mode
   globally), so this renders interactively as a plain child: the MudThemeProvider reacts to the theme
   toggle and the dialog/snackbar/popover overlays fire for interactive pages. Every interactive
   component in the circuit shares one scoped LayoutState, so the app-bar toggle and the Settings page
   both drive this provider through State.Changed. *@
@implements IDisposable
@inject LayoutState State
@inject BrowserStore Store

<MudThemeProvider Theme="_theme" IsDarkMode="State.IsDarkMode" />
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" CloseButton="true" />

@code {
    private readonly MudTheme _theme = DaleelTheme.Build();

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // Restore the visitor's saved theme now that the circuit is live and JS interop works.
        var theme = await Store.GetAsync("theme");
        if (theme is not null)
        {
            State.SetDarkMode(theme != "light");
        }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}
