@* Primary navigation. Labels are localized (English / Arabic) via the shared resource catalogue. *@
@inject IStringLocalizer<SharedResource> L
<div class="pa-4 d-flex align-center">
    <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Color="Color.Primary" Class="mr-2" />
    <div>
        <MudText Typo="Typo.subtitle1" Class="daleel-wordmark" Style="line-height:1.1;">دليل</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">market intelligence</MudText>
    </div>
</div>
<MudDivider />

@* Search-related destinations are gated behind sign-in: anonymous visitors only have the landing
   home, pricing and settings, so the drawer stays uncluttered for them. *@
<MudNavMenu Bordered="true">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Search">@L["Nav.Home"]</MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/brand" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Verified">@L["Nav.Brand"]</MudNavLink>
            <MudNavLink Href="/stores" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Storefront">@L["Nav.Stores"]</MudNavLink>
            <MudNavLink Href="/deals" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocalOffer">@L["Nav.Deals"]</MudNavLink>
            <MudNavLink Href="/compare" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Compare">@L["Nav.Compare"]</MudNavLink>
            <MudNavLink Href="/monitor" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Radar">@L["Nav.Monitor"]</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/history" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">@L["Nav.History"]</MudNavLink>
            <MudNavLink Href="/saved" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Bookmarks">@L["Nav.Saved"]</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <MudDivider Class="my-2" />
    <MudNavLink Href="/pricing" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.WorkspacePremium">@L["Nav.Pricing"]</MudNavLink>
    <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">@L["Nav.Settings"]</MudNavLink>
</MudNavMenu>
