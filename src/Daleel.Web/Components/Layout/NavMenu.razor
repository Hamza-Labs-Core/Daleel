@* Primary navigation. Bilingual labels: Arabic lead, English secondary. *@
<div class="pa-4 d-flex align-center">
    <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Color="Color.Primary" Class="mr-2" />
    <div>
        <MudText Typo="Typo.subtitle1" Class="daleel-wordmark" Style="line-height:1.1;">دليل</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">market intelligence</MudText>
