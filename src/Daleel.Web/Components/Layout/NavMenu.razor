    <MudNavLink Href="/deals" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocalOffer">
        العروض · Deals
    </MudNavLink>
    <MudNavLink Href="/compare" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Compare">
        قارن · Compare
