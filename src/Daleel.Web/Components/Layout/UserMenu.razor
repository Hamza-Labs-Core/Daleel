@* App-bar account control: a Sign-in button when anonymous, avatar + menu when signed in.
   MainLayout is InteractiveServer, so the MudMenu dropdown opens as a plain child. *@
@inject IStringLocalizer<SharedResource> L

<AuthorizeView>
    <Authorized>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
            <ActivatorContent>
                <MudTooltip Text="@DisplayName(context)">
                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                        @if (Avatar(context) is { } url)
                        {
                            <MudImage Src="@url" Alt="avatar" />
                        }
                        else
                        {
                            @Initial(context)
                        }
                    </MudAvatar>
                </MudTooltip>
            </ActivatorContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Class="px-4 py-2">@DisplayName(context)</MudText>
                <MudDivider />
                <MudMenuItem Href="/account" Icon="@Icons.Material.Filled.AccountCircle">@L["Nav.Account"]</MudMenuItem>
                <MudMenuItem Href="/history" Icon="@Icons.Material.Filled.History">@L["Nav.History"]</MudMenuItem>
                <MudMenuItem Href="/saved" Icon="@Icons.Material.Filled.Bookmarks">@L["Nav.Saved"]</MudMenuItem>
                @if (context.User.IsInRole("Admin"))
                {
                    <MudMenuItem Href="/admin" Icon="@Icons.Material.Filled.AdminPanelSettings">@L["Nav.Admin"]</MudMenuItem>
                }
                <MudDivider />
                <MudMenuItem Href="/logout" Icon="@Icons.Material.Filled.Logout">
                    @L["Nav.Logout"]
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
    </Authorized>
    <NotAuthorized>
        <MudButton Href="/login" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Login">@L["Nav.Login"]</MudButton>
    </NotAuthorized>
</AuthorizeView>

@code {
    private static string DisplayName(AuthenticationState ctx) =>
        ctx.User.FindFirst("display_name")?.Value
        ?? ctx.User.Identity?.Name
        ?? "Account";

    private static string? Avatar(AuthenticationState ctx) =>
        ctx.User.FindFirst("avatar_url")?.Value;

    private static string Initial(AuthenticationState ctx)
    {
        var name = DisplayName(ctx);
        return string.IsNullOrWhiteSpace(name) ? "?" : name[..1].ToUpperInvariant();
    }
}
