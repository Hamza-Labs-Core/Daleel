@page "/store/{Id}"
@inject IStoreRepository Stores
@inject IScrapedPriceRepository Prices
@inject NavigationManager Nav
@inject ILogger<StoreDetail> Logger

@* Dedicated full page for a store: name, type, Google-verified rating, address, phone, opening
   hours, the brands it carries and a map link. Routing is by a stable id: a numeric id resolves the
   saved profile directly, otherwise the store is loaded by the name carried in the query (the fallback
   for stores not yet persisted). The store card links here via "Store page". *@

<PageTitle>دليل · @DecodedName</PageTitle>

<MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2"
           OnClick="@(() => Nav.NavigateTo("/"))">Back to search</MudButton>

@if (_loading)
{
    <div class="d-flex justify-center pa-8"><MudProgressCircular Indeterminate="true" /></div>
}
else if (_store is null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No saved profile for “@DecodedName” yet. Run a store search that surfaces it and we'll build one.
    </MudAlert>
}
else
{
    <div class="d-flex align-center gap-2 mb-1">
        <MudIcon Icon="@Icons.Material.Filled.Storefront" Color="Color.Primary" Style="font-size:2.4rem;" />
        <MudText Typo="Typo.h4">@_store.Name</MudText>
        @if (_store.IsVerified)
        {
            <MudTooltip Text="Verified on Google Maps">
                <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Info" />
            </MudTooltip>
        }
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3 align-center">
        @if (!string.IsNullOrWhiteSpace(_store.Type))
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@_store.Type</MudChip>
        }
        @if ((_store.GoogleRating ?? _store.Rating) is { } rating)
        {
            <MudRating ReadOnly="true" SelectedValue="@((int)Math.Round(rating))" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @rating.ToString("0.0")@(_store.GoogleReviewCount is { } rc ? $" ({rc} reviews)" : "")
            </MudText>
        }
    </div>

    <MudPaper Class="pa-4 mb-3" Outlined="true" Elevation="0">
        <MudList T="string" Dense="true">
            @if (!string.IsNullOrWhiteSpace(_store.Address) || !string.IsNullOrWhiteSpace(_store.Location))
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Place">
                    <MudText Typo="Typo.body2">@(_store.Address ?? _store.Location)</MudText>
                </MudListItem>
            }
            @if (!string.IsNullOrWhiteSpace(_store.Phone))
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Phone">
                    <MudLink Href="@($"tel:{_store.Phone}")">@_store.Phone</MudLink>
                </MudListItem>
            }
            @if (!string.IsNullOrWhiteSpace(_store.Email))
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Email">
                    <MudLink Href="@($"mailto:{_store.Email}")">@_store.Email</MudLink>
                </MudListItem>
            }
            @if (_store.OpeningHours.Count > 0)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Schedule">
                    <MudText Typo="Typo.body2">@string.Join(" · ", _store.OpeningHours)</MudText>
                </MudListItem>
            }
        </MudList>
    </MudPaper>

    <div class="d-flex flex-wrap gap-2 mb-3">
        @if (!string.IsNullOrWhiteSpace(_store.Website))
        {
            <MudButton Href="@_store.Website" Target="_blank" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.OpenInNew">Website</MudButton>
        }
        @if (MapUrl is { } map)
        {
            <MudButton Href="@map" Target="_blank" Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Map">Open in Maps</MudButton>
        }
    </div>

    @if (MapEmbedUrl is { } embed)
    {
        <MudPaper Class="mb-3" Outlined="true" Elevation="0" Style="overflow:hidden;border-radius:8px;">
            <iframe src="@embed" title="@($"{_store.Name} on Google Maps")" loading="lazy"
                    style="width:100%;height:300px;border:0;" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </MudPaper>
    }

    @if (_products.Count > 0)
    {
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.h6" Class="mb-2">Products carried (@_products.Count)</MudText>
        <MudSimpleTable Dense="true" Hover="true" Bordered="true">
            <tbody>
                @foreach (var p in _products)
                {
                    <tr>
                        <td>
                            <MudLink Href="@ProductHref(p)" dir="@Catalog.Dir(p.ProductName)">@p.ProductName</MudLink>
                        </td>
                        <td>
                            @if (PriceOf(p) is { } money)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight:600;">@money.ToDisplay()</MudText>
                            }
                            else { <span>—</span> }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(p.SourceUrl))
                            {
                                <MudButton Href="@p.SourceUrl" Target="_blank" Size="Size.Small" Variant="Variant.Filled"
                                           Color="Color.Primary" StartIcon="@Icons.Material.Filled.ShoppingCart">Buy</MudButton>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    @if (_store.BrandsCarried.Count > 0)
    {
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.h6" Class="mb-2">Brands carried</MudText>
        <div class="d-flex flex-wrap gap-1">
            @foreach (var brand in _store.BrandsCarried)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         OnClick="@(() => Nav.NavigateTo($"/brand/{StableId.ForBrand(brand)}?name={Uri.EscapeDataString(brand)}"))">@brand</MudChip>
            }
        </div>
    }
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [SupplyParameterFromQuery] public string? Name { get; set; }

    private Store? _store;
    private IReadOnlyList<ScrapedPrice> _products = Array.Empty<ScrapedPrice>();
    private bool _loading = true;

    // Display/lookup fallback: the store name carried in the query (routing is by the stable id).
    private string DecodedName => Uri.UnescapeDataString(Name ?? string.Empty);

    private string? MapUrl =>
        !string.IsNullOrWhiteSpace(_store?.GoogleMapsUrl) ? _store!.GoogleMapsUrl
        : _store is { Latitude: { } lat, Longitude: { } lng }
            ? $"https://www.google.com/maps/search/?api=1&query={lat},{lng}"
            : _store is not null
                ? $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString(_store.Name)}"
                : null;

    // Keyless Google Maps embed (the &output=embed form needs no API key): prefer exact coordinates,
    // else fall back to the formatted address / store name so the location still renders.
    private string? MapEmbedUrl
    {
        get
        {
            var query = _store switch
            {
                { Latitude: { } lat, Longitude: { } lng } => $"{lat},{lng}",
                { Address: { Length: > 0 } addr } => addr,
                not null => _store.Name,
                _ => null,
            };
            return query is null ? null : $"https://www.google.com/maps?q={Uri.EscapeDataString(query)}&output=embed";
        }
    }

    private static Money? PriceOf(ScrapedPrice p) =>
        p.Price is { } v && !string.IsNullOrWhiteSpace(p.Currency) ? new Money(v, p.Currency!) : null;

    // Link to the product's detail page using the app's stable-id convention. Carry both the display name
    // and the exact stored ProductKey so the page resolves prices/profile even when the name isn't "brand
    // model" (which Normalize(name) alone would miss).
    private static string ProductHref(ScrapedPrice p) =>
        $"/product/{StableId.ForProduct(null, null, p.ProductName)}" +
        $"?name={Uri.EscapeDataString(p.ProductName)}&key={Uri.EscapeDataString(p.ProductKey)}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            // A numeric id is a real database key — resolve it directly. Anything else is a name-hash
            // for a store that may not be persisted, so fall back to the name carried in the query.
            _store = int.TryParse(Id, out var dbId)
                ? await Stores.GetByIdAsync(dbId)
                : !string.IsNullOrWhiteSpace(DecodedName)
                    ? await Stores.GetByNameAsync(DecodedName)
                    : null;
            if (_store is not null)
            {
                // Products carried = the latest scraped price per product observed at this store.
                _products = await Prices.LatestForStoreAsync(_store.Name);
            }
        }
        catch (Exception ex)
        {
            // Log so a real load error is distinguishable from a genuine "not found"; the not-found panel
            // still covers the user-facing case without leaking internal detail.
            Logger.LogWarning(ex, "Loading store detail for {Name} failed", DecodedName);
            _store = null;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
