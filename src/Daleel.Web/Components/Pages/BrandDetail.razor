@page "/brand/{Name}"
@using DbBrand = Daleel.Web.Data.Brand
@inject IBrandRepository Brands
@inject IBrandModelRepository BrandModels
@inject NavigationManager Nav

@* Dedicated full page for a brand: logo, in-market reputation, strengths/complaints, price
   positioning and the catalogue of harvested models (with images and local prices). Loads the
   persisted profile saved during search enrichment; the brand card / dialog links here. *@

<PageTitle>دليل · @DecodedName</PageTitle>

<MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2"
           OnClick="@(() => Nav.NavigateTo("/"))">Back to search</MudButton>

@if (_loading)
{
    <div class="d-flex justify-center pa-8"><MudProgressCircular Indeterminate="true" /></div>
}
else if (_brand is null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No saved profile for “@DecodedName” yet. Run a product search that surfaces this brand and we'll build one.
    </MudAlert>
}
else
{
    <div class="d-flex align-center gap-3 mb-2">
        @if (LogoSrc is { } logo)
        {
            <img src="@logo" alt="@_brand.Name" loading="lazy"
                 style="height:56px;width:56px;object-fit:contain;border-radius:10px;"
                 onerror="this.style.display='none'" />
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Info" Style="font-size:3rem;" />
        }
        <div>
            <MudText Typo="Typo.h4">@_brand.Name</MudText>
            @if (!string.IsNullOrWhiteSpace(_brand.CountryOfOrigin))
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">Origin: @_brand.CountryOfOrigin</MudText>
            }
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3 align-center">
        @if (_brand.ReputationScore is { } score)
        {
            <MudChip T="string" Color="@(score >= 7 ? Color.Success : score >= 4 ? Color.Warning : Color.Error)"
                     Icon="@Icons.Material.Filled.Star">@score.ToString("0.#")/10 reputation</MudChip>
        }
        @if (!string.IsNullOrWhiteSpace(_brand.PriceRange))
        {
            <MudChip T="string" Variant="Variant.Text" Color="Color.Primary" Icon="@Icons.Material.Filled.Sell">@_brand.PriceRange</MudChip>
        }
        @if (!string.IsNullOrWhiteSpace(_brand.Website))
        {
            <MudButton Href="@_brand.Website" Target="_blank" Size="Size.Small" Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.OpenInNew">Official site</MudButton>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_brand.Description))
    {
        <MudText Typo="Typo.body1" Class="mb-3" dir="@Catalog.Dir(_brand.Description)">@_brand.Description</MudText>
    }

    @if (_brand.Pros.Count > 0 || _brand.Cons.Count > 0)
    {
        <MudGrid Class="mb-2">
            @if (_brand.Pros.Count > 0)
            {
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle1" Color="Color.Success">Strengths</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var pro in _brand.Pros)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.ThumbUp" IconColor="Color.Success">
                                <MudText Typo="Typo.body2" dir="@Catalog.Dir(pro)">@pro</MudText>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }
            @if (_brand.Cons.Count > 0)
            {
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle1" Color="Color.Error">Common complaints</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var con in _brand.Cons)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.ThumbDown" IconColor="Color.Error">
                                <MudText Typo="Typo.body2" dir="@Catalog.Dir(con)">@con</MudText>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }
        </MudGrid>
    }

    @if (_models.Count > 0)
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-2">Models in this market (@_models.Count)</MudText>
        <MudGrid Spacing="3">
            @foreach (var m in _models)
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudCard Class="daleel-card" Elevation="0" Outlined="true" Style="height:100%;">
                        <div style="height:120px;display:flex;align-items:center;justify-content:center;background:var(--mud-palette-background-grey);overflow:hidden;">
                            @if (!string.IsNullOrWhiteSpace(m.ImageUrl))
                            {
                                <SafeImage Src="@m.ImageUrl" Alt="@m.ModelName" Style="max-height:120px;max-width:100%;object-fit:contain;" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Image" Style="opacity:0.3;" />
                            }
                        </div>
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.body2" Style="font-weight:500;" dir="@Catalog.Dir(m.ModelName)">@m.ModelName</MudText>
                            @if (m.LocalPrice is { } lp)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Primary">@lp.ToString("0.##") @m.Currency</MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_brand.PopularModels.Count > 0)
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-2">Popular models</MudText>
        <div class="d-flex flex-wrap gap-1">
            @foreach (var pm in _brand.PopularModels)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" dir="@Catalog.Dir(pm)">@pm</MudChip>
            }
        </div>
    }
}

@code {
    [Parameter] public string Name { get; set; } = string.Empty;

    private DbBrand? _brand;
    private IReadOnlyList<BrandModel> _models = Array.Empty<BrandModel>();
    private bool _loading = true;

    private string DecodedName => Uri.UnescapeDataString(Name ?? string.Empty);

    private string? LogoSrc
    {
        get
        {
            var host = HostOf(_brand?.Website);
            return host is null ? null : $"https://icons.duckduckgo.com/ip3/{host}.ico";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _brand = await Brands.GetByNameAsync(DecodedName);
            if (_brand is not null)
            {
                _models = await BrandModels.ListByBrandAsync(_brand.Id);
            }
        }
        catch
        {
            _brand = null;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string? HostOf(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        var s = url.Contains("://") ? url : "https://" + url;
        if (!Uri.TryCreate(s, UriKind.Absolute, out var u))
        {
            return null;
        }

        return u.Host.StartsWith("www.", StringComparison.OrdinalIgnoreCase) ? u.Host[4..] : u.Host;
    }
}
