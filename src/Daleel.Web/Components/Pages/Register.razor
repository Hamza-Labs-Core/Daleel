@page "/register"
@attribute [StaticSsrPage]
@layout Daleel.Web.Components.Layout.AuthLayout
@* Static SSR (flagged [StaticSsrPage]) so this plain HTML form makes a real HTTP POST to /auth/register,
   where the account is created and signed in (cookie write) in one raw request. See Login.razor for the
   failure mode this avoids ("Headers are read-only, response has already started"). *@

<PageTitle>دليل · Create account</PageTitle>

<div class="d-flex justify-center mt-4">
    <MudPaper Class="pa-8" Elevation="0" Outlined="true" Style="max-width:460px;width:100%;border-radius:18px;">
        <div class="text-center mb-4">
            <div class="daleel-logo" style="font-size:2rem;">دليل · Daleel</div>
            <MudText Typo="Typo.h5" Class="mt-2">إنشاء حساب · Create account</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Create your free account — you get 5 free searches every month.
            </MudText>
        </div>

        <AuthorizeView>
            <Authorized>
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    You're already signed in as @(context.User.Identity?.Name).
                </MudAlert>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
                    Go to Daleel
                </MudButton>
            </Authorized>
            <NotAuthorized>
                @if (ErrorMessage is not null)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@ErrorMessage</MudAlert>
                }

                <form method="post" action="/auth/register">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                    <label class="daleel-field-label" for="reg-email">Email</label>
                    <input id="reg-email" name="email" class="daleel-field" type="email" required
                           autocomplete="username" placeholder="you@example.com" />

                    <label class="daleel-field-label" for="reg-password">Password</label>
                    <input id="reg-password" name="password" class="daleel-field" type="password" required
                           autocomplete="new-password" placeholder="At least 8 characters" />

                    <label class="daleel-field-label" for="reg-confirm">Confirm password</label>
                    <input id="reg-confirm" name="confirmPassword" class="daleel-field" type="password" required
                           autocomplete="new-password" placeholder="Re-enter your password" />

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                        Use at least 8 characters with upper- and lower-case letters and a number.
                    </MudText>

                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true" Class="mt-4">
                        Create account
                    </MudButton>
                </form>

                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="d-block mt-3">
                    Your search history is private to your account. Searches are also analyzed
                    anonymously to improve results — never linked to your identity.
                    <MudLink Href="/faq" Typo="Typo.caption">Learn more</MudLink>
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                    Already have an account? <MudLink Href="/login">Sign in</MudLink>
                </MudText>
            </NotAuthorized>
        </AuthorizeView>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    // /auth/register redirects back here with ?error=<code> on failure; map the code to a message.
    private string? ErrorMessage => Error switch
    {
        "missing" => "Please enter both an email and a password.",
        "mismatch" => "The passwords do not match.",
        "duplicate" => "An account with that email already exists. Try signing in instead.",
        "weakpassword" => "Password must be at least 8 characters with upper- and lower-case letters and a number.",
        "failed" => "We couldn't create your account. Please check your details and try again.",
        _ => null,
    };
}
