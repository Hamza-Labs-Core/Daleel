@page "/register"
@layout Daleel.Web.Components.Layout.AuthLayout
@using Microsoft.AspNetCore.Authentication
@inject IAuthenticationSchemeProvider SchemeProvider

@* Static SSR. Daleel has no password sign-up: accounts are auto-provisioned on first OAuth callback
   (see /auth/callback), so "register" and "sign in" share the same provider buttons — the only
   difference is the framing. Kept static (its own AuthLayout) so it matches the auth flow. *@

<PageTitle>دليل · Create account</PageTitle>

<div class="d-flex justify-center mt-4">
    <MudPaper Class="pa-8" Elevation="0" Outlined="true" Style="max-width:460px;width:100%;border-radius:18px;">
        <div class="text-center mb-4">
            <div class="daleel-logo" style="font-size:2.4rem;">دليل</div>
            <MudText Typo="Typo.h5" Class="mt-2">إنشاء حساب · Create account</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Sign up with one tap — we'll create your free account automatically.
                You get 5 free searches every month.
            </MudText>
        </div>

        <AuthorizeView>
            <Authorized>
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    You're already signed in as @(context.User.Identity?.Name).
                </MudAlert>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
                    Go to Daleel
                </MudButton>
            </Authorized>
            <NotAuthorized>
                @if (_providers.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="text-center">
                        <MudText Typo="Typo.subtitle2">Sign-up is coming soon</MudText>
                        <MudText Typo="Typo.body2" Class="mt-1">
                            إنشاء الحساب قريباً — We're putting the finishing touches on secure sign-in.
                            Check back shortly to create your free account.
                        </MudText>
                    </MudAlert>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var p in _providers)
                        {
                            <MudButton Href="@SignUpHref(p.Scheme)" rel="nofollow"
                                       Variant="Variant.Outlined" Size="Size.Large" FullWidth="true"
                                       StartIcon="@Icon(p.Scheme)">
                                Sign up with @p.Display
                            </MudButton>
                        }
                    </div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                        Already have an account? <MudLink Href="/login">Sign in</MudLink>
                    </MudText>
                }
            </NotAuthorized>
        </AuthorizeView>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private readonly List<(string Scheme, string Display)> _providers = new();

    protected override async Task OnInitializedAsync()
    {
        // Only schemes that were actually registered (i.e. configured) show up here.
        var all = await SchemeProvider.GetAllSchemesAsync();
        foreach (var s in all.Where(s => !string.IsNullOrEmpty(s.DisplayName)
                                         && !s.Name.StartsWith("Identity.", StringComparison.Ordinal)))
        {
            _providers.Add((s.Name, s.DisplayName!));
        }
    }

    private string SignUpHref(string scheme)
    {
        var target = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
        return $"/auth/signin/{Uri.EscapeDataString(scheme)}?returnUrl={Uri.EscapeDataString(target)}";
    }

    private static string Icon(string scheme) => scheme switch
    {
        "Google" => Icons.Custom.Brands.Google,
        "Microsoft" => Icons.Custom.Brands.MicrosoftWindows,
        "Twitter" => Icons.Custom.Brands.Twitter,
        "GitHub" => Icons.Custom.Brands.GitHub,
        "Facebook" => Icons.Custom.Brands.Facebook,
        _ => Icons.Material.Filled.Login
    };
}
