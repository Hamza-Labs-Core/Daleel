@page "/register"
@attribute [StaticSsrPage]
@layout Daleel.Web.Components.Layout.AuthLayout
@* Static SSR (flagged [StaticSsrPage]) so this plain HTML form makes a real HTTP POST to /auth/register,
   where the account is created and signed in (cookie write) in one raw request. See Login.razor for the
   failure mode this avoids ("Headers are read-only, response has already started"). *@
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · @L["Auth.CreateAccount"]</PageTitle>

<div class="d-flex justify-center mt-4">
    <MudPaper Class="pa-8" Elevation="0" Outlined="true" Style="max-width:460px;width:100%;border-radius:18px;">
        <div class="text-center mb-4">
            <div class="daleel-logo" style="font-size:2rem;">دليل · Daleel</div>
            <MudText Typo="Typo.h5" Class="mt-2">@L["Auth.CreateAccount"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @L["Auth.Register.Subtitle"]
            </MudText>
        </div>

        <AuthorizeView>
            <Authorized>
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    @L["Auth.AlreadySignedIn", context.User.Identity?.Name ?? string.Empty]
                </MudAlert>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
                    @L["Auth.GoToDaleel"]
                </MudButton>
            </Authorized>
            <NotAuthorized>
                @if (ErrorMessage is not null)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@ErrorMessage</MudAlert>
                }

                <form method="post" action="/auth/register">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                    <label class="daleel-field-label" for="reg-email">@L["Auth.Email"]</label>
                    <input id="reg-email" name="email" class="daleel-field" type="email" required
                           autocomplete="username" placeholder="@L["Auth.EmailPlaceholder"]" />

                    <label class="daleel-field-label" for="reg-password">@L["Auth.Password"]</label>
                    <input id="reg-password" name="password" class="daleel-field" type="password" required
                           autocomplete="new-password" placeholder="@L["Auth.RegPasswordPlaceholder"]" />

                    <label class="daleel-field-label" for="reg-confirm">@L["Auth.ConfirmPassword"]</label>
                    <input id="reg-confirm" name="confirmPassword" class="daleel-field" type="password" required
                           autocomplete="new-password" placeholder="@L["Auth.ConfirmPasswordPlaceholder"]" />

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                        @L["Auth.PasswordHint"]
                    </MudText>

                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true" Class="mt-4">
                        @L["Auth.CreateAccount"]
                    </MudButton>
                </form>

                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="d-block mt-3">
                    @L["Auth.PrivacyNote"]
                    <MudLink Href="/faq" Typo="Typo.caption">@L["Auth.LearnMore"]</MudLink>
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                    @L["Auth.AlreadyHaveAccount"] <MudLink Href="/login">@L["Auth.SignIn"]</MudLink>
                </MudText>
            </NotAuthorized>
        </AuthorizeView>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    // /auth/register redirects back here with ?error=<code> on failure; map the code to a message.
    private string? ErrorMessage => Error switch
    {
        "missing" => (string)L["Auth.Error.Missing"],
        "mismatch" => (string)L["Auth.Error.Mismatch"],
        "duplicate" => (string)L["Auth.Error.Duplicate"],
        "weakpassword" => (string)L["Auth.Error.WeakPassword"],
        "failed" => (string)L["Auth.Error.Failed"],
        _ => null,
    };
}
