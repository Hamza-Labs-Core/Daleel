@page "/pricing"
@inject IStringLocalizer<SharedResource> L

@* Standalone pricing page. The tier cards are rendered by the shared <PricingTiers /> component —
   the same one the anonymous landing page uses — so the two pages always show identical plans. *@

<PageTitle>دليل · Pricing</PageTitle>

<div class="text-center mb-8">
    <MudText Typo="Typo.h3">@L["Landing.Pricing.Title"]</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">@L["Landing.Pricing.Subtitle"]</MudText>
</div>

<PricingTiers />

<MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block text-center mt-6">
    Paid plans are not yet billable — contact us to upgrade. Stripe integration is coming.
</MudText>
