@page "/product/{Id}"
@inject IProductDetailDbService Details
@inject NavigationManager Nav
@inject ILogger<ProductDetail> Logger
@inject IStringLocalizer<SharedResource> L

@* Dedicated full page for a single product model, read entirely from the saved database — never
   re-scraped live. It assembles the harvested catalogue row (specs + R2 image), the deep-dive profile
   (description), the brand's saved reputation and the scraped-price history (where-to-buy + observed
   range). Routing is by a stable id (numeric catalogue id or an identity hash); the human name carried
   in the query reconstructs the normalized key the price/profile rows are stored under. *@

<PageTitle>دليل · @DisplayTitle</PageTitle>

<MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2"
           OnClick="@(() => Nav.NavigateTo("/"))">Back to search</MudButton>

@if (_loading)
{
    <div class="d-flex justify-center pa-8"><MudProgressCircular Indeterminate="true" /></div>
}
else if (_view is null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Details not yet available — this product will be profiled on the next search.
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4" dir="@Catalog.Dir(_view.Name)" Class="mb-1">@_view.Name</MudText>
    @if (!string.IsNullOrWhiteSpace(_view.Brand) || !string.IsNullOrWhiteSpace(_view.Model))
    {
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-3">
            @string.Join(" · ", new[] { _view.Brand, _view.Model }.Where(s => !string.IsNullOrWhiteSpace(s)))
        </MudText>
    }

    <MudGrid Spacing="4">
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-3 d-flex align-center justify-center" Outlined="true" Elevation="0"
                      Style="min-height:280px;background:var(--mud-palette-background-grey);">
                @if (!string.IsNullOrWhiteSpace(_view.ImageUrl))
                {
                    <SafeImage Src="@_view.ImageUrl" Alt="@_view.Name" Style="max-height:340px;max-width:100%;object-fit:contain;" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Image" Style="font-size:5rem;opacity:0.3;" />
                }
            </MudPaper>

            <div class="d-flex flex-wrap gap-2 mt-3 align-center">
                @if (_view.Lowest is { } low)
                {
                    <MudText Typo="Typo.h5" Color="Color.Primary">@low.ToDisplay()</MudText>
                    @if (_view.SellerCount > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">lowest across @_view.SellerCount @(_view.SellerCount == 1 ? "seller" : "sellers")</MudText>
                    }
                }
                @if (_view.BrandReputationScore is { } score && _view.BrandStableId is { } brandId)
                {
                    <MudChip T="string" Size="Size.Small"
                             Color="@(score >= 7 ? Color.Success : score >= 4 ? Color.Warning : Color.Error)"
                             Icon="@Icons.Material.Filled.Verified"
                             OnClick="@(() => Nav.NavigateTo($"/brand/{brandId}?name={Uri.EscapeDataString(_view.Brand ?? string.Empty)}"))">
                        @_view.Brand @score.ToString("0.#")/10
                    </MudChip>
                }
            </div>

            @if (PriceRange is { } range)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1" />Observed range: @range
                </MudText>
            }
            @if (_view.LastUpdated is { } updated)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">Prices updated @updated.LocalDateTime.ToString("d MMM yyyy")</MudText>
            }
        </MudItem>

        <MudItem xs="12" md="7">
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.PriceCheck" Class="mr-1" />Where to buy
            </MudText>
            @if (_view.Offers.Count > 0)
            {
                <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                    <tbody>
                        @foreach (var offer in _view.Offers)
                        {
                            <tr>
                                <td>
                                    <MudLink Href="@($"/store/{offer.StoreId}?name={Uri.EscapeDataString(offer.StoreName)}")"
                                             dir="@Catalog.Dir(offer.StoreName)">@offer.StoreName</MudLink>
                                </td>
                                <td>
                                    @if (AsMoney(offer) is { } m)
                                    {
                                        <MudText Typo="Typo.body1" Color="Color.Primary" Style="font-weight:600;">@m.ToDisplay()</MudText>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(offer.Url))
                                    {
                                        <MudButton Href="@offer.Url" Target="_blank" Size="Size.Small" Variant="Variant.Filled"
                                                   Color="Color.Primary" StartIcon="@Icons.Material.Filled.ShoppingCart">Buy</MudButton>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No saved prices yet — they'll appear after the next price scan.</MudText>
            }
        </MudItem>
    </MudGrid>

    @if (!string.IsNullOrWhiteSpace(_view.Description))
    {
        <MudDivider Class="my-4" />
        <ReportView Title="Overview" Text="@_view.Description" />
    }

    @* Specs come from the persisted catalogue row (already sanitized into clean key/value pairs by
       ProductDetailDbService) — the raw scraped "details" blob never reaches this page. *@
    @if (_view.Specs.Count > 0)
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-2">@L["Detail.Specifications"]</MudText>
        <MudSimpleTable Dense="true" Bordered="true" Style="max-width:560px;">
            <tbody>
                @foreach (var (key, value) in _view.Specs)
                {
                    <tr><td><strong>@Humanize(key)</strong></td><td dir="@Catalog.Dir(value)">@value</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Detail.SpecsUnavailable"]</MudText>
    }
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [SupplyParameterFromQuery] public string? Name { get; set; }
    [SupplyParameterFromQuery] public string? Geo { get; set; }

    // The exact stored ScrapedPrice.ProductKey, when the linking page has it (e.g. a store page). Resolves
    // products whose display name isn't "brand model", which Normalize(Name) alone would miss.
    [SupplyParameterFromQuery] public string? Key { get; set; }

    private ProductDetailView? _view;
    private bool _loading = true;

    // Routing is by stable id; the name (carried in the query) reconstructs the DB lookup key.
    private string DecodedName => Uri.UnescapeDataString(Name ?? string.Empty);
    private string DisplayTitle => _view?.Name is { Length: > 0 } n ? n : DecodedName;

    private string? PriceRange
    {
        get
        {
            if (_view is { LowestSeen: { } lo, HighestSeen: { } hi, Currency: { } cur } && hi > lo)
            {
                return $"{new Money(lo, cur).ToDisplay()} – {new Money(hi, cur).ToDisplay()}";
            }

            return null;
        }
    }

    private static Money? AsMoney(ProductDetailOffer offer) =>
        offer.Price is { } p && !string.IsNullOrWhiteSpace(offer.Currency) ? new Money(p, offer.Currency!) : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            // Read the assembled view from the database — no live scrape. Works cold from a shared link.
            _view = await Details.GetAsync(
                Id, DecodedName, string.IsNullOrWhiteSpace(Geo) ? "jordan" : Geo!, lookupKey: Key);
        }
        catch (Exception ex)
        {
            // Log so a real load error is distinguishable from a genuine "not found"; the not-available
            // panel covers this for the user and never surfaces internal detail.
            Logger.LogWarning(ex, "Loading product detail for {Name} failed", DecodedName);
            _view = null;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string Humanize(string key) =>
        string.Join(' ', key.Replace('_', ' ').Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(w => char.ToUpperInvariant(w[0]) + w[1..]));
}
