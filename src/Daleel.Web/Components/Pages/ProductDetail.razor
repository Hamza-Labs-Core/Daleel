@page "/product/{Name}"
@inject IModelDetailService Details
@inject NavigationManager Nav

@* Dedicated full page for a single product model — "everything": large image, identity, the full
   price-comparison table across every seller, brand reputation, pros/cons and the spec sheet. The
   compact detail dialog links here via "View Full Details". The model is re-scanned on demand from
   its name (results aren't persisted with a stable id), so this page works from a shared/bookmarked URL. *@

<PageTitle>دليل · @DecodedName</PageTitle>

<MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2"
           OnClick="@(() => Nav.NavigateTo("/"))">Back to search</MudButton>

@if (_loading)
{
    <div class="d-flex flex-column align-center pa-8">
        <MudProgressCircular Indeterminate="true" />
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">Deep-scanning @DecodedName…</MudText>
    </div>
}
else if (_model is null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        We couldn't load full details for “@DecodedName”. It may not be available in
        @GeoProfiles.ResolveOrDefault(string.IsNullOrWhiteSpace(Geo) ? "jordan" : Geo).Country,
        or deep scanning is not configured. Try searching for it from the home page.
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4" dir="@Catalog.Dir(_model.Name)" Class="mb-1">@_model.Name</MudText>
    @if (!string.IsNullOrWhiteSpace(_model.Brand) || !string.IsNullOrWhiteSpace(_model.Model))
    {
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-3">
            @string.Join(" · ", new[] { _model.Brand, _model.Model }.Where(s => !string.IsNullOrWhiteSpace(s)))
        </MudText>
    }

    <MudGrid Spacing="4">
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-3 d-flex align-center justify-center" Outlined="true" Elevation="0"
                      Style="min-height:280px;background:var(--mud-palette-background-grey);">
                @if (!string.IsNullOrWhiteSpace(_model.ImageUrl))
                {
                    <SafeImage Src="@_model.ImageUrl" Alt="@_model.Name" Style="max-height:340px;max-width:100%;object-fit:contain;" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Image" Style="font-size:5rem;opacity:0.3;" />
                }
            </MudPaper>

            <div class="d-flex flex-wrap gap-2 mt-3 align-center">
                @if (_model.LowestPrice is { } p && _model.LowestOffer?.Currency is { } cur)
                {
                    <MudText Typo="Typo.h5" Color="Color.Primary">@(new Money(p, cur).ToDisplay())</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">lowest across @_model.SellerCount @(_model.SellerCount == 1 ? "seller" : "sellers")</MudText>
                }
                @if (_model.Msrp_ is { } msrp)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">MSRP @msrp.ToDisplay()</MudChip>
                }
            </div>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.PriceCheck" Class="mr-1" />Where to buy
            </MudText>
            <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                <tbody>
                    @foreach (var offer in _model.Offers)
                    {
                        <tr>
                            <td><SourceBadge SourceType="offer.SourceType" Source="@offer.Source" /></td>
                            <td>
                                @if (offer.AsMoney is { } m)
                                {
                                    <MudText Typo="Typo.body1" Color="Color.Primary" Style="font-weight:600;">@m.ToDisplay()</MudText>
                                }
                                else { <span>—</span> }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(offer.Condition))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@offer.Condition</MudChip>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(offer.Url))
                                {
                                    <MudButton Href="@offer.Url" Target="_blank" Size="Size.Small" Variant="Variant.Filled"
                                               Color="Color.Primary" StartIcon="@Icons.Material.Filled.ShoppingCart">Buy</MudButton>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudItem>
    </MudGrid>

    @if (_model.BrandReputation is { HasSignal: true })
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Verified" Class="mr-1" />Brand reputation
        </MudText>
        <BrandReputationView Reputation="_model.BrandReputation" Compact="false" />
    }

    @if (!string.IsNullOrWhiteSpace(_model.ReviewSummary) || _model.Pros.Count > 0 || _model.Cons.Count > 0)
    {
        <MudDivider Class="my-4" />
        @if (!string.IsNullOrWhiteSpace(_model.ReviewSummary))
        {
            <MudText Typo="Typo.body1" Class="mb-2" dir="@Catalog.Dir(_model.ReviewSummary)">@_model.ReviewSummary</MudText>
        }
        <MudGrid>
            @if (_model.Pros.Count > 0)
            {
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle1" Color="Color.Success">Pros</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var pro in _model.Pros)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.ThumbUp" IconColor="Color.Success">
                                <MudText Typo="Typo.body2" dir="@Catalog.Dir(pro)">@pro</MudText>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }
            @if (_model.Cons.Count > 0)
            {
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle1" Color="Color.Error">Cons</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var con in _model.Cons)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.ThumbDown" IconColor="Color.Error">
                                <MudText Typo="Typo.body2" dir="@Catalog.Dir(con)">@con</MudText>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }
        </MudGrid>
    }

    @if (_model.Specs.Count > 0)
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-2">Specifications</MudText>
        <MudSimpleTable Dense="true" Bordered="true" Style="max-width:560px;">
            <tbody>
                @foreach (var (key, value) in _model.Specs)
                {
                    <tr><td><strong>@Humanize(key)</strong></td><td>@value</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    [Parameter] public string Name { get; set; } = string.Empty;
    [SupplyParameterFromQuery] public string? Geo { get; set; }

    private ProductModel? _model;
    private bool _loading = true;

    private string DecodedName => Uri.UnescapeDataString(Name ?? string.Empty);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            // Re-scan the model from its name (results aren't persisted with stable ids), so the page
            // works cold from a bookmark/share link, not just from an in-memory result.
            _model = await Details.GetAsync(DecodedName, string.IsNullOrWhiteSpace(Geo) ? "jordan" : Geo!);
        }
        catch
        {
            _model = null; // the not-found panel covers this; never surface internal detail.
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string Humanize(string key) =>
        string.Join(' ', key.Replace('_', ' ').Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(w => char.ToUpperInvariant(w[0]) + w[1..]));
}
