@page "/"
@rendermode InteractiveServer
@inherits AgentPageBase

<PageTitle>دليل · Daleel — Ask</PageTitle>

<div class="daleel-hero">
    <div class="daleel-logo">دليل</div>
    <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mt-1">
        Arabic market &amp; social intelligence · ذكاء الأسواق ووسائل التواصل
    </MudText>
</div>

<MudPaper Class="pa-4 mx-auto" Elevation="0" Outlined="true" Style="max-width:820px;border-radius:18px;">
    <MudTextField @bind-Value="_question" Lines="2" AutoGrow="true"
                  Placeholder="اسأل دليل… / Ask Daleel…"
                  Variant="Variant.Text" Immediate="true"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  OnKeyDown="OnKey" Class="mt-1" />

    <div class="d-flex flex-wrap gap-3 mt-3 align-center">
        <div style="min-width:230px;flex:1;"><GeoSelect @bind-Value="Geo" /></div>
        <div style="min-width:230px;flex:1;"><ModelSelect @bind-Value="Model" /></div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.AutoAwesome"
                   OnClick="Ask" Disabled="Busy || string.IsNullOrWhiteSpace(_question)">
            اسأل · Ask
        </MudButton>
    </div>
</MudPaper>

<div class="mx-auto mt-4" style="max-width:820px;">
    @if (Ready)
    {
        <ProviderStatusBar Keys="Keys" />
    }

    @if (Error is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-3">@Error</MudAlert>
    }

    <ProgressLog Busy="Busy" Lines="LogLines" />
</div>

@if (_answer is not null && !Busy)
{
    var bundle = _answer.Research;
    <div class="mx-auto" style="max-width:980px;">
        <div class="d-flex align-center gap-2 my-3">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">@_answer.QueryType</MudChip>
            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">@Catalog.ResolveGeo(_answer.Geo).Display</MudChip>
            <MudSpacer />
            <SaveResultButton Result="_answer" ResultType="ask" DefaultTitle="@_answer.Question" SearchHistoryId="LastHistoryId" />
        </div>

        <ReportView Title="الملخص · Summary" Text="@_answer.Summary" />

        @{ var prices = bundle.ShoppingResults.Where(r => r.Price is not null).Take(9).ToList(); }
        @if (prices.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mt-6 mb-2">الأسعار والعروض · Prices &amp; deals</MudText>
            <MudGrid Spacing="3">
                @foreach (var r in prices)
                {
                    <MudItem xs="12" sm="6" md="4"><ShoppingCard Result="r" /></MudItem>
                }
            </MudGrid>
        }

        @if (bundle.Stores.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mt-6 mb-2">المتاجر · Stores</MudText>
            <MudGrid Spacing="3">
                @foreach (var s in bundle.Stores.Take(6))
                {
                    <MudItem xs="12" sm="6" md="4"><StoreCard Store="s" /></MudItem>
                }
            </MudGrid>
        }

        @if (bundle.SocialPosts.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mt-6 mb-2">آراء الناس · Opinions (@bundle.SocialPosts.Count)</MudText>
            <MudList T="string" Dense="true">
                @foreach (var p in bundle.SocialPosts.Take(8))
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.ChatBubbleOutline">
                        <MudText Typo="Typo.body2" dir="@Catalog.Dir(p.Text)">@Trim(p.Text, 240)</MudText>
                        @if (!string.IsNullOrWhiteSpace(p.Author))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">— @p.Author</MudText>
                        }
                    </MudListItem>
                }
            </MudList>
        }

        <SourceChips Sources="bundle.Sources" />
    </div>
}

@code {
    [SupplyParameterFromQuery] private string? Q { get; set; }
    [SupplyParameterFromQuery(Name = "geo")] private string? GeoParam { get; set; }

    private string _question = string.Empty;
    private AgentAnswer? _answer;

    // Prefill from a History "re-run" deep link (?q=…&geo=…); the user presses Ask to run it.
    protected override Task OnReadyAsync()
    {
        if (!string.IsNullOrWhiteSpace(Q))
        {
            _question = Q!;
        }

        if (!string.IsNullOrWhiteSpace(GeoParam))
        {
            Geo = GeoParam!;
        }

        return Task.CompletedTask;
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey))
        {
            await Ask();
        }
    }

    private async Task Ask()
    {
        if (string.IsNullOrWhiteSpace(_question))
        {
            return;
        }

        _answer = null;
        await Store.SetAsync("geo", Geo);
        await Store.SetAsync("model", Model);
        await RunAsync(
            async (agent, ct) => _answer = await agent.AskAsync(_question, Geo, ct),
            () => _answer is null ? null : new SearchHistoryEntry
            {
                Query = _question,
                QueryType = "ask",
                ResultSummary = _answer.Summary
            });
    }

    private static string Trim(string s, int max) => s.Length <= max ? s : s[..max] + "…";
}
