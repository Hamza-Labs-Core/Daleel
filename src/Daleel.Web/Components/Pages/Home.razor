@page "/"
@implements IDisposable
@inject ICurrentUser CurrentUser
@inject IConversationService Conversations
@inject IConversationStore ConvoStore
@inject IConversationNotifier Notifier
@inject ISearchHistoryRepository History
@inject BrowserStore Store
@inject IDialogService Dialogs
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L
@inject IEmailService Email
@inject IUserEmailPreferences EmailPrefs
@inject IEnrichmentWorkQueue EnrichQueue
@using Daleel.Web.Email
@using Daleel.Web.Pipeline.Enrichment

<PageTitle>دليل · Daleel</PageTitle>

@* Signed-out visitors get the marketing landing page; the search/chat workspace is for members only. *@
<AuthorizeView>
<NotAuthorized>
    <LandingPage />
</NotAuthorized>
<Authorized>
<div class="daleel-workspace">
    <!-- Prominent search bar, anchored at the top of the workspace. Recent searches now live in the
         left-nav "Recent" submenu (NavMenu), so the page content stays focused on the search + results.
         The market isn't a control here: it's detected from the query text itself (GeoProfiles.DetectInText,
         e.g. "AC in Dubai" → UAE). When the query names no market we ask inline (below) instead of
         silently defaulting to one. AutoGrow keeps the field a compact single line that expands as the
         user types a longer query, rather than starting as a giant textarea. -->
    <MudPaper Class="pa-2 mb-4" Outlined="true" Elevation="0" Style="border-radius:14px;">
        <div class="d-flex align-center gap-2">
            <MudTextField @bind-Value="_input" Placeholder="@(L["Search.Placeholder"])"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          AutoGrow="true" Lines="1" MaxLines="6"
                          Immediate="true" OnKeyDown="OnKey" Class="mt-0" Style="flex:1 1 auto;"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Disabled="_running" />
            <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" Size="Size.Large"
                           OnClick="SubmitAsync" Disabled="@(_running || string.IsNullOrWhiteSpace(_input))" />
        </div>
    </MudPaper>

    @* When the query text doesn't name a market we never assume one — we ask, inline, right under the
       input, before the search runs. Picking a market here runs the pending query against it. *@
    @if (_awaitingMarket)
    {
        <MudPaper Class="pa-3 mb-4" Outlined="true" Elevation="0" Style="border-radius:14px;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Market.Prompt"]</MudText>
            <div class="d-flex gap-2" style="flex-wrap:wrap;">
                @foreach (var geo in Catalog.Geos)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               OnClick="@(() => RunPendingSearchAsync(geo.Key))">@geo.Display</MudButton>
                }
            </div>
        </MudPaper>
    }

        @if (_query is null && _status is "idle" or null)
        {
            <div class="daleel-hero">
                <div class="daleel-logo">دليل</div>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mt-1">
                    @L["Home.Tagline"]
                </MudText>
            </div>
        }

        @if (_query is not null)
        {
            <MudPaper Class="pa-4 mb-3" Outlined="true" Elevation="0">
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" />
                    <MudText Typo="Typo.h6" dir="@Catalog.Dir(_query)">@_query</MudText>
                </div>
            </MudPaper>
        }

        @* The animated workflow stepper + live activity feed. Each streamed progress line decodes into
           a step + localized message, so the stepper advances stage-by-stage while the feed narrates. *@
        @if (_status == "running")
        {
            <SearchProgress Messages="_progress" Active="true" OnCancel="CancelAsync" />
            @if (_emailNotice)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-2"
                          Icon="@Icons.Material.Filled.MarkEmailRead">
                    @L["Search.EmailNotice"]
                </MudAlert>
            }

            @* PROGRESSIVE RESULTS: the pipeline streams partial grids while it keeps working — render
               them immediately under the live stepper. The UI never waits on the workflow; the grid
               fills in and re-renders in place as each enrichment sub-workflow lands. *@
            @if (_answer?.Products is { } partial && (partial.HasListings || partial.StoreCount > 0 || partial.BrandCount > 0 || partial.ReviewCount > 0))
            {
                <div class="d-flex align-center mb-2 mt-3">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Search.PartialResults"]</MudText>
                </div>
                @* AdaptiveResults tabs the grid with its stores/brands, and falls back to the
                   secondary sections when a search yielded no distinct product models at all. *@
                <AdaptiveResults Result="partial" />
            }
        }

        @* No raw status/error metadata: a search that yields nothing shows a neutral empty state.
           The underlying reason is logged server-side for operators, not shown to the user. *@
        @if (_status == "error")
        {
            <MudPaper Class="pa-6 mb-3 d-flex flex-column align-center" Outlined="true" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                <MudText Typo="Typo.subtitle1" Align="Align.Center">@L["Home.NoResults.Title"]</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                    @L["Home.NoResults.Hint"]
                </MudText>
            </MudPaper>
        }

        @if (_status == "cancelled")
        {
            <MudPaper Class="pa-6 mb-3 d-flex flex-column align-center" Outlined="true" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                <MudText Typo="Typo.subtitle1" Align="Align.Center">@L["Search.Cancelled"]</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                    @L["Search.CancelledHint"]
                </MudText>
            </MudPaper>
        }

        @* A search whose worker was killed by a container restart: the startup reconciler (OrphanedJobReconciler)
           flips the conversation to "interrupted", so a reconnecting tab stops spinning and shows a retry prompt
           instead of waiting forever for a completion that will never arrive. *@
        @if (_status == "interrupted")
        {
            <MudPaper Class="pa-6 mb-3 d-flex flex-column align-center" Outlined="true" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                <MudText Typo="Typo.subtitle1" Align="Align.Center">@L["Search.Interrupted"]</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                    @L["Search.InterruptedHint"]
                </MudText>
            </MudPaper>
        }

        @* Results render as a structured product list (with stores/brands/reviews secondary).
           No text-summary paragraph — the data speaks for itself. *@
        @* @key on the query makes the whole block remount when a new search completes, so the
           staggered reveal animation replays for each fresh result set rather than only the first. *@
        @if (_status == "completed" && _answer is not null)
        {
            <div class="daleel-results-reveal" @key="_query">
                @* The deep dive keeps patching the grid AFTER completion (images, prices, per-card
                   reviews/mentions land via the Enriched handler). While the job still has open
                   enrichment units (polled from the work queue), say so — otherwise a card that
                   sprouts details seconds later looks like a glitch. *@
                @if (_openEnrichment > 0)
                {
                    <div class="d-flex align-center mb-2">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Search.EnrichingHint"]</MudText>
                    </div>
                }
                @if (_answer.Products is { } products && (products.HasListings || products.StoreCount > 0 || products.BrandCount > 0 || products.ReviewCount > 0))
                {
                    @* AdaptiveResults tabs the grid with its stores/brands, and falls back to the
                       secondary sections when the search yielded no distinct product models at all. *@
                    <AdaptiveResults Result="products" />
                }
                else
                {
                    <MudPaper Class="pa-6 mb-3 d-flex flex-column align-center" Outlined="true" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                        <MudText Typo="Typo.subtitle1" Align="Align.Center">@L["Home.NoResults.Title"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                            @L["Home.NoResults.Hint"]
                        </MudText>
                    </MudPaper>
                }
            </div>
        }
</div>
</Authorized>
</AuthorizeView>

@code {
    [SupplyParameterFromQuery] private string? Q { get; set; }

    // When set, open a saved history entry's results read-only (no re-run). See LoadHistoryResultAsync.
    [SupplyParameterFromQuery(Name = "historyId")] private int? HistoryId { get; set; }

    private string? _userId;
    private string _input = string.Empty;
    // Set while we're asking the user which market to search (the query named none, and geolocation
    // couldn't place them). Holds the query the user submitted so we can run it once they pick a market.
    private bool _awaitingMarket;
    private string? _pendingQuery;
    // Browser-geolocation result, resolved lazily on the first market-less query and reused afterwards so
    // we don't re-trigger the location permission prompt on every search. _geoTried guards the JS call;
    // _geoMarket is the nearest supported market key, or null when geolocation was denied/unavailable.
    private bool _geoTried;
    private string? _geoMarket;
    private string? _query;
    private string? _status; // idle | running | completed | error | cancelled | interrupted
    private string? _error;
    private int? _jobId;
    private bool _running => _status == "running";

    // Deep-dive watch: while a completed result is on screen for a known job, poll the enrichment
    // work queue's open-unit count (pending+running) every 5s and show the "still enriching" hint
    // while it's non-zero. Same Timer + InvokeAsync pattern as AdminQueues; the queue is a singleton
    // that opens its own DB scopes, so calling it from the circuit is safe.
    private int _openEnrichment;
    private Timer? _enrichTimer;
    private int _enrichChecks;
    private bool _enrichSeenWork;
    private readonly List<string> _progress = new();
    private AgentAnswer? _answer;
    private List<SearchHistoryEntry> _recent = new();

    // True when we'll actually email this user their results: email is configured AND they're opted in.
    // Drives the "we'll email you" banner so it never promises an email that won't be sent.
    private bool _emailNotice;

    // The viewer's culture, captured on the interactive circuit (see ApplyCulture). Init to the
    // ambient culture as a fallback; the real value is captured on first render.
    private System.Globalization.CultureInfo _culture = System.Globalization.CultureInfo.CurrentCulture;
    private System.Globalization.CultureInfo _uiCulture = System.Globalization.CultureInfo.CurrentUICulture;

    // The progress/result callbacks are raised from the pipeline's OWN background thread (default "en"
    // culture), and CurrentUICulture flows with the caller's execution context into the InvokeAsync
    // re-render — so the live stepper would localize to English while the rest of the page (rendered on
    // the circuit) stays Arabic. Re-apply the circuit's captured culture before each background render.
    private void ApplyCulture()
    {
        System.Globalization.CultureInfo.CurrentCulture = _culture;
        System.Globalization.CultureInfo.CurrentUICulture = _uiCulture;
    }

    protected override void OnInitialized()
    {
        Notifier.Progress += OnProgress;
        Notifier.Completed += OnCompleted;
        Notifier.Enriched += OnEnriched;
        Notifier.Partial += OnPartial;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Capture the viewer's culture from the interactive circuit (the first render already localized
        // the static page to it) so background callbacks can restore it before re-rendering the stepper.
        _culture = System.Globalization.CultureInfo.CurrentCulture;
        _uiCulture = System.Globalization.CultureInfo.CurrentUICulture;

        _userId = await CurrentUser.GetUserIdAsync();
        if (!string.IsNullOrWhiteSpace(Q)) _input = Q!;

        if (_userId is not null)
        {
            // Only promise an email when one will actually be sent (provider configured + user opted in).
            var recipient = await EmailPrefs.GetRecipientAsync(_userId);
            _emailNotice = Email.IsEnabled && recipient is { WantsSearchEmails: true };

            await LoadStateAsync();

            // Opening a saved search from History: show its stored results instead of the live convo.
            if (HistoryId is int hid)
            {
                await LoadHistoryResultAsync(hid);
            }
        }

        StateHasChanged();
    }

    // Re-display a saved history entry's results (no network). Falls back to prefilling the query for
    // older entries saved before results were persisted.
    private async Task LoadHistoryResultAsync(int id)
    {
        var entry = await History.GetAsync(_userId!, id);
        if (entry is null)
        {
            return;
        }

        if (entry.ResultJson is { Length: > 0 } resultJson)
        {
            _query = entry.Query;
            _status = "completed";
            _jobId = null;
            StopEnrichmentWatch();
            _progress.Clear();
            _answer = ResultSerialization.Deserialize<AgentAnswer>(resultJson);
        }
        else
        {
            _input = entry.Query; // pre-results entry — let the user re-run it
        }
    }

    private async Task LoadStateAsync()
    {
        _recent = (await History.ListAsync(_userId!, page: 1, pageSize: 15)).Items.ToList();

        var convo = await ConvoStore.GetAsync(_userId!);
        if (convo is not null)
        {
            _query = convo.CurrentQuery;
            _status = convo.CurrentStatus;
            _jobId = convo.CurrentJobId;
            if (convo.CurrentStatus == "completed" && convo.CurrentResultJson is not null)
            {
                _answer = ResultSerialization.Deserialize<AgentAnswer>(convo.CurrentResultJson);
                // Reconnecting to a freshly-completed search (reload / second tab): its deep dive may
                // still be running, so resume the open-unit watch for the hint.
                if (convo.CurrentJobId is int completedJob && _answer?.Products is { HasListings: true })
                {
                    StartEnrichmentWatch(completedJob);
                }
            }
            else if (convo.CurrentStatus == "running" && convo.CurrentJobId is int runningJob)
            {
                // Reconnecting to a search still running on the server (reload, or a second tab): seed the
                // stepper with the job's current stage so we show real progress immediately instead of a
                // blank/step-1 view. The broadcaster caches the latest signal in memory; live OnProgress
                // updates carry on from here. If the cache was lost (server restarted since the job
                // started) we fall back to the first stage rather than showing nothing.
                var latest = Notifier.LatestProgress(_userId!, runningJob)
                    ?? SearchProgressSignal.Encode(SearchStep.Analyzing, "Progress.Msg.Strategy");
                _progress.Clear();
                _progress.Add(latest);
            }
        }

        // Nothing live or freshly-completed to show, but the user has saved results: re-display their
        // most recent search instead of a blank hero / empty state. A running search is left untouched
        // (the guard above), and an idle/errored/cancelled conversation no longer hides good prior
        // results — those live in history and are the "last search" the user expects to see on load.
        // "interrupted" is excluded alongside "running": a restart-killed search must show the interrupt
        // notice + retry prompt, not silently fall back to re-displaying the user's last saved result.
        if (_status is not "running" and not "interrupted" && _answer is null)
        {
            var lastWithResult = _recent.FirstOrDefault(h => !string.IsNullOrEmpty(h.ResultJson));
            if (lastWithResult is not null)
            {
                _query = lastWithResult.Query;
                _status = "completed";
                _jobId = null;
                StopEnrichmentWatch();
                _answer = ResultSerialization.Deserialize<AgentAnswer>(lastWithResult.ResultJson!);
            }
        }
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SubmitAsync();
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_input) || _status == "running") return;

        if (_userId is null)
        {
            await PromptSignInAsync();
            return;
        }

        var query = _input.Trim();

        // Market detection, in priority order — we never silently assume a default:
        //   1) the query text itself ("AC in Dubai" → UAE),
        //   2) the browser's geolocation, mapped to the nearest supported market,
        //   3) otherwise stop and ask the user inline.
        var detected = GeoProfiles.DetectInText(query)?.Key ?? await DetectFromLocationAsync();
        if (detected is null)
        {
            _pendingQuery = query;
            _awaitingMarket = true;
            return;
        }

        _awaitingMarket = false;
        await RunSearchAsync(query, detected);
    }

    // Step 2 of market detection: the browser's geolocation, mapped to the nearest supported market.
    // Resolved once per session and cached — a denial/timeout (null) makes the caller fall through to
    // asking, and we won't badger the user with the location prompt again on the next search.
    private async Task<string?> DetectFromLocationAsync()
    {
        if (!_geoTried)
        {
            _geoMarket = await Store.DetectMarketFromLocationAsync();
            _geoTried = true;
        }

        return _geoMarket;
    }

    // Runs the query the user submitted before we knew the market, now that they've picked one inline.
    private async Task RunPendingSearchAsync(string market)
    {
        var query = _pendingQuery;
        _awaitingMarket = false;
        _pendingQuery = null;
        if (string.IsNullOrWhiteSpace(query)) return;

        await RunSearchAsync(query, market);
    }

    private async Task RunSearchAsync(string query, string geo)
    {
        var model = await Store.GetAsync("model");
        var isAdmin = await CurrentUser.IsAdminAsync();

        var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var result = await Conversations.SubmitAsync(_userId!, isAdmin, query, geo, model, lang);
        if (!result.Accepted)
        {
            _status = "error";
            _error = result.Error;
            return;
        }

        _query = query;
        _input = string.Empty;
        _jobId = result.JobId;
        _status = "running";
        _error = null;
        _answer = null;
        StopEnrichmentWatch(); // a new search owns the screen — drop the previous job's deep-dive hint
        _progress.Clear();
        // Encoded so SearchProgress localizes it and lights up the first stepper stage immediately.
        _progress.Add(SearchProgressSignal.Encode(SearchStep.Analyzing, "Progress.Msg.Strategy"));
    }

    private async Task CancelAsync()
    {
        if (_userId is null || _jobId is not { } id)
        {
            return;
        }

        await Conversations.CancelAsync(_userId, id);

        // Respond immediately rather than waiting for the worker to reach its next cancellation
        // checkpoint. Clearing _jobId makes OnProgress/OnCompleted ignore any in-flight broadcasts for
        // this job, so a late progress message can't resurrect the "running" UI. The query stays in the
        // box so the user can tweak and retry.
        _jobId = null;
        _status = "cancelled";
        StopEnrichmentWatch();
        _progress.Clear();
        if (!string.IsNullOrWhiteSpace(_query))
        {
            _input = _query!;
        }
        StateHasChanged();
    }

    // Real-time updates from the background worker — fan out to every device of this user.
    private void OnProgress(string userId, int jobId, string message)
    {
        if (userId != _userId || jobId != _jobId) return;
        InvokeAsync(() =>
        {
            ApplyCulture(); // localize the streamed stepper in the viewer's language, not the worker's
            // Never resurrect "running" once the job has completed/errored — a late or background
            // (enrichment) progress message must not hide the result that's already on screen.
            if (_status is "completed" or "error" or "cancelled") return;
            _status = "running";
            _query ??= "…";
            if (_progress.Count == 0 || _progress[^1] != message) _progress.Add(message);
            StateHasChanged();
        });
    }

    private void OnCompleted(string userId, int jobId, string status, string? resultJson, string? resultType, string? error)
    {
        if (userId != _userId || jobId != _jobId) return;
        InvokeAsync(async () =>
        {
            ApplyCulture();
            // Map the broadcast status to a UI state. "cancelled" is distinct from a hard error so a tab
            // that didn't initiate the cancel (a second device, or a sweep-forced cancel) shows the
            // cancelled notice rather than the generic "no results" error panel.
            _status = status switch
            {
                "completed" => "completed",
                "cancelled" => "cancelled",
                _ => "error"
            };
            _error = error;
            _answer = status == "completed" && resultJson is not null
                ? ResultSerialization.Deserialize<AgentAnswer>(resultJson)
                : null;
            // Base results are now on screen; the server keeps deep-diving in the background. Watch
            // the enrichment queue's open-unit count and show the "still enriching" hint while any
            // of this job's units are pending/running.
            if (_status == "completed" && _answer?.Products is { HasListings: true })
            {
                StartEnrichmentWatch(jobId);
            }
            else
            {
                StopEnrichmentWatch();
            }
            _recent = (await History.ListAsync(_userId!, page: 1, pageSize: 15)).Items.ToList();
            StateHasChanged();
        });
    }

    // A streamed result refresh after completion (item deep-dive specs arrived). Re-render in place
    // without resetting the "completed" state.
    private void OnEnriched(string userId, int jobId, string resultJson, string resultType)
    {
        if (userId != _userId || jobId != _jobId) return;
        InvokeAsync(() =>
        {
            ApplyCulture();
            _answer = ResultSerialization.Deserialize<AgentAnswer>(resultJson) ?? _answer;
            // A unit just landed — re-check the open count right away (then back to the 5s cadence)
            // so the hint disappears the moment the last unit finishes, not up to 5s later.
            _enrichTimer?.Change(TimeSpan.Zero, TimeSpan.FromSeconds(5));
            StateHasChanged();
        });
    }

    // An INTERMEDIATE result while the search is still running: render the grid now and keep the
    // stepper going — results load as they're ready, the UI never waits on the whole workflow. A
    // partial that races the completion is ignored (Completed's answer supersedes).
    private void OnPartial(string userId, int jobId, string resultJson, string resultType)
    {
        if (userId != _userId || jobId != _jobId) return;
        InvokeAsync(() =>
        {
            ApplyCulture();
            if (_status != "running") return;
            _answer = ResultSerialization.Deserialize<AgentAnswer>(resultJson) ?? _answer;
            StateHasChanged();
        });
    }

    private void StartEnrichmentWatch(int jobId)
    {
        StopEnrichmentWatch();
        _enrichChecks = 0;
        _enrichSeenWork = false;
        // First check after 1s, not immediately: the worker broadcasts completion BEFORE inserting
        // the plan unit, so an instant poll could see an empty queue and give up prematurely.
        _enrichTimer = new Timer(
            _ => _ = InvokeAsync(() => CheckEnrichmentAsync(jobId)), null,
            TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(5));
    }

    private void StopEnrichmentWatch()
    {
        _enrichTimer?.Dispose();
        _enrichTimer = null;
        _openEnrichment = 0;
    }

    private async Task CheckEnrichmentAsync(int jobId)
    {
        ApplyCulture(); // Timer fires on a background thread — localize the "still enriching" hint in the viewer's culture
        // Stale tick: the screen moved on (new search, cancel, history view) — stop watching.
        if (_enrichTimer is null || _jobId != jobId || _status != "completed")
        {
            StopEnrichmentWatch();
            return;
        }

        int open;
        try
        {
            open = await EnrichQueue.OpenCountAsync(jobId);
        }
        catch
        {
            return; // transient DB blip — keep the current hint and try again next tick
        }

        _enrichChecks++;
        if (open > 0) _enrichSeenWork = true;

        // Stop at zero — but only once we've either seen work drain or given the enqueue a grace
        // window (~3 checks): completion is broadcast before the plan unit is inserted, and some
        // completions (cache ServeAsIs, cost-cap) legitimately never enqueue anything.
        if (open == 0 && (_enrichSeenWork || _enrichChecks >= 3))
        {
            _enrichTimer?.Dispose();
            _enrichTimer = null;
        }

        if (_openEnrichment != open)
        {
            _openEnrichment = open;
            StateHasChanged();
        }
    }

    private void Prefill(string query) => _input = query;

    private async Task PromptSignInAsync()
    {
        var ok = await Dialogs.ShowMessageBox(L["Home.SignInDialog.Title"],
            L["Home.SignInDialog.Body"],
            yesText: L["Nav.Login"], cancelText: L["Search.Cancel"]);
        if (ok == true)
        {
            // forceLoad: true — see RedirectToLogin: /login's antiforgery cookie must be set on a full
            // document load, not an enhanced-navigation fetch, or the first sign-in POST fails.
            Nav.NavigateTo("/login?returnUrl=%2F", forceLoad: true);
        }
    }

    public void Dispose()
    {
        Notifier.Progress -= OnProgress;
        Notifier.Completed -= OnCompleted;
        Notifier.Enriched -= OnEnriched;
        Notifier.Partial -= OnPartial;
        _enrichTimer?.Dispose();
    }
}
