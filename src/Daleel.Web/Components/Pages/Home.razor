@page "/"
@implements IDisposable
@inject ICurrentUser CurrentUser
@inject IConversationService Conversations
@inject IConversationStore ConvoStore
@inject IConversationNotifier Notifier
@inject ISearchHistoryRepository History
@inject BrowserStore Store
@inject IDialogService Dialogs
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · Daleel</PageTitle>

@* Signed-out visitors get the marketing landing page; the search/chat workspace is for members only. *@
<AuthorizeView>
<NotAuthorized>
    <LandingPage />
</NotAuthorized>
<Authorized>
<MudGrid Spacing="3">
    <!-- Conversation history sidebar -->
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-3" Outlined="true" Elevation="0" Style="position:sticky;top:80px;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Search.Recent"]</MudText>
            @if (_recent.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">No searches yet.</MudText>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var h in _recent)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ChatBubbleOutline"
                                     OnClick="@(() => Prefill(h.Query))">
                            <MudText Typo="Typo.body2" dir="@Catalog.Dir(h.Query)" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@h.Query</MudText>
                        </MudListItem>
                    }
                </MudList>
                <MudButton Href="/history" Size="Size.Small" Variant="Variant.Text" Class="mt-1">@L["Search.ViewAll"]</MudButton>
            }
        </MudPaper>
    </MudItem>

    <!-- Main conversation column -->
    <MudItem xs="12" md="9">
        @if (_query is null && _status is "idle" or null)
        {
            <div class="daleel-hero">
                <div class="daleel-logo">دليل</div>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mt-1">
                    Your smart shopping assistant · مساعدك الذكي للتسوّق
                </MudText>
            </div>
        }

        @if (_query is not null)
        {
            <MudPaper Class="pa-4 mb-3" Outlined="true" Elevation="0">
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" />
                    <MudText Typo="Typo.h6" dir="@Catalog.Dir(_query)">@_query</MudText>
                </div>
            </MudPaper>
        }

        @if (_status == "running")
        {
            <MudPaper Class="pa-4 mb-3" Outlined="true" Elevation="0">
                <div class="d-flex align-center mb-2">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                    <MudText Typo="Typo.subtitle2">@L["Search.Searching"]</MudText>
                    <MudSpacer />
                    <MudButton Size="Size.Small" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop"
                               OnClick="CancelAsync">@L["Search.Cancel"]</MudButton>
                </div>
                <MudList T="string" Dense="true">
                    @foreach (var line in _progress)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ChevronRight">
                            <MudText Typo="Typo.body2">@line</MudText>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        }

        @if (_status == "error")
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">@(_error ?? "Search failed.")</MudAlert>
        }

        @if (_status == "completed" && _answer is not null)
        {
            <ReportView Title="@(L["Search.Summary"])" Text="@_answer.Summary" />
            @if (_answer.Products is { } products && (products.HasListings || products.StoreCount > 0 || products.BrandCount > 0 || products.ReviewCount > 0))
            {
                <AdaptiveResults Result="products" />
            }
            <SourceChips Sources="_answer.Research.Sources" />
        }

        <!-- Chat input -->
        <MudPaper Class="pa-3 mt-4" Outlined="true" Elevation="0" Style="position:sticky;bottom:12px;border-radius:14px;">
            <div class="d-flex align-center gap-2">
                <MudTextField @bind-Value="_input" Placeholder="@(L["Search.Placeholder"])" Variant="Variant.Text"
                              Immediate="true" OnKeyDown="OnKey" Class="mt-0" Disabled="_running" />
                <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                               OnClick="SubmitAsync" Disabled="@(_running || string.IsNullOrWhiteSpace(_input))" />
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>
</Authorized>
</AuthorizeView>

@code {
    [SupplyParameterFromQuery] private string? Q { get; set; }

    private string? _userId;
    private string _input = string.Empty;
    private string? _query;
    private string? _status; // idle | running | completed | error
    private string? _error;
    private int? _jobId;
    private bool _running => _status == "running";
    private readonly List<string> _progress = new();
    private AgentAnswer? _answer;
    private List<SearchHistoryEntry> _recent = new();

    protected override void OnInitialized()
    {
        Notifier.Progress += OnProgress;
        Notifier.Completed += OnCompleted;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _userId = await CurrentUser.GetUserIdAsync();
        if (!string.IsNullOrWhiteSpace(Q)) _input = Q!;

        if (_userId is not null)
        {
            await LoadStateAsync();
        }

        StateHasChanged();
    }

    private async Task LoadStateAsync()
    {
        var convo = await ConvoStore.GetAsync(_userId!);
        if (convo is not null)
        {
            _query = convo.CurrentQuery;
            _status = convo.CurrentStatus;
            _jobId = convo.CurrentJobId;
            if (convo.CurrentStatus == "completed" && convo.CurrentResultJson is not null)
            {
                _answer = ResultSerialization.Deserialize<AgentAnswer>(convo.CurrentResultJson);
            }
        }

        _recent = (await History.ListAsync(_userId!, page: 1, pageSize: 15)).Items.ToList();
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SubmitAsync();
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_input) || _status == "running") return;

        if (_userId is null)
        {
            await PromptSignInAsync();
            return;
        }

        var geo = await Store.GetAsync("geo") ?? "jordan";
        var model = await Store.GetAsync("model");
        var isAdmin = await CurrentUser.IsAdminAsync();

        var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var result = await Conversations.SubmitAsync(_userId, isAdmin, _input, geo, model, lang);
        if (!result.Accepted)
        {
            _status = "error";
            _error = result.Error;
            return;
        }

        _query = _input.Trim();
        _input = string.Empty;
        _jobId = result.JobId;
        _status = "running";
        _error = null;
        _answer = null;
        _progress.Clear();
        _progress.Add("🔍 Generating search strategy…");
    }

    private async Task CancelAsync()
    {
        if (_userId is not null && _jobId is { } id)
        {
            await Conversations.CancelAsync(_userId, id);
        }
    }

    // Real-time updates from the background worker — fan out to every device of this user.
    private void OnProgress(string userId, int jobId, string message)
    {
        if (userId != _userId || jobId != _jobId) return;
        InvokeAsync(() =>
        {
            _status = "running";
            _query ??= "…";
            if (_progress.Count == 0 || _progress[^1] != message) _progress.Add(message);
            StateHasChanged();
        });
    }

    private void OnCompleted(string userId, int jobId, string status, string? resultJson, string? resultType, string? error)
    {
        if (userId != _userId || jobId != _jobId) return;
        InvokeAsync(async () =>
        {
            _status = status == "completed" ? "completed" : "error";
            _error = error;
            _answer = status == "completed" && resultJson is not null
                ? ResultSerialization.Deserialize<AgentAnswer>(resultJson)
                : null;
            _recent = (await History.ListAsync(_userId!, page: 1, pageSize: 15)).Items.ToList();
            StateHasChanged();
        });
    }

    private void Prefill(string query) => _input = query;

    private async Task PromptSignInAsync()
    {
        var ok = await Dialogs.ShowMessageBox("Sign in to search",
            "Create a free account to run searches — you get 5 free searches every month.",
            yesText: "Sign in", cancelText: "Cancel");
        if (ok == true)
        {
            Nav.NavigateTo("/login?returnUrl=%2F");
        }
    }

    public void Dispose()
    {
        Notifier.Progress -= OnProgress;
        Notifier.Completed -= OnCompleted;
    }
}
