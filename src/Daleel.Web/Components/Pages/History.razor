@page "/history"
@attribute [Authorize]
@inject ICurrentUser CurrentUser
@inject ISearchHistoryRepository HistoryRepo
@inject NavigationManager Nav
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · History</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@L["History.Title"]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @L["History.Subtitle"]
</MudText>

@if (_ready && !_authenticated)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        <MudText>@L["History.SignInPrompt"]</MudText>
        <MudButton Href="/login" Variant="Variant.Text" Color="Color.Primary" Class="mt-2">@L["Nav.Login"]</MudButton>
    </MudAlert>
}
else if (_authenticated)
{
    <MudPaper Class="pa-3 mb-3" Elevation="0" Outlined="true">
        <div class="d-flex flex-wrap gap-3 align-center">
            <MudTextField @bind-Value="_search" @bind-Value:after="OnSearchChanged"
                          Placeholder="@L["History.FilterPlaceholder"]" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList"
                          Immediate="false" DebounceInterval="300" Style="flex:1;min-width:240px;" />
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearAllAsync">
                @L["History.ClearAll"]
            </MudButton>
        </div>
    </MudPaper>

    <MudTable T="SearchHistoryEntry" ServerData="LoadAsync" @ref="_table" Hover="true"
              Dense="true" Bordered="false" Striped="true">
        <HeaderContent>
            <MudTh>@L["History.Col.When"]</MudTh>
            <MudTh>@L["History.Col.Type"]</MudTh>
            <MudTh>@L["History.Col.Query"]</MudTh>
            <MudTh>@L["History.Col.Market"]</MudTh>
            <MudTh>@L["History.Col.Summary"]</MudTh>
            <MudTh Style="text-align:right;">@L["History.Col.Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["History.Col.When"]">
                <MudText Typo="Typo.caption">@context.CreatedAt.LocalDateTime.ToString("g")</MudText>
            </MudTd>
            <MudTd DataLabel="@L["History.Col.Type"]">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@context.QueryType</MudChip>
            </MudTd>
            <MudTd DataLabel="@L["History.Col.Query"]">
                <MudLink Typo="Typo.body2" Underline="Underline.Hover" dir="@Catalog.Dir(context.Query)"
                         OnClick="@(() => Open(context))" Style="cursor:pointer;text-align:start;">
                    @context.Query
                </MudLink>
            </MudTd>
            <MudTd DataLabel="@L["History.Col.Market"]">@Catalog.ResolveGeo(context.Geo).English</MudTd>
            <MudTd DataLabel="@L["History.Col.Summary"]">
                <MudText Typo="Typo.caption" Color="Color.Secondary" dir="@Catalog.Dir(context.ResultSummary ?? "")">
                    @context.ResultSummary
                </MudText>
            </MudTd>
            <MudTd Style="text-align:right;">
                <MudTooltip Text="@L["History.Open"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => Open(context))" />
                </MudTooltip>
                <MudTooltip Text="@L["History.Rerun"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Replay" Size="Size.Small"
                                   OnClick="@(() => Rerun(context))" />
                </MudTooltip>
                <MudTooltip Text="@L["History.Delete"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(context))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4" Color="Color.Secondary">@L["History.Empty"]</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 20, 50 }" />
        </PagerContent>
    </MudTable>
}

@code {
    private MudTable<SearchHistoryEntry>? _table;
    private string? _userId;
    private bool _ready;
    private bool _authenticated;
    private string _search = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _userId = await CurrentUser.GetUserIdAsync();
        _authenticated = _userId is not null;
        _ready = true;
        StateHasChanged();
    }

    private async Task<TableData<SearchHistoryEntry>> LoadAsync(TableState state, CancellationToken token)
    {
        if (_userId is null)
        {
            return new TableData<SearchHistoryEntry> { Items = Array.Empty<SearchHistoryEntry>(), TotalItems = 0 };
        }

        var page = await HistoryRepo.ListAsync(_userId, _search, state.Page + 1, state.PageSize, token);
        return new TableData<SearchHistoryEntry> { Items = page.Items, TotalItems = page.TotalCount };
    }

    private Task OnSearchChanged() => _table?.ReloadServerData() ?? Task.CompletedTask;

    private async Task DeleteAsync(SearchHistoryEntry entry)
    {
        if (_userId is null)
        {
            return;
        }

        await HistoryRepo.DeleteAsync(_userId, entry.Id);
        Snackbar.Add(L["History.Deleted"], Severity.Success);
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }

    private async Task ClearAllAsync()
    {
        var ok = await Dialogs.ShowMessageBox(L["History.ClearDialog.Title"],
            L["History.ClearDialog.Body"], yesText: L["History.ClearAll"], cancelText: L["Search.Cancel"]);
        if (ok != true || _userId is null)
        {
            return;
        }

        var count = await HistoryRepo.ClearAsync(_userId);
        Snackbar.Add(string.Format(L["History.Cleared"], count), Severity.Success);
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }

    // Open loads the SAVED results for this search (no re-run) — Home renders the stored ResultJson.
    private void Open(SearchHistoryEntry entry) =>
        Nav.NavigateTo($"/?historyId={entry.Id}");

    // Re-run sends the visitor to the originating feature page with the query pre-filled (?q=).
    private void Rerun(SearchHistoryEntry entry)
    {
        var route = entry.QueryType switch
        {
            "brand" => "/brand",
            "stores" => "/stores",
            "deals" => "/deals",
            "compare" => "/compare",
            _ => "/"
        };
        Nav.NavigateTo($"{route}?q={Uri.EscapeDataString(entry.Query)}&geo={Uri.EscapeDataString(entry.Geo)}");
    }
}
