@page "/compare"
@inherits AgentPageBase
@inject IStringLocalizer<SharedResource> L
@inject IProductDetailDbService Details

<PageTitle>دليل · @L["Compare.Title"]</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@L["Compare.Title"]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @L["Compare.Subtitle"]
</MudText>

<MudPaper Class="pa-4" Elevation="0" Outlined="true">
    <MudGrid Spacing="3" Class="align-center">
        <MudItem xs="12" md="5">
            <MudTextField @bind-Value="_a" Label="@L["Compare.ProductA"]"
                          Placeholder="e.g. iPhone 15" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Smartphone" />
        </MudItem>
        <MudItem xs="12" md="2" Class="text-center">
            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled">VS</MudChip>
        </MudItem>
        <MudItem xs="12" md="5">
            <MudTextField @bind-Value="_b" Label="@L["Compare.ProductB"]"
                          Placeholder="e.g. Galaxy S24" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Smartphone" />
        </MudItem>
    </MudGrid>
    <div class="d-flex flex-wrap gap-3 align-center mt-3">
        <div style="min-width:230px;flex:1;"><GeoSelect @bind-Value="Geo" /></div>
        <div style="min-width:230px;flex:1;"><ModelSelect @bind-Value="Model" /></div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Compare" OnClick="Run"
                   Disabled="Busy || string.IsNullOrWhiteSpace(_a) || string.IsNullOrWhiteSpace(_b)">
            @L["Products.Compare"]
        </MudButton>
    </div>
</MudPaper>

@if (Ready)
{
    <div class="mt-4"><ProviderStatusBar /></div>
}
@if (Error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-3">@Error</MudAlert>
}
<ProgressLog Busy="Busy" Lines="LogLines" />

@if (_result is null && !Busy && Error is null && LogLines.Count > 0)
{
    @* A comparison ran but produced no result: show a clear empty state instead of blank space. *@
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-3">@L["Search.NoResults"]</MudAlert>
}

@if (_result is not null && !Busy)
{
    <div class="d-flex my-3">
        <MudSpacer />
        <SaveResultButton Result="_result" ResultType="compare" DefaultTitle="@_compareTitle" SearchHistoryId="LastHistoryId" />
    </div>

    @if (!_result.Schema.IsEmpty)
    {
        @* Product-type-aware comparison dimensions: the specs that actually decide this category,
           as determined by the up-front intelligence pass. *@
        <MudPaper Class="pa-3 mt-2" Outlined="true" Elevation="0">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Comparing as <strong>@_result.Schema.ProductType</strong> — key dimensions:
            </MudText>
            <div class="d-flex flex-wrap gap-1 mt-1">
                @foreach (var f in _result.Schema.Fields)
                {
                    <MudChip T="string" Size="Size.Small"
                             Variant="@(f.Importance == Daleel.Core.Intelligence.SpecImportance.Key ? Variant.Filled : Variant.Outlined)"
                             Color="@(f.Importance == Daleel.Core.Intelligence.SpecImportance.Key ? Color.Primary : Color.Default)">
                        @f.Label@(string.IsNullOrWhiteSpace(f.Unit) ? "" : $" ({f.Unit})")
                    </MudChip>
                }
            </div>
        </MudPaper>
    }

    @* Deep per-spec table: the actual values for each product (6.7" vs 6.1", 8 GB vs 6 GB, lowest
       price…), schema-ordered with the better value per row highlighted and "N/A" where a spec is
       missing. Same component the in-results compare dialog uses. *@
    @if (_models.Count >= 2)
    {
        <MudPaper Class="pa-3 mt-3" Outlined="true" Elevation="0">
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.TableChart" Class="mr-1" />Spec-by-spec
            </MudText>
            <ComparisonTable Items="_models" Schema="_result.Schema" />
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-3">
            Specs not yet profiled for a side-by-side table — these products haven't been fully saved to
            the database yet. The verdict and pros/cons below still apply; search for each product first
            to build out its spec sheet.
        </MudAlert>
    }

    <MudGrid Spacing="3" Class="mt-2">
        @foreach (var (product, index) in _result.Products.Select((p, i) => (p, i)))
        {
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 daleel-card" Elevation="0" Outlined="true"
                          Style="@($"border-top:3px solid {(index == 0 ? "var(--mud-palette-primary)" : "var(--mud-palette-secondary)")};")">
                    <div class="d-flex justify-space-between align-center">
                        <MudText Typo="Typo.h6" dir="@Catalog.Dir(product)">@product</MudText>
                        @if (string.Equals(_result.Winner, product, StringComparison.OrdinalIgnoreCase))
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.EmojiEvents">Winner</MudChip>
                        }
                    </div>
                    @{ var b = _result.Breakdown.FirstOrDefault(x => string.Equals(x.Name, product, StringComparison.OrdinalIgnoreCase)); }
                    @if (b is not null)
                    {
                        @if (b.Pros.Count > 0)
                        {
                            <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="mt-2">@L["Compare.Pros"]</MudText>
                            @foreach (var pro in b.Pros)
                            {
                                <MudText Typo="Typo.body2" dir="@Catalog.Dir(pro)">＋ @pro</MudText>
                            }
                        }
                        @if (b.Cons.Count > 0)
                        {
                            <MudText Typo="Typo.subtitle2" Color="Color.Error" Class="mt-2">@L["Compare.Cons"]</MudText>
                            @foreach (var con in b.Cons)
                            {
                                <MudText Typo="Typo.body2" dir="@Catalog.Dir(con)">－ @con</MudText>
                            }
                        }
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <ReportView Title="@L["Compare.Verdict"]" Text="@_result.Summary" />
    <SourceChips Sources="_result.Sources" />
}

@code {
    [SupplyParameterFromQuery] private string? Q { get; set; }
    [SupplyParameterFromQuery(Name = "geo")] private string? GeoParam { get; set; }

    private string _a = string.Empty;
    private string _b = string.Empty;
    private ProductComparison? _result;

    // Full spec sheets for the two products, read from the saved database so the per-spec table shows
    // real values (not just the schema dimensions). Empty when neither product has been profiled yet.
    private List<ProductModel> _models = new();

    private string _compareTitle => string.IsNullOrWhiteSpace(_a) && string.IsNullOrWhiteSpace(_b)
        ? "Compare"
        : $"{_a} vs {_b}";

    // History stores compare queries as "A vs B"; split them back into the two fields on re-run.
    protected override Task OnReadyAsync()
    {
        if (!string.IsNullOrWhiteSpace(Q))
        {
            var parts = Q!.Split(" vs ", 2, StringSplitOptions.TrimEntries);
            _a = parts.ElementAtOrDefault(0) ?? string.Empty;
            _b = parts.ElementAtOrDefault(1) ?? string.Empty;
        }

        if (!string.IsNullOrWhiteSpace(GeoParam))
        {
            Geo = GeoParam!;
        }

        return Task.CompletedTask;
    }

    private async Task Run()
    {
        if (string.IsNullOrWhiteSpace(_a) || string.IsNullOrWhiteSpace(_b))
        {
            return;
        }

        _result = null;
        _models = new();
        await Store.SetAsync("geo", Geo);
        await Store.SetAsync("model", Model);
        var products = new[] { _a.Trim(), _b.Trim() };
        await RunAsync(
            async (agent, ct) =>
            {
                _result = await agent.CompareAsync(products, Geo, ct);
                // Read each product's saved spec sheet from the database so the side-by-side table shows
                // actual values. A product not yet profiled is simply dropped and the table degrades
                // gracefully (the alert above explains the "specs not yet profiled" case).
                _models = new();
                foreach (var product in products)
                {
                    var model = await Details.GetComparableAsync(product, ct);
                    if (model is not null)
                    {
                        _models.Add(model);
                    }
                }
            },
            () => _result is null ? null : new SearchHistoryEntry
            {
                Query = $"{_a.Trim()} vs {_b.Trim()}",
                QueryType = "compare",
                ResultSummary = _result.Summary
            });
    }
}
