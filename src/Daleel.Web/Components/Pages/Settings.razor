@page "/settings"
@inject BrowserStore Store
@inject LayoutState Layout
@inject ISnackbar Snackbar
@inject ICurrentUser CurrentUser
@inject IQuotaService Quota
@inject IStringLocalizer<SharedResource> L
@inject UserManager<ApplicationUser> Users
@using Daleel.Core.Moderation
@using Daleel.Web.Data
@using Microsoft.AspNetCore.Identity

<PageTitle>دليل · Settings</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@L["Settings.Title"]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @L["Settings.Subtitle"]
</MudText>

<MudGrid Spacing="3">
    @if (_credits is not null)
    {
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <div class="d-flex align-center mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="mr-2" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">@L["Settings.Credits"]</MudText>
                    <MudSpacer />
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@_credits.PlanName</MudChip>
                </div>
                @if (_credits.IsAdmin || _credits.Unlimited)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Settings.CreditsUnlimited"]</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mb-1">
                        <b>@_credits.Remaining</b> / @_credits.Limit @L["Settings.CreditsLeft"]
                    </MudText>
                    <MudProgressLinear Color="@(_credits.CanSearch ? Color.Primary : Color.Error)"
                                       Value="@CreditPercent" Class="my-2" Size="Size.Large" Rounded="true" />
                    <div class="d-flex align-center flex-wrap gap-2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @L["Settings.CreditsHelp"] @_credits.PeriodEnd.ToString("MMM d").
                        </MudText>
                        <MudSpacer />
                        <MudButton Href="/pricing" Size="Size.Small" Variant="Variant.Outlined"
                                   Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upgrade">
                            @L["Settings.CreditsGetMore"]
                        </MudButton>
                    </div>
                }
            </MudPaper>
        </MudItem>
    }
    @* Preferences available to every user. Admin-only config (API keys, default model,
       content filter, image safety) lives in the separate admin column below. *@
    <MudItem xs="12" md="@(_isAdmin ? 5 : 7)">
        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <div class="d-flex align-center mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Tune" Class="mr-2" />
                <MudText Typo="Typo.h6">@L["Settings.Preferences"]</MudText>
            </div>

            <GeoSelect Value="@_geo" ValueChanged="OnGeoChanged" Label="@L["Settings.DefaultMarket"]" />

            <MudDivider Class="my-4" />

            <MudSwitch T="bool" Value="_dark" ValueChanged="OnDarkChanged" Color="Color.Primary"
                       Label="@(_dark ? L["Settings.DarkTheme"] : L["Settings.LightTheme"])"
                       ThumbIcon="@(_dark ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)" />

            @if (_hasEmail)
            {
                <MudDivider Class="my-4" />
                <MudSwitch T="bool" Value="_emailResults" ValueChanged="OnEmailResultsChanged" Color="Color.Primary"
                           Label="@L["Settings.EmailResults"]"
                           ThumbIcon="@Icons.Material.Filled.Email" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Settings.EmailResultsHelp"]</MudText>
            }

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-4">
                @L["Settings.PreferencesNote"]
            </MudAlert>
        </MudPaper>
    </MudItem>

    @* Admin-only configuration. The @if gates rendering; server-side handlers must still
       re-validate the admin role since the UI gate alone is not a security boundary. *@
    @if (_isAdmin)
    {
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <div class="d-flex align-center mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Key" Class="mr-2" />
                    <MudText Typo="Typo.h6">@L["Settings.ApiKeys"]</MudText>
                    <MudSpacer />
                    <MudSwitch T="bool" @bind-Value="_showKeys" Color="Color.Primary" Label="@L["Settings.Show"]" />
                </div>

                @if (!_ready)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else
                {
                    @foreach (var (name, label, help) in BrowserStore.ApiKeyNames)
                    {
                        <MudTextField T="string" Value="@GetKey(name)" ValueChanged="@(v => _keys[name] = v ?? string.Empty)"
                                      Label="@label" HelperText="@help"
                                      InputType="@(_showKeys ? InputType.Text : InputType.Password)"
                                      Variant="Variant.Outlined" Class="mb-3" Immediate="true"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(string.IsNullOrWhiteSpace(GetKey(name)) ? Icons.Material.Filled.RadioButtonUnchecked : Icons.Material.Filled.CheckCircle)" />
                    }

                    <div class="d-flex gap-2 mt-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save" OnClick="SaveKeys">@L["Settings.SaveKeys"]</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearKeys">@L["History.ClearAll"]</MudButton>
                    </div>
                }
            </MudPaper>

            <MudPaper Class="pa-4 mt-3" Elevation="0" Outlined="true">
                <div class="d-flex align-center mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Class="mr-2" />
                    <MudText Typo="Typo.h6">@L["Settings.DefaultModel"]</MudText>
                </div>

                <ModelSelect Value="@_model" ValueChanged="OnModelChanged" Label="@L["Settings.DefaultModel"]" />
            </MudPaper>

            <MudPaper Class="pa-4 mt-3" Elevation="0" Outlined="true">
                <div class="d-flex align-center mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="mr-2" Color="Color.Success" />
                    <MudText Typo="Typo.h6">@L["Settings.ContentFilter"]</MudText>
                </div>

                <MudSelect T="FilterStrictness" Value="_strictness" ValueChanged="OnStrictnessChanged"
                           Label="@L["Settings.HalalFiltering"]" Variant="Variant.Outlined" Dense="true">
                    <MudSelectItem Value="FilterStrictness.Strict">@L["Settings.Strict"]</MudSelectItem>
                    <MudSelectItem Value="FilterStrictness.Moderate">@L["Settings.Moderate"]</MudSelectItem>
                    <MudSelectItem Value="FilterStrictness.Off">@L["Settings.Off"]</MudSelectItem>
                </MudSelect>

                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                    @(_strictness == FilterStrictness.Strict ? L["Settings.FilterDesc.Strict"] : L["Settings.FilterDesc"])
                </MudText>
            </MudPaper>

            <MudPaper Class="pa-4 mt-3" Elevation="0" Outlined="true">
                <div class="d-flex align-center mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.HideImage" Class="mr-2" Color="Color.Info" />
                    <MudText Typo="Typo.h6">@L["Settings.ImageSafety"]</MudText>
                </div>

                <MudSwitch T="bool" Value="_blurImages" ValueChanged="OnBlurChanged" Color="Color.Primary"
                           Label="@L["Settings.BlurImages"]"
                           ThumbIcon="@Icons.Material.Filled.BlurOn" />
                <MudSwitch T="bool" Value="_haramBlurPrompt" ValueChanged="OnHaramBlurPromptChanged" Color="Color.Primary"
                           Label="@L["Settings.HaramBlurPrompt"]"
                           ThumbIcon="@Icons.Material.Filled.Extension" />

                <MudText Typo="Typo.subtitle2" Class="mt-3">@L["Settings.TrustedDomains"]</MudText>
                @if (_trustedDomains.Count == 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Settings.NoTrustedDomains"]</MudText>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2 mt-1">
                        @foreach (var d in _trustedDomains)
                        {
                            <MudChip T="string" Size="Size.Small" OnClose="@(() => RemoveTrusted(d))">@d</MudChip>
                        }
                    </div>
                }
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    private bool _ready;
    private QuotaStatus? _credits;
    private double CreditPercent => _credits?.Limit is int lim && lim > 0
        ? Math.Min(100, 100.0 * _credits.Used / lim) : 0;
    private bool _showKeys;
    private readonly Dictionary<string, string> _keys = new(StringComparer.OrdinalIgnoreCase);
    private string _geo = "jordan";
    private string _model = Catalog.DefaultModel;
    private bool _dark = true;
    private FilterStrictness _strictness = FilterStrictness.Strict;
    private bool _isAdmin;
    private bool _blurImages = true;
    private bool _haramBlurPrompt = true;
    private List<string> _trustedDomains = new();
    private bool _hasEmail;
    private bool _emailResults = true;
    private ApplicationUser? _user;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _isAdmin = await CurrentUser.IsAdminAsync();

        // Preferences shown to every user.
        _geo = await Store.GetAsync("geo") ?? _geo;
        _dark = (await Store.GetAsync("theme") ?? "dark") != "light";

        var userId = await CurrentUser.GetUserIdAsync();
        if (userId is not null)
        {
            _credits = await Quota.GetStatusAsync(userId, _isAdmin);
            _user = await Users.FindByIdAsync(userId);
            if (_user is not null)
            {
                _hasEmail = !string.IsNullOrWhiteSpace(_user.Email);
                _emailResults = _user.EmailSearchResults;
            }
        }

        // Admin-only configuration: only load it when the corresponding UI is rendered,
        // so a regular user's browser never pulls API keys (or other admin state) into memory.
        if (_isAdmin)
        {
            foreach (var (name, _, _) in BrowserStore.ApiKeyNames)
            {
                _keys[name] = await Store.GetAsync("key." + name) ?? string.Empty;
            }

            _model = await Store.GetAsync("model") ?? _model;
            _strictness = (await Store.GetAsync("filter.strictness")) switch
            {
                "off" => FilterStrictness.Off,
                "moderate" => FilterStrictness.Moderate,
                _ => FilterStrictness.Strict
            };
            _blurImages = (await Store.GetAsync("img.blur") ?? "0") != "0";
            _haramBlurPrompt = (await Store.GetAsync("img.haramblur_prompt") ?? "1") != "0";
            _trustedDomains = (await Store.GetAsync("img.trusted") ?? string.Empty)
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        }

        Layout.SetDarkMode(_dark);

        _ready = true;
        StateHasChanged();
    }

    private string GetKey(string name) => _keys.TryGetValue(name, out var v) ? v : string.Empty;

    private async Task SaveKeys()
    {
        foreach (var (name, _, _) in BrowserStore.ApiKeyNames)
        {
            var value = GetKey(name);
            if (string.IsNullOrWhiteSpace(value))
            {
                await Store.RemoveAsync("key." + name);
            }
            else
            {
                await Store.SetAsync("key." + name, value.Trim());
            }
        }

        Snackbar.Add(L["Settings.Snack.KeysSaved"], Severity.Success);
    }

    private async Task ClearKeys()
    {
        foreach (var (name, _, _) in BrowserStore.ApiKeyNames)
        {
            await Store.RemoveAsync("key." + name);
            _keys[name] = string.Empty;
        }

        Snackbar.Add(L["Settings.Snack.KeysCleared"], Severity.Info);
    }

    private async Task OnGeoChanged(string value)
    {
        _geo = value;
        await Store.SetAsync("geo", value);
    }

    private async Task OnModelChanged(string value)
    {
        _model = value;
        await Store.SetAsync("model", value);
    }

    private async Task OnDarkChanged(bool value)
    {
        _dark = value;
        Layout.SetDarkMode(value);
        await Store.SetAsync("theme", value ? "dark" : "light");
    }

    private async Task OnStrictnessChanged(FilterStrictness value)
    {
        // Defensive: never let a non-admin persist "Off" even if the option leaks into the DOM.
        if (value == FilterStrictness.Off && !_isAdmin)
        {
            value = FilterStrictness.Strict;
        }

        _strictness = value;
        await Store.SetAsync("filter.strictness", value.ToString().ToLowerInvariant());
        Snackbar.Add(string.Format(L["Settings.Snack.FilterSet"], value), Severity.Success);
    }

    private async Task OnBlurChanged(bool value)
    {
        _blurImages = value;
        await Store.SetAsync("img.blur", value ? "1" : "0");
    }

    private async Task OnHaramBlurPromptChanged(bool value)
    {
        _haramBlurPrompt = value;
        await Store.SetAsync("img.haramblur_prompt", value ? "1" : "0");
    }

    private async Task RemoveTrusted(string domain)
    {
        _trustedDomains.Remove(domain);
        await Store.SetAsync("img.trusted", string.Join(",", _trustedDomains));
    }

    private async Task OnEmailResultsChanged(bool value)
    {
        _emailResults = value;
        if (_user is null)
        {
            return;
        }

        // Server-side preference (read by the background search worker), so it persists via the user row.
        _user.EmailSearchResults = value;
        await Users.UpdateAsync(_user);
        Snackbar.Add(value ? L["Settings.Snack.EmailResultsOn"] : L["Settings.Snack.EmailResultsOff"],
            value ? Severity.Success : Severity.Info);
    }
}
