@page "/admin/credentials"
@attribute [Authorize(Roles = "Admin")]
@using Daleel.Web.Cloudflare
@inject ICredentialVault Vault
@inject ICredentialRotationService Rotation
@inject ISnackbar Snackbar

<PageTitle>دليل · Admin · Credentials</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-1">Credentials</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Worker bearer tokens and vendor API keys managed by the VPS token authority.
</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    This page is the token authority: worker bearer tokens are minted here and pushed to the
    Cloudflare workers automatically, so both sides of every app-to-worker edge always agree.
    Values are encrypted at rest and never displayed — rotate a token instead of trying to read it.
</MudAlert>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load credentials: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_workerRows is null || _vendorRows is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div class="d-flex align-center mb-2">
        <MudText Typo="Typo.h6">Worker bearers</MudText>
        <MudSpacer />
        <MudButton StartIcon="@Icons.Material.Filled.Sync" Variant="Variant.Filled" Color="Color.Primary"
                   Size="Size.Small" Disabled="_busy" OnClick="SyncAllAsync">
            @(_busy ? "Working…" : "Sync all")
        </MudButton>
    </div>
    <MudTable Items="_workerRows" Hover="true" Dense="true" Striped="true" Class="mb-6">
        <HeaderContent>
            <MudTh>Worker script</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Rotated</MudTh>
            <MudTh>Pushed</MudTh>
            <MudTh Style="text-align:right;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudText Typo="Typo.body2" Style="font-family:monospace;">@context.Script</MudText></MudTd>
            <MudTd>
                @if (context.Credential is null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">not minted</MudChip>
                }
                else if (context.Credential.Revoked)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">revoked</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">minted</MudChip>
                }
            </MudTd>
            <MudTd><MudText Typo="Typo.caption">@When(context.Credential?.CreatedAt)</MudText></MudTd>
            <MudTd><MudText Typo="Typo.caption">@When(context.Credential?.RotatedAt)</MudText></MudTd>
            <MudTd><MudText Typo="Typo.caption">@When(context.Credential?.PushedAt)</MudText></MudTd>
            <MudTd Style="text-align:right;">
                <MudTooltip Text="@(context.Credential is null
                                      ? "No bearer minted yet — run Sync all first"
                                      : "Mint a new token and push it to the worker (grace window keeps the old one valid)")">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Autorenew"
                               Disabled="@(_busy || context.Credential is null)"
                               OnClick="() => RotateAsync(context.Script)">Rotate</MudButton>
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudText Typo="Typo.h6" Class="mb-2">Vendor keys</MudText>
    <MudTable Items="_vendorRows" Hover="true" Dense="true" Striped="true" Class="mb-4">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Rotated</MudTh>
            <MudTh>Notes</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudText Typo="Typo.body2" Style="font-family:monospace;">@context.Name</MudText></MudTd>
            <MudTd>
                @if (context.Revoked)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">revoked</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">stored</MudChip>
                }
            </MudTd>
            <MudTd><MudText Typo="Typo.caption">@When(context.CreatedAt)</MudText></MudTd>
            <MudTd><MudText Typo="Typo.caption">@When(context.RotatedAt)</MudText></MudTd>
            <MudTd><MudText Typo="Typo.caption">@(context.Notes ?? "—")</MudText></MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary">No vendor keys stored yet.</MudText>
        </NoRecordsContent>
    </MudTable>

    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudText Typo="Typo.subtitle1" Class="mb-2">Add or update a vendor key</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Saving overwrites any existing value for the selected key. The value is encrypted
            immediately and cannot be read back — only replaced.
        </MudText>
        <div class="d-flex flex-wrap align-center gap-3">
            <MudSelect T="string" @bind-Value="_vendorName" Label="Key" Dense="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:260px;">
                @foreach (var name in KnownVendorKeys)
                {
                    <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_vendorValue" Label="Value" InputType="InputType.Password"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:280px;"
                          autocomplete="new-password" Immediate="true" />
            <MudTextField @bind-Value="_vendorNote" Label="Note (optional)"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:220px;" />
            <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_busy || string.IsNullOrWhiteSpace(_vendorName) || string.IsNullOrWhiteSpace(_vendorValue))"
                       OnClick="SaveVendorKeyAsync">
                @(_busy ? "Saving…" : "Save")
            </MudButton>
        </div>
    </MudPaper>
}

@code {
    private sealed class WorkerRow
    {
        public string Script { get; init; } = string.Empty;
        public ServiceCredential? Credential { get; init; }
    }

    /// <summary>The vendor env-var names the app knows how to consume from the vault.</summary>
    private static readonly string[] KnownVendorKeys =
    {
        "CONTEXT_DEV_API_KEY", "SERPAPI_KEY", "GOOGLE_PLACES_API_KEY",
        "APIFY_TOKEN", "OPENROUTER_API_KEY", "BING_SEARCH_KEY"
    };

    private List<WorkerRow>? _workerRows;
    private List<ServiceCredential>? _vendorRows;
    private string? _error;
    private bool _busy;

    private string _vendorName = string.Empty;
    private string _vendorValue = string.Empty;
    private string _vendorNote = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        // Reset to the loading state, then attempt the load; on failure surface a retryable error
        // instead of leaving the page on a permanent spinner.
        _error = null;
        _workerRows = null;
        _vendorRows = null;
        StateHasChanged();
        try
        {
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        // Metadata only — ListAsync never has its encrypted blobs rendered anywhere on this page.
        var all = await Vault.ListAsync();
        _workerRows = Rotation.WorkerScripts
            .Select(script => new WorkerRow
            {
                Script = script,
                Credential = all.FirstOrDefault(c => c.Name == Rotation.BearerNameFor(script))
            })
            .ToList();
        _vendorRows = all.Where(c => c.Kind == ServiceCredentialKind.VendorKey).ToList();
    }

    private async Task SyncAllAsync()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var synced = await Rotation.EnsureAndPushAllAsync();
            var total = Rotation.WorkerScripts.Count;
            Snackbar.Add(
                $"Synced {synced}/{total} worker bearers.",
                synced == total ? Severity.Success : Severity.Warning);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't sync worker bearers: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RotateAsync(string script)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (await Rotation.RotateWorkerAsync(script))
            {
                Snackbar.Add($"Rotated bearer for {script} and pushed it to Cloudflare.", Severity.Success);
            }
            else
            {
                // The service reports push failures via its return value: the worker keeps accepting
                // the previous token, so this is recoverable by rotating again later.
                Snackbar.Add(
                    $"Rotation of {script} didn't complete — the Cloudflare push failed. " +
                    "The worker still accepts the previous token; try again.",
                    Severity.Error);
            }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't rotate {script}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveVendorKeyAsync()
    {
        if (_busy || string.IsNullOrWhiteSpace(_vendorName) || string.IsNullOrWhiteSpace(_vendorValue))
        {
            return;
        }

        _busy = true;
        try
        {
            var note = string.IsNullOrWhiteSpace(_vendorNote) ? "set from admin" : _vendorNote.Trim();
            await Vault.SetAsync(_vendorName, _vendorValue.Trim(), ServiceCredentialKind.VendorKey, note);
            await Vault.RefreshSnapshotAsync();
            Snackbar.Add($"Stored {_vendorName}.", Severity.Success);
            _vendorNote = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't store {_vendorName}: {ex.Message}", Severity.Error);
        }
        finally
        {
            // Always drop the secret from the input — success or failure, it should never linger.
            _vendorValue = string.Empty;
            _busy = false;
        }
    }

    private static string When(DateTimeOffset? at) => at?.ToLocalTime().ToString("g") ?? "—";
}
