@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> Users
@inject DaleelDbContext Db
@inject ISnackbar Snackbar
@inject IDialogService Dialogs

<PageTitle>دليل · Admin · Users</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-4">User Management</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load users: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_rows is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTable Items="_rows" Hover="true" Dense="true" Striped="true" Filter="Matches">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Search name/email…" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>User</MudTh>
            <MudTh>Plan</MudTh>
            <MudTh>Used</MudTh>
            <MudTh>Joined</MudTh>
            <MudTh>Last active</MudTh>
            <MudTh>Roles/State</MudTh>
            <MudTh Style="text-align:right;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.body2">@(context.User.DisplayName ?? context.User.UserName)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.User.Email</MudText>
            </MudTd>
            <MudTd>
                <MudSelect T="int" Value="context.PlanId" ValueChanged="@(v => ChangePlanAsync(context, v))"
                           Dense="true" Variant="Variant.Outlined" Style="min-width:130px;">
                    @foreach (var p in _plans)
                    {
                        <MudSelectItem T="int" Value="p.Id">@p.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudTd>
            <MudTd>@context.Used</MudTd>
            <MudTd><MudText Typo="Typo.caption">@context.User.CreatedAt.ToLocalTime().ToString("d")</MudText></MudTd>
            <MudTd><MudText Typo="Typo.caption">@(context.User.LastActiveAt?.ToLocalTime().ToString("g") ?? "—")</MudText></MudTd>
            <MudTd>
                @if (context.User.IsAdmin) { <MudChip T="string" Size="Size.Small" Color="Color.Tertiary">admin</MudChip> }
                @if (context.User.IsDisabled) { <MudChip T="string" Size="Size.Small" Color="Color.Error">disabled</MudChip> }
            </MudTd>
            <MudTd Style="text-align:right;">
                <MudTooltip Text="@(context.User.IsAdmin ? "Revoke admin" : "Grant admin")">
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.AdminPanelSettings"
                                   Color="@(context.User.IsAdmin ? Color.Tertiary : Color.Default)"
                                   OnClick="@(() => ToggleAdminAsync(context))" />
                </MudTooltip>
                <MudTooltip Text="@(context.User.IsDisabled ? "Enable" : "Disable")">
                    <MudIconButton Size="Size.Small"
                                   Icon="@(context.User.IsDisabled ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.Block)"
                                   Color="@(context.User.IsDisabled ? Color.Success : Color.Error)"
                                   OnClick="@(() => ToggleDisableAsync(context))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <PagerContent><MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" /></PagerContent>
    </MudTable>
}

@code {
    private sealed class Row
    {
        public ApplicationUser User { get; set; } = default!;
        public int PlanId { get; set; }
        public int Used { get; set; }
    }

    private List<Row>? _rows;
    private List<SubscriptionPlan> _plans = new();
    private string _search = string.Empty;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        // Reset to the loading state, then attempt the load; on failure surface a retryable error
        // instead of leaving the page on a permanent spinner. H4.
        _error = null;
        _rows = null;
        StateHasChanged();
        try
        {
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _plans = await Db.SubscriptionPlans.OrderBy(p => p.SortOrder).ToListAsync();
        var users = await Users.Users.ToListAsync();

        var activeSubs = await Db.UserSubscriptions.Where(s => s.Status == "active").ToListAsync();
        var planByUser = activeSubs
            .GroupBy(s => s.UserId)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(s => s.StartedAt).First().PlanId);
        // Read-only display column: project just the two needed columns (no change tracking) and
        // build the dictionary straight from the DB rather than materializing full tracked entities.
        var usedByUser = await Db.UserQuotas
            .AsNoTracking()
            .Select(q => new { q.UserId, q.SearchesUsed })
            .ToDictionaryAsync(q => q.UserId, q => q.SearchesUsed);

        _rows = users.Select(u => new Row
        {
            User = u,
            PlanId = planByUser.GetValueOrDefault(u.Id, SubscriptionPlan.BasicId),
            Used = usedByUser.GetValueOrDefault(u.Id, 0)
        }).ToList();
    }

    private bool Matches(Row r) =>
        string.IsNullOrWhiteSpace(_search) ||
        (r.User.Email?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (r.User.DisplayName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);

    private async Task ChangePlanAsync(Row row, int planId)
    {
        if (planId == row.PlanId)
        {
            return;
        }

        var who = row.User.DisplayName ?? row.User.Email ?? "this user";
        var newPlan = _plans.FirstOrDefault(p => p.Id == planId)?.Name ?? "the selected plan";
        var confirmed = await Dialogs.ShowMessageBox(
            "Change subscription plan?",
            $"This cancels {who}'s current subscription and moves them to {newPlan}. Continue?",
            yesText: "Change plan", cancelText: "Cancel");

        if (confirmed != true)
        {
            // Revert the MudSelect to the persisted plan (its Value is bound to row.PlanId).
            StateHasChanged();
            return;
        }

        try
        {
            // Cancel any current active subscriptions, then add the new one (Basic = no subscription row).
            var current = await Db.UserSubscriptions
                .Where(s => s.UserId == row.User.Id && s.Status == "active").ToListAsync();
            foreach (var s in current) { s.Status = "cancelled"; }

            if (planId != SubscriptionPlan.BasicId)
            {
                Db.UserSubscriptions.Add(new UserSubscription
                {
                    UserId = row.User.Id, PlanId = planId, Status = "active", StartedAt = DateTimeOffset.UtcNow
                });
            }

            await Db.SaveChangesAsync();
            // Only mutate UI state after the save succeeds, so the row never diverges from the DB.
            row.PlanId = planId;
            Snackbar.Add("Plan updated.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't update plan: {ex.Message}", Severity.Error);
            StateHasChanged();
        }
    }

    private async Task ToggleAdminAsync(Row row)
    {
        var who = row.User.DisplayName ?? row.User.Email ?? "this user";
        var granting = !row.User.IsAdmin;
        var confirmed = await Dialogs.ShowMessageBox(
            granting ? "Grant admin?" : "Revoke admin?",
            granting
                ? $"Grant full admin access to {who}?"
                : $"Revoke admin from {who}? They will be signed out everywhere.",
            yesText: granting ? "Grant admin" : "Revoke admin", cancelText: "Cancel");

        if (confirmed != true)
        {
            return;
        }

        try
        {
            row.User.IsAdmin = granting;
            // IdentityResult reports failure via Succeeded/Errors rather than throwing, so check it
            // explicitly and roll back the optimistic flip before surfacing the error.
            var updateResult = await Users.UpdateAsync(row.User);
            if (!updateResult.Succeeded)
            {
                row.User.IsAdmin = !granting;
                Snackbar.Add($"Couldn't change admin role: {Describe(updateResult)}", Severity.Error);
                return;
            }
            // Rotate the security stamp so live sessions/circuits are revalidated and the role change
            // (especially a *revocation*) takes effect without waiting for the cookie to expire.
            var stampResult = await Users.UpdateSecurityStampAsync(row.User);
            if (!stampResult.Succeeded)
            {
                row.User.IsAdmin = !granting;
                Snackbar.Add($"Couldn't change admin role: {Describe(stampResult)}", Severity.Error);
                return;
            }
            Snackbar.Add(granting ? "Granted admin (effective on next sign-in)." : "Revoked admin (signed out everywhere).", Severity.Success);
        }
        catch (Exception ex)
        {
            row.User.IsAdmin = !granting; // roll back the optimistic flip
            Snackbar.Add($"Couldn't change admin role: {ex.Message}", Severity.Error);
        }
    }

    private async Task ToggleDisableAsync(Row row)
    {
        var who = row.User.DisplayName ?? row.User.Email ?? "this user";
        var disabling = !row.User.IsDisabled;
        var confirmed = await Dialogs.ShowMessageBox(
            disabling ? "Disable account?" : "Enable account?",
            disabling
                ? $"Disable {who}? This signs them out everywhere and blocks sign-in until re-enabled."
                : $"Re-enable {who}? They will be able to sign in again.",
            yesText: disabling ? "Disable" : "Enable", cancelText: "Cancel");

        if (confirmed != true)
        {
            return;
        }

        try
        {
            row.User.IsDisabled = disabling;
            // IdentityResult reports failure via Succeeded/Errors rather than throwing, so check it
            // explicitly and roll back the optimistic flip before surfacing the error.
            var updateResult = await Users.UpdateAsync(row.User);
            if (!updateResult.Succeeded)
            {
                row.User.IsDisabled = !disabling;
                Snackbar.Add($"Couldn't change account status: {Describe(updateResult)}", Severity.Error);
                return;
            }
            // Rotate the security stamp: disabling must terminate the user's existing sessions, not just
            // block the next sign-in. The revalidating auth-state provider picks this up and tears down
            // their live circuits; the cookie's stamp validation rejects subsequent requests.
            var stampResult = await Users.UpdateSecurityStampAsync(row.User);
            if (!stampResult.Succeeded)
            {
                row.User.IsDisabled = !disabling;
                Snackbar.Add($"Couldn't change account status: {Describe(stampResult)}", Severity.Error);
                return;
            }
            Snackbar.Add(disabling ? "Account disabled (signed out everywhere)." : "Account enabled.", Severity.Success);
        }
        catch (Exception ex)
        {
            row.User.IsDisabled = !disabling; // roll back the optimistic flip
            Snackbar.Add($"Couldn't change account status: {ex.Message}", Severity.Error);
        }
    }

    // IdentityResult exposes failures as a collection of IdentityError; join their descriptions for display.
    private static string Describe(IdentityResult result) =>
        result.Errors.Any() ? string.Join(" ", result.Errors.Select(e => e.Description)) : "Unknown error.";
}
