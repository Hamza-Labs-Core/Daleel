@page "/admin/moderation"
@attribute [Authorize(Roles = "Admin")]
@inject IAnalyticsService Analytics
@inject IFilteredContentLogRepository FilteredLog

<PageTitle>دليل · Admin · Moderation</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-4">Content Filter Stats</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load moderation stats: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><Kpi Title="Items filtered (30d)" Value="_totalFiltered" Icon="@Icons.Material.Filled.FilterAlt" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><Kpi Title="Searches with removals" Value="_withFilters" Icon="@Icons.Material.Filled.Shield" /></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">Most filtered categories (30d)</MudText>
        @if (_byCategory.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">Nothing has been filtered yet.</MudText>
        }
        else
        {
            @foreach (var (cat, count) in _byCategory)
            {
                <div class="d-flex justify-space-between"><span>@cat</span><b>@count</b></div>
            }
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">Classifier precision from admin ratings (90d)</MudText>
        @if (_ratingStats.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                No rated findings yet — rate findings on the
                <MudLink Href="/admin/filtered" Typo="Typo.caption">Filtered content</MudLink> page and the
                classifier's per-category confidence thresholds will adapt.
            </MudText>
        }
        else
        {
            @foreach (var s in _ratingStats)
            {
                var stat = s; // per-iteration local: deferred RenderFragments must not capture the loop var
                var rated = stat.Correct + stat.Incorrect;
                var precision = rated == 0 ? 0 : (double)stat.Correct / rated;
                var threshold = Daleel.Core.Moderation.HalalPolicy.ThresholdFromPrecision(stat.Correct, stat.Incorrect);
                <div class="d-flex justify-space-between align-center mb-1">
                    <span>@stat.Category</span>
                    <span>
                        <b>@precision.ToString("P0")</b> precision (@stat.Correct✓ / @stat.Incorrect✗)
                        · removal threshold @threshold.ToString("0.00")
                    </span>
                </div>
                <MudProgressLinear Value="@(precision * 100)"
                                   Color="@(precision >= 0.8 ? Color.Success : precision >= 0.5 ? Color.Warning : Color.Error)"
                                   Class="mb-2" />
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Low precision raises that category's confidence bar automatically — the model must be more
                certain before an item is hidden.
            </MudText>
        }
    </MudPaper>

    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">
        Filtered items are never shown to users. For the exact content removed and the rule that fired,
        see <MudLink Href="/admin/filtered" Typo="Typo.caption">Filtered content</MudLink>.
    </MudText>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _totalFiltered;
    private int _withFilters;
    private IReadOnlyList<(string Category, int Count)> _byCategory = new List<(string, int)>();
    private IReadOnlyList<CategoryRatingStats> _ratingStats = Array.Empty<CategoryRatingStats>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _loading = true;
        StateHasChanged();
        try
        {
            var (total, withFilters, byCat) = await Analytics.ModerationStatsAsync(DateTime.UtcNow.AddDays(-30));
            _totalFiltered = total;
            _withFilters = withFilters;
            _byCategory = byCat;
            _ratingStats = await FilteredLog.RatingStatsAsync(DateTimeOffset.UtcNow.AddDays(-90));
            _loading = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
        StateHasChanged();
    }
}
