@page "/admin/moderation"
@attribute [Authorize(Roles = "Admin")]
@inject IAnalyticsService Analytics
@inject IFilteredContentLogRepository FilteredLog
@inject IModerationRuleRepository Rules
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache Cache
@inject ISnackbar Snackbar

<PageTitle>دليل · Admin · Moderation</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-4">Content Filter Stats</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load moderation stats: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><Kpi Title="Items filtered (30d)" Value="_totalFiltered" Icon="@Icons.Material.Filled.FilterAlt" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><Kpi Title="Searches with removals" Value="_withFilters" Icon="@Icons.Material.Filled.Shield" /></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">Most filtered categories (30d)</MudText>
        @if (_byCategory.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">Nothing has been filtered yet.</MudText>
        }
        else
        {
            @foreach (var (cat, count) in _byCategory)
            {
                <div class="d-flex justify-space-between"><span>@cat</span><b>@count</b></div>
            }
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">Classifier precision from admin ratings (90d)</MudText>
        @if (_ratingStats.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                No rated findings yet — rate findings on the
                <MudLink Href="/admin/filtered" Typo="Typo.caption">Filtered content</MudLink> page and the
                classifier's per-category confidence thresholds will adapt.
            </MudText>
        }
        else
        {
            @foreach (var s in _ratingStats)
            {
                var stat = s; // per-iteration local: deferred RenderFragments must not capture the loop var
                var rated = stat.Correct + stat.Incorrect;
                var precision = rated == 0 ? 0 : (double)stat.Correct / rated;
                var threshold = Daleel.Core.Moderation.HalalPolicy.ThresholdFromPrecision(stat.Correct, stat.Incorrect);
                <div class="d-flex justify-space-between align-center mb-1">
                    <span>@stat.Category</span>
                    <span>
                        <b>@precision.ToString("P0")</b> precision (@stat.Correct haram / @stat.Incorrect halal)
                        · removal threshold @threshold.ToString("0.00")
                    </span>
                </div>
                <MudProgressLinear Value="@(precision * 100)"
                                   Color="@(precision >= 0.8 ? Color.Success : precision >= 0.5 ? Color.Warning : Color.Error)"
                                   Class="mb-2" />
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Low precision raises that category's confidence bar automatically — the model must be more
                certain before an item is hidden.
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Dynamic keyword rules</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
            The LLM auditor reviews every finding and adjusts the keyword layer itself: repeated
            wrong flags auto-suppress a term (revocable below); proposed additions wait here for
            your approval. Your ratings always outrank the machine's.
        </MudText>
        @if (_rules.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">No dynamic rules yet — the static keyword list is in effect.</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Style="overflow-x:auto;">
                <thead>
                    <tr><th>Rule</th><th>Term</th><th>Category</th><th>Source</th><th>Status</th><th>Reason</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var r in _rules)
                    {
                        var rule = r; // per-iteration local for deferred RenderFragments
                        <tr>
                            <td>@(rule.Kind == "suppress-term" ? "suppress" : "add")</td>
                            <td dir="@Catalog.Dir(rule.Term)"><code>@rule.Term</code></td>
                            <td>@rule.Category</td>
                            <td>@rule.Source</td>
                            <td>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(rule.Status == "active" ? Color.Success : Color.Warning)"
                                         Variant="Variant.Text">@rule.Status</MudChip>
                            </td>
                            <td style="max-width:340px;">@rule.Reason</td>
                            <td style="white-space:nowrap;">
                                @if (rule.Status == "pending")
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                               OnClick="() => ApproveRuleAsync(rule)">Approve</MudButton>
                                }
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           OnClick="() => RevokeRuleAsync(rule)">Revoke</MudButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>

    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">
        Filtered items are never shown to users. For the exact content removed and the rule that fired,
        see <MudLink Href="/admin/filtered" Typo="Typo.caption">Filtered content</MudLink>.
    </MudText>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _totalFiltered;
    private int _withFilters;
    private IReadOnlyList<(string Category, int Count)> _byCategory = new List<(string, int)>();
    private IReadOnlyList<CategoryRatingStats> _ratingStats = Array.Empty<CategoryRatingStats>();
    private IReadOnlyList<ModerationRuleOverride> _rules = Array.Empty<ModerationRuleOverride>();

    private async Task ApproveRuleAsync(ModerationRuleOverride rule)
    {
        try
        {
            await Rules.ApproveAsync(rule.Id);
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add($"Rule approved — '{rule.Term}' now applies to every search.", Severity.Success);
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't approve rule: {ex.Message}", Severity.Error);
        }
    }

    private async Task RevokeRuleAsync(ModerationRuleOverride rule)
    {
        try
        {
            await Rules.RevokeAsync(rule.Id);
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add($"Rule revoked — the static default applies to '{rule.Term}' again.", Severity.Success);
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't revoke rule: {ex.Message}", Severity.Error);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _loading = true;
        StateHasChanged();
        try
        {
            var (total, withFilters, byCat) = await Analytics.ModerationStatsAsync(DateTime.UtcNow.AddDays(-30));
            _totalFiltered = total;
            _withFilters = withFilters;
            _byCategory = byCat;
            _ratingStats = await FilteredLog.RatingStatsAsync(DateTimeOffset.UtcNow.AddDays(-90));
            _rules = await Rules.ListOpenAsync();
            _loading = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
        StateHasChanged();
    }
}
