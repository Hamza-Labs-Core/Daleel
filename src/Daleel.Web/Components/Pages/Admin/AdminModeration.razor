@page "/admin/moderation"
@attribute [Authorize(Roles = "Admin")]
@inject IAnalyticsService Analytics
@inject IFilteredContentLogRepository FilteredLog
@inject IModerationRuleRepository Rules
@inject IModerationWhitelistRepository Whitelist
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache Cache
@inject IImageModerationRuleRepository ImageRules
@inject ISnackbar Snackbar
@using Daleel.Web.Moderation

<PageTitle>دليل · Admin · Moderation</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-4">Content Filter Stats</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load moderation stats: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><Kpi Title="Items filtered (30d)" Value="_totalFiltered" Icon="@Icons.Material.Filled.FilterAlt" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><Kpi Title="Searches with removals" Value="_withFilters" Icon="@Icons.Material.Filled.Shield" /></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">Most filtered categories (30d)</MudText>
        @if (_byCategory.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">Nothing has been filtered yet.</MudText>
        }
        else
        {
            @foreach (var (cat, count) in _byCategory)
            {
                <div class="d-flex justify-space-between"><span>@cat</span><b>@count</b></div>
            }
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">Classifier precision from admin ratings (90d)</MudText>
        @if (_ratingStats.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                No rated findings yet — rate findings on the
                <MudLink Href="/admin/filtered" Typo="Typo.caption">Filtered content</MudLink> page and the
                classifier's per-category confidence thresholds will adapt.
            </MudText>
        }
        else
        {
            @foreach (var s in _ratingStats)
            {
                var stat = s; // per-iteration local: deferred RenderFragments must not capture the loop var
                var rated = stat.Correct + stat.Incorrect;
                var precision = rated == 0 ? 0 : (double)stat.Correct / rated;
                var threshold = Daleel.Core.Moderation.HalalPolicy.ThresholdFromPrecision(stat.Correct, stat.Incorrect);
                <div class="d-flex justify-space-between align-center mb-1">
                    <span>@stat.Category</span>
                    <span>
                        <b>@precision.ToString("P0")</b> precision (@stat.Correct haram / @stat.Incorrect halal)
                        · removal threshold @threshold.ToString("0.00")
                    </span>
                </div>
                <MudProgressLinear Value="@(precision * 100)"
                                   Color="@(precision >= 0.8 ? Color.Success : precision >= 0.5 ? Color.Warning : Color.Error)"
                                   Class="mb-2" />
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Low precision raises that category's confidence bar automatically — the model must be more
                certain before an item is hidden.
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Dynamic keyword rules</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
            The LLM auditor reviews every finding and adjusts the keyword layer itself: repeated
            wrong flags auto-suppress a term (revocable below); proposed additions wait here for
            your approval. Your ratings always outrank the machine's.
        </MudText>
        @if (_rules.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">No dynamic rules yet — the static keyword list is in effect.</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Style="overflow-x:auto;">
                <thead>
                    <tr><th>Rule</th><th>Term</th><th>Category</th><th>Source</th><th>Status</th><th>Reason</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var r in _rules)
                    {
                        var rule = r; // per-iteration local for deferred RenderFragments
                        <tr>
                            <td>@(rule.Kind == "suppress-term" ? "suppress" : "add")</td>
                            <td dir="@Catalog.Dir(rule.Term)"><code>@rule.Term</code></td>
                            <td>@rule.Category</td>
                            <td>@rule.Source</td>
                            <td>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(rule.Status == "active" ? Color.Success : Color.Warning)"
                                         Variant="Variant.Text">@rule.Status</MudChip>
                            </td>
                            <td style="max-width:340px;">@rule.Reason</td>
                            <td style="white-space:nowrap;">
                                @if (rule.Status == "pending")
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                               OnClick="() => ApproveRuleAsync(rule)">Approve</MudButton>
                                }
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           OnClick="() => RevokeRuleAsync(rule)">Revoke</MudButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Image moderation rules (vision policy)</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
            The list of rules the vision model screens every product/brand image against. The screening
            prompt is composed from these — <em>"the following rules apply: …"</em> — so editing the list
            retunes image moderation with no redeploy; changes take effect on the next screen. Each rule
            has a <b>category</b> (the tag a flagged image gets) and an <b>instruction</b>. Disable a rule
            to drop it from the prompt without deleting it.
        </MudText>

        @if (_imageRules.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">No rules — the built-in default policy is in effect.</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Style="overflow-x:auto;">
                <thead>
                    <tr><th style="width:1%;">On</th><th>Category</th><th>Instruction</th><th style="width:1%;"></th></tr>
                </thead>
                <tbody>
                    @foreach (var r in _imageRules)
                    {
                        var rule = r; // per-iteration local for deferred RenderFragments
                        <tr style="@(rule.Enabled ? "" : "opacity:0.5;")">
                            <td>
                                <MudSwitch T="bool" Value="rule.Enabled" Color="Color.Success" Disabled="@_imageRuleBusy"
                                           ValueChanged="@(v => ToggleImageRuleAsync(rule, v))" />
                            </td>
                            <td><code>@rule.Category</code></td>
                            <td style="max-width:640px;">@rule.Instruction</td>
                            <td>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               Disabled="@_imageRuleBusy" OnClick="() => DeleteImageRuleAsync(rule)" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }

        <div class="d-flex flex-wrap gap-2 align-end mt-3">
            <MudTextField @bind-Value="_newRuleCategory" Label="Category" Placeholder="e.g. immodest"
                          Style="min-width:150px;" Immediate="true" />
            <MudTextField @bind-Value="_newRuleInstruction" Label="Instruction — what to flag"
                          Style="min-width:360px; flex:1;" Immediate="true" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@(_imageRuleBusy || string.IsNullOrWhiteSpace(_newRuleCategory) || string.IsNullOrWhiteSpace(_newRuleInstruction))"
                       OnClick="AddImageRuleAsync">Add rule</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.RestartAlt" Disabled="@_imageRuleBusy"
                       OnClick="ResetImageRulesAsync">Reset to defaults</MudButton>
        </div>

        <MudExpansionPanels Class="mt-3" Elevation="0">
            <MudExpansionPanel Text="Preview composed prompt">
                <pre style="white-space:pre-wrap; font-size:0.8rem; margin:0;">@_composedPreview</pre>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </MudPaper>

    <MudPaper Class="pa-4 mt-3" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-1">Whitelist (never filtered)</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
            Content the moderation pipeline must always keep — created from a finding's
            "un-filter" action or added here manually. Removing an entry makes that content
            filterable again on the next run.
        </MudText>

        <div class="d-flex flex-wrap gap-2 align-end mb-3">
            <MudSelect T="string" @bind-Value="_newKind" Label="Type" Dense="true" Style="min-width:170px;">
                <MudSelectItem T="string" Value="@("url")">Page URL</MudSelectItem>
                <MudSelectItem T="string" Value="@("image")">Image URL</MudSelectItem>
                <MudSelectItem T="string" Value="@("text")">Exact text (hashed)</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_newValue" Label="@(_newKind == "text" ? "The exact item text to always allow" : "https://…")"
                          Style="min-width:340px; flex:1;" Immediate="true" />
            <MudTextField @bind-Value="_newNote" Label="Note (optional)" Style="min-width:200px;" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       Disabled="@(_busy || string.IsNullOrWhiteSpace(_newValue))"
                       OnClick="AddWhitelistAsync">Add</MudButton>
        </div>

        @if (_whitelist.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">No whitelist entries.</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Style="overflow-x:auto;">
                <thead>
                    <tr><th>Type</th><th>Key</th><th>Category</th><th>Note</th><th>Created (UTC)</th><th>Origin</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var w in _whitelist)
                    {
                        var entry = w; // per-iteration local for deferred RenderFragments
                        <tr>
                            <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@entry.MatchType</MudChip></td>
                            <td style="max-width:380px; overflow:hidden; text-overflow:ellipsis;"><code>@entry.Key</code></td>
                            <td>@entry.Category</td>
                            <td dir="@Catalog.Dir(entry.Note)" style="max-width:280px; overflow:hidden; text-overflow:ellipsis;">@entry.Note</td>
                            <td style="white-space:nowrap;">@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(entry.SourceLogId is null ? "manual" : $"finding #{entry.SourceLogId}")</td>
                            <td>
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           Disabled="@_busy" OnClick="() => RemoveWhitelistEntryAsync(entry)">Remove</MudButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>

    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">
        Filtered items are never shown to users. For the exact content removed and the rule that fired,
        see <MudLink Href="/admin/filtered" Typo="Typo.caption">Filtered content</MudLink>.
    </MudText>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _totalFiltered;
    private int _withFilters;
    private IReadOnlyList<(string Category, int Count)> _byCategory = new List<(string, int)>();
    private IReadOnlyList<CategoryRatingStats> _ratingStats = Array.Empty<CategoryRatingStats>();
    private IReadOnlyList<ModerationRuleOverride> _rules = Array.Empty<ModerationRuleOverride>();
    private IReadOnlyList<ModerationWhitelistEntry> _whitelist = Array.Empty<ModerationWhitelistEntry>();
    private bool _busy;
    private string _newKind = "url";
    private string? _newValue;
    private string? _newNote;

    // The admin-managed halal image-moderation rule list (composed into the vision prompt).
    private IReadOnlyList<ImageModerationRule> _imageRules = Array.Empty<ImageModerationRule>();
    private bool _imageRuleBusy;
    private string? _newRuleCategory;
    private string? _newRuleInstruction;
    private string _composedPreview = string.Empty;

    private async Task LoadImageRulesAsync()
    {
        _imageRules = await ImageRules.ListAllAsync();
        var active = _imageRules.Where(r => r.Enabled)
            .Select(r => new VisionPolicy.Rule(r.Category, r.Instruction)).ToList();
        _composedPreview = VisionPolicy.Compose(active);
    }

    private async Task AddImageRuleAsync()
    {
        if (string.IsNullOrWhiteSpace(_newRuleCategory) || string.IsNullOrWhiteSpace(_newRuleInstruction) || _imageRuleBusy)
        {
            return;
        }

        _imageRuleBusy = true;
        try
        {
            await ImageRules.AddAsync(_newRuleCategory!, _newRuleInstruction!);
            _newRuleCategory = null;
            _newRuleInstruction = null;
            await LoadImageRulesAsync();
            Snackbar.Add("Rule added.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't add the rule: {ex.Message}", Severity.Error);
        }
        finally
        {
            _imageRuleBusy = false;
        }
    }

    private async Task ToggleImageRuleAsync(ImageModerationRule rule, bool enabled)
    {
        if (_imageRuleBusy)
        {
            return;
        }

        _imageRuleBusy = true;
        try
        {
            await ImageRules.SetEnabledAsync(rule.Id, enabled);
            await LoadImageRulesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't update the rule: {ex.Message}", Severity.Error);
        }
        finally
        {
            _imageRuleBusy = false;
        }
    }

    private async Task DeleteImageRuleAsync(ImageModerationRule rule)
    {
        _imageRuleBusy = true;
        try
        {
            await ImageRules.DeleteAsync(rule.Id);
            await LoadImageRulesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't delete the rule: {ex.Message}", Severity.Error);
        }
        finally
        {
            _imageRuleBusy = false;
        }
    }

    private async Task ResetImageRulesAsync()
    {
        _imageRuleBusy = true;
        try
        {
            await ImageRules.ResetToDefaultsAsync();
            await LoadImageRulesAsync();
            Snackbar.Add("Image rules reset to the built-in defaults.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't reset the rules: {ex.Message}", Severity.Error);
        }
        finally
        {
            _imageRuleBusy = false;
        }
    }

    private async Task AddWhitelistAsync()
    {
        if (string.IsNullOrWhiteSpace(_newValue) || _busy)
        {
            return;
        }

        _busy = true;
        try
        {
            string key, matchType;
            var note = _newNote;
            if (_newKind == "text")
            {
                // Whitelist-by-content: hash the exact text (same normalization as the pipeline)
                // and keep the original in the note so the entry stays human-readable.
                key = Daleel.Core.Moderation.ModerationKeys.HashContent(_newValue);
                matchType = "hash";
                note = string.IsNullOrWhiteSpace(note) ? _newValue.Trim() : note;
            }
            else
            {
                if (!Uri.TryCreate(_newValue.Trim(), UriKind.Absolute, out var uri)
                    || (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
                {
                    Snackbar.Add("Enter a full http(s) URL.", Severity.Warning);
                    return;
                }

                key = _newValue.Trim();
                matchType = _newKind;
            }

            await Whitelist.AddEntryAsync(key, matchType, category: null, note);
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add("Whitelisted — future searches will keep this content.", Severity.Success);
            _newValue = null;
            _newNote = null;
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't add whitelist entry: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveWhitelistEntryAsync(ModerationWhitelistEntry entry)
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        try
        {
            await Whitelist.DeleteEntryAsync(entry.Id);
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add("Whitelist entry removed — filtering applies again.", Severity.Success);
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't remove entry: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ApproveRuleAsync(ModerationRuleOverride rule)
    {
        try
        {
            await Rules.ApproveAsync(rule.Id);
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add($"Rule approved — '{rule.Term}' now applies to every search.", Severity.Success);
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't approve rule: {ex.Message}", Severity.Error);
        }
    }

    private async Task RevokeRuleAsync(ModerationRuleOverride rule)
    {
        try
        {
            await Rules.RevokeAsync(rule.Id);
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add($"Rule revoked — the static default applies to '{rule.Term}' again.", Severity.Success);
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't revoke rule: {ex.Message}", Severity.Error);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _loading = true;
        StateHasChanged();
        try
        {
            var (total, withFilters, byCat) = await Analytics.ModerationStatsAsync(DateTime.UtcNow.AddDays(-30));
            _totalFiltered = total;
            _withFilters = withFilters;
            _byCategory = byCat;
            _ratingStats = await FilteredLog.RatingStatsAsync(DateTimeOffset.UtcNow.AddDays(-90));
            _rules = await Rules.ListOpenAsync();
            _whitelist = await Whitelist.ListEntriesAsync();
            await LoadImageRulesAsync();
            _loading = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
        StateHasChanged();
    }
}
