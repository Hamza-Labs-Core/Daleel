@page "/admin/settings"
@attribute [Authorize(Roles = "Admin")]
@inject ISystemConfigService Config
@inject ISnackbar Snackbar

<PageTitle>دليل · Admin · Settings</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-1">System Settings</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Rate limits, feature flags, default models per plan, and other tunables.
</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load settings: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_items is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        @foreach (var item in _items)
        {
            <div class="d-flex align-center gap-3 mb-2">
                <MudText Typo="Typo.body2" Style="min-width:240px;font-family:monospace;">@item.Key</MudText>
                @if (item.Type == "bool")
                {
                    <MudSwitch T="bool" Value="@(item.Value == "true")"
                               ValueChanged="@(v => item.Value = v ? "true" : "false")" Color="Color.Primary" />
                }
                else
                {
                    <MudTextField @bind-Value="item.Value" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="max-width:320px;"
                                  InputType="@(item.Type == "int" ? InputType.Number : InputType.Text)" />
                }
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@item.Type</MudChip>
            </div>
        }
        <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Primary"
                   Class="mt-3" OnClick="SaveAllAsync" Disabled="_saving">
            @(_saving ? "Saving…" : "Save all")
        </MudButton>
    </MudPaper>
}

@code {
    private List<SystemConfig>? _items;
    private string? _error;
    private bool _saving;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _items = null;
        StateHasChanged();
        try
        {
            _items = (await Config.AllAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task SaveAllAsync()
    {
        if (_items is null || _saving) return;

        // Validate every value before writing anything, so a single bad entry can't leave the system
        // half-saved with a misleading "Settings saved." H5.
        foreach (var item in _items)
        {
            if (item.Type == "int" && !int.TryParse(item.Value, out _))
            {
                Snackbar.Add($"\"{item.Key}\" must be a whole number.", Severity.Warning);
                return;
            }
            if (item.Type == "bool" && item.Value is not ("true" or "false"))
            {
                Snackbar.Add($"\"{item.Key}\" must be true or false.", Severity.Warning);
                return;
            }
        }

        _saving = true;
        try
        {
            foreach (var item in _items)
            {
                await Config.SetAsync(item.Key, item.Value, item.Type);
            }
            Snackbar.Add("Settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't save all settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
