@page "/admin/filtered"
@attribute [Authorize(Roles = "Admin")]
@inject IFilteredContentLogRepository FilteredLog

<PageTitle>دليل · Admin · Filtered content</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-1">Filtered content</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Exactly what the halal filter removed — the offending content, the blocklist rule that fired, and
    the query that produced it. Use this to check the filter isn't too aggressive (or missing things).
    Anonymous by design: no user is recorded against a removal.
</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load filtered content: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
        @_count removed in the last 30 days · showing the latest @_rows.Count
    </MudText>

    @if (_rows.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Nothing has been filtered yet.</MudAlert>
    }
    else
    {
        <MudPaper Outlined="true" Elevation="0" Class="pa-2">
            <MudSimpleTable Dense="true" Hover="true" Style="overflow-x:auto;">
                <thead>
                    <tr>
                        <th>When (UTC)</th>
                        <th>Category</th>
                        <th>Rule</th>
                        <th>Kind</th>
                        <th>Query</th>
                        <th>Filtered content</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td style="white-space:nowrap;">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">@r.Category</MudChip></td>
                            <td><code>@r.Rule</code></td>
                            <td>@r.Kind</td>
                            <td dir="@Catalog.Dir(r.Query)">@r.Query</td>
                            <td dir="@Catalog.Dir(r.Content)" style="max-width:360px;">@r.Content</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _count;
    private IReadOnlyList<FilteredContentLog> _rows = Array.Empty<FilteredContentLog>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _loading = true;
        StateHasChanged();
        try
        {
            _count = await FilteredLog.CountSinceAsync(DateTimeOffset.UtcNow.AddDays(-30));
            _rows = await FilteredLog.ListRecentAsync(200);
            _loading = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
        StateHasChanged();
    }
}
