@page "/admin/filtered"
@attribute [Authorize(Roles = "Admin")]
@inject IFilteredContentLogRepository FilteredLog
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache Cache
@inject ISnackbar Snackbar
@inject IDialogService Dialogs

<PageTitle>دليل · Admin · Filtered content</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-1">Filtered content</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Every moderation finding — the exact content or image flagged, where it was found, how it was
    decided (keyword, LLM, or vision), and the query that produced it. Rate findings
    <b>correct/incorrect</b> to tune the classifier's thresholds, or <b>un-filter</b> a finding to
    whitelist that content permanently. Anonymous by design: no user is recorded against a removal.
</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load filtered content: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
        @_count finding(s) in the last 30 days · showing the latest @_rows.Count
    </MudText>

    @if (_legacyCount > 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-2" Dense="true">
            @_legacyCount legacy finding(s) from the old filter have no stable key — they can't be
            whitelisted and don't tune thresholds.
            <MudButton Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Class="ms-2"
                       OnClick="PurgeLegacyAsync">Purge them</MudButton>
        </MudAlert>
    }

    @if (_selected.Count > 0)
    {
        <MudPaper Outlined="true" Elevation="0" Class="pa-2 mb-2 d-flex flex-wrap gap-2 align-center">
            <MudText Typo="Typo.body2" Class="me-2"><b>@_selected.Count</b> selected</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Block" Disabled="@_busy"
                       OnClick="() => RateSelectedAsync(1)">Mark haram</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.CheckCircleOutline" Disabled="@_busy"
                       OnClick="() => RateSelectedAsync(-1)">Mark halal</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Undo" Disabled="@_busy"
                       OnClick="WhitelistSelectedAsync">Un-filter</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Redo" Disabled="@_busy"
                       OnClick="UnwhitelistSelectedAsync">Re-enable filtering</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.DeleteOutline" Disabled="@_busy"
                       OnClick="DeleteSelectedAsync">Delete</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" Disabled="@_busy"
                       OnClick="ClearSelection">Clear</MudButton>
        </MudPaper>
    }

    @if (_rows.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Nothing has been filtered yet.</MudAlert>
    }
    else
    {
        <MudPaper Outlined="true" Elevation="0" Class="pa-2">
            <MudSimpleTable Dense="true" Hover="true" Style="overflow-x:auto;">
                <thead>
                    <tr>
                        <th style="width:36px;">
                            <MudCheckBox T="bool" Value="@AllSelected" ValueChanged="ToggleSelectAll"
                                         Size="Size.Small" Dense="true" />
                        </th>
                        <th style="width:28px;"></th>
                        <th>When (UTC)</th>
                        <th>Category</th>
                        <th>Decided by</th>
                        <th>Action</th>
                        <th>Query</th>
                        <th>Flagged content</th>
                        <th>Feedback</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _rows)
                    {
                        var row = r; // per-iteration local: deferred RenderFragments must not capture the loop var
                        var expanded = _expandedId == row.Id;
                        <tr @onclick="() => Toggle(row.Id)" style="cursor:pointer;">
                            <td @onclick:stopPropagation="true" style="cursor:default;">
                                <MudCheckBox T="bool" Value="@_selected.Contains(row.Id)"
                                             ValueChanged="@(v => ToggleSelect(row.Id, v))"
                                             Size="Size.Small" Dense="true" />
                            </td>
                            <td>
                                <MudIcon Icon="@(expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                         Size="Size.Small" />
                            </td>
                            <td style="white-space:nowrap;">@row.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(row.WhitelistEntryId is not null ? Color.Default : Color.Error)"
                                         Variant="Variant.Text">@row.Category</MudChip>
                            </td>
                            <td>
                                <MudChip T="string" Size="Size.Small" Color="@SourceColor(row.DecisionSource)"
                                         Variant="Variant.Outlined">
                                    @(row.DecisionSource ?? "keyword")@(row.DecisionSource is "llm" or "vision"
                                        ? $" · {row.Confidence:0.00}" : "")
                                </MudChip>
                            </td>
                            <td style="white-space:nowrap;">
                                @if (row.WhitelistEntryId is not null)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">un-filtered</MudChip>
                                }
                                else if (row.ItemRemoved)
                                {
                                    @("item removed")
                                }
                                else if (row.Field == "image")
                                {
                                    @("image stripped")
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">shown · low confidence</MudChip>
                                }
                            </td>
                            <td dir="@Catalog.Dir(row.Query)" style="max-width:200px; overflow:hidden; text-overflow:ellipsis;">@row.Query</td>
                            <td dir="@Catalog.Dir(row.Content)" style="max-width:320px; overflow:hidden; text-overflow:ellipsis;">@row.Content</td>
                            <td style="white-space:nowrap;">
                                @if (row.Rating is > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">haram</MudChip>
                                }
                                else if (row.Rating is < 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">halal</MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">unrated</MudText>
                                }
                            </td>
                        </tr>
                        @if (expanded)
                        {
                            <tr>
                                <td colspan="9" style="background: var(--mud-palette-background-gray);">
                                    <div class="pa-4 d-flex flex-wrap gap-6">
                                        @if (SafeHttpUrl(row.ImageUrl) is { } imageUrl)
                                        {
                                            <div>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Flagged image</MudText>
                                                <div>
                                                    <img src="@imageUrl" alt="flagged content (admin review)" referrerpolicy="no-referrer"
                                                         style="max-width:180px; max-height:180px; border-radius:6px; border:1px solid var(--mud-palette-lines-default);"
                                                         loading="lazy" />
                                                </div>
                                            </div>
                                        }
                                        <div style="min-width:280px; max-width:640px; flex:1;">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Flagged content</MudText>
                                            <MudText Typo="Typo.body2" dir="@Catalog.Dir(row.Content)">@row.Content</MudText>

                                            <div class="d-flex flex-wrap gap-2 mt-3 align-center">
                                                @if (row.Field is not null)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                        found in: @row.Field
                                                    </MudChip>
                                                }
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                    rule/reason: @row.Rule
                                                </MudChip>
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                    kind: @row.Kind
                                                </MudChip>
                                                @if (row.DecisionSource is "llm" or "vision")
                                                {
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                        confidence: @row.Confidence.ToString("0.00")
                                                    </MudChip>
                                                }
                                            </div>

                                            @if (SafeHttpUrl(row.SourceUrl) is { } sourceUrl)
                                            {
                                                <MudLink Href="@sourceUrl" Target="_blank" rel="noopener noreferrer"
                                                         Typo="Typo.body2" Class="mt-2 d-inline-block">
                                                    View source page ↗
                                                </MudLink>
                                            }
                                        </div>
                                        <div style="min-width:220px;">
                                            @* Flag-centric on purpose: "was the DECISION right" reads backwards on
                                               shown rows and would feed the thresholds inverted. *@
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Is this content actually haram?</MudText>
                                            <div class="d-flex gap-2 mb-3">
                                                <MudButton Variant="@(row.Rating is > 0 ? Variant.Filled : Variant.Outlined)"
                                                           Color="Color.Error" Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.Block"
                                                           OnClick="() => RateAsync(row, 1)">Yes — haram</MudButton>
                                                <MudButton Variant="@(row.Rating is < 0 ? Variant.Filled : Variant.Outlined)"
                                                           Color="Color.Success" Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.CheckCircleOutline"
                                                           OnClick="() => RateAsync(row, -1)">No — halal</MudButton>
                                            </div>
                                            @if (row.WhitelistEntryId is null)
                                            {
                                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.Undo"
                                                           OnClick="() => WhitelistAsync(row)">
                                                    Un-filter (whitelist)
                                                </MudButton>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1 d-block">
                                                    Future searches will keep this @(row.Field == "image" ? "image" : "content").
                                                </MudText>
                                            }
                                            else
                                            {
                                                <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.Redo"
                                                           OnClick="() => UnwhitelistAsync(row)">
                                                    Re-enable filtering
                                                </MudButton>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
}

@code {
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private int _count;
    private int _legacyCount;
    private long? _expandedId;
    private readonly HashSet<long> _selected = new();
    private IReadOnlyList<FilteredContentLog> _rows = Array.Empty<FilteredContentLog>();

    private bool AllSelected => _rows.Count > 0 && _selected.Count == _rows.Count;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await RetryAsync();
    }

    private void Toggle(long id) => _expandedId = _expandedId == id ? null : id;

    private void ToggleSelect(long id, bool selected)
    {
        if (selected)
        {
            _selected.Add(id);
        }
        else
        {
            _selected.Remove(id);
        }
    }

    private void ToggleSelectAll(bool selected)
    {
        _selected.Clear();
        if (selected)
        {
            foreach (var row in _rows)
            {
                _selected.Add(row.Id);
            }
        }
    }

    private void ClearSelection() => _selected.Clear();

    /// <summary>Runs one batch action: confirm (optional) → repo call → snackbar → reload.</summary>
    private async Task RunBatchAsync(string? confirmText, Func<long[], Task<int>> action, Func<int, string> message)
    {
        if (_selected.Count == 0 || _busy)
        {
            return;
        }

        if (confirmText is not null)
        {
            var ok = await Dialogs.ShowMessageBox(
                "Confirm", confirmText, yesText: "Proceed", cancelText: "Cancel");
            if (ok != true)
            {
                return;
            }
        }

        _busy = true;
        StateHasChanged();
        try
        {
            var done = await action(_selected.ToArray());
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add(message(done), Severity.Success);
            _selected.Clear();
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Batch action failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private Task RateSelectedAsync(int rating) => RunBatchAsync(
        null,
        ids => FilteredLog.RateManyAsync(ids, rating),
        done => rating > 0
            ? $"Marked {done} finding(s) haram — model findings among them tune thresholds."
            : $"Marked {done} finding(s) halal — model findings among them tune thresholds.");

    private Task WhitelistSelectedAsync() => RunBatchAsync(
        $"Un-filter {_selected.Count} finding(s)? Future searches will keep this content.",
        ids => FilteredLog.WhitelistManyAsync(ids),
        done => $"Un-filtered {done} finding(s); those without a stable key were skipped.");

    private Task UnwhitelistSelectedAsync() => RunBatchAsync(
        null,
        ids => FilteredLog.RemoveWhitelistManyAsync(ids),
        done => $"Re-enabled filtering for {done} finding(s).");

    private Task DeleteSelectedAsync() => RunBatchAsync(
        $"Delete {_selected.Count} finding(s)? Linked whitelist entries are removed too, so their "
        + "content becomes filterable again. This cannot be undone.",
        ids => FilteredLog.DeleteManyAsync(ids),
        done => $"Deleted {done} finding(s).");

    private async Task PurgeLegacyAsync()
    {
        if (_busy)
        {
            return;
        }

        var ok = await Dialogs.ShowMessageBox(
            "Purge legacy findings",
            $"Delete all {_legacyCount} legacy finding(s) from the old filter? They have no stable "
            + "key, so they can't be whitelisted and don't tune thresholds. This cannot be undone.",
            yesText: "Purge", cancelText: "Cancel");
        if (ok != true)
        {
            return;
        }

        _busy = true;
        StateHasChanged();
        try
        {
            var done = await FilteredLog.PurgeKeylessAsync();
            Snackbar.Add($"Purged {done} legacy finding(s).", Severity.Success);
            _selected.Clear();
            await RetryAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Purge failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// The stored URLs come from scraped external content — render them only when they're plain
    /// http(s), so a hostile result can't smuggle a javascript:/data: scheme into an admin click.
    /// </summary>
    private static string? SafeHttpUrl(string? url) =>
        Uri.TryCreate(url, UriKind.Absolute, out var u)
        && (u.Scheme == Uri.UriSchemeHttp || u.Scheme == Uri.UriSchemeHttps)
            ? url
            : null;

    private static Color SourceColor(string? source) => source switch
    {
        "llm" => Color.Info,
        "vision" => Color.Tertiary,
        _ => Color.Default
    };

    /// <summary>Only model findings feed the threshold tuner; keyword rows are review-only.</summary>
    private static bool TunesThresholds(FilteredContentLog row) =>
        row.DecisionSource is "llm" or "vision";

    private async Task RateAsync(FilteredContentLog row, int rating)
    {
        try
        {
            // Clicking the same rating again clears it.
            var newRating = row.Rating == rating ? (int?)null : rating;
            await FilteredLog.RateAsync(row.Id, newRating);
            row.Rating = newRating;
            row.RatedAt = newRating is null ? null : DateTimeOffset.UtcNow;
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            // Honest copy: keyword rows never move thresholds (they're deterministic), so don't
            // promise learning that won't happen.
            Snackbar.Add(newRating switch
            {
                null => "Rating cleared.",
                _ when !TunesThresholds(row) => "Recorded — keyword findings are review-only and don't tune thresholds.",
                > 0 => "Marked haram — the classifier will be trusted more in this category.",
                _ => "Marked halal — the classifier will need more confidence in this category."
            }, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't save rating: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    private async Task WhitelistAsync(FilteredContentLog row)
    {
        try
        {
            var entryId = await FilteredLog.WhitelistAsync(row.Id);
            if (entryId is null)
            {
                Snackbar.Add("This finding has no stable key to whitelist.", Severity.Warning);
                return;
            }

            row.WhitelistEntryId = entryId;
            row.Rating ??= -1;
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add("Un-filtered — future searches will keep this content.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't whitelist: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    private async Task UnwhitelistAsync(FilteredContentLog row)
    {
        try
        {
            await FilteredLog.RemoveWhitelistAsync(row.Id);
            row.WhitelistEntryId = null;
            Daleel.Web.Moderation.ModerationPolicyProvider.Invalidate(Cache);
            Snackbar.Add("Filtering re-enabled for this content.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't re-enable filtering: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _loading = true;
        StateHasChanged();
        try
        {
            _count = await FilteredLog.CountSinceAsync(DateTimeOffset.UtcNow.AddDays(-30));
            _rows = await FilteredLog.ListRecentAsync(200);
            _legacyCount = await FilteredLog.CountKeylessAsync();
            // Selection only makes sense against rows still on screen.
            _selected.IntersectWith(_rows.Select(r => r.Id));
            _loading = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
        StateHasChanged();
    }
}
