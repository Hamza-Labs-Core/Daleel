@page "/admin/oauth"
@attribute [Authorize(Roles = "Admin")]
@using Daleel.Web.Auth
@using Microsoft.Extensions.Configuration
@inject ISystemConfigService Config
@inject IConfiguration Configuration
@inject IAgentFactory Agents
@inject ISnackbar Snackbar

<PageTitle>دليل · Admin · OAuth & Integrations</PageTitle>

<AdminNav />
<MudText Typo="Typo.h4" Class="mb-1">OAuth & Integrations</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Manage social sign-in credentials and review integration/API-key status — no redeploy required.
    Stored credentials live in <code>SystemConfig</code> and take precedence over deploy env vars.
</MudText>

@if (_providers is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @* ── OAuth providers ─────────────────────────────────────────────────── *@
    <MudText Typo="Typo.h6" Class="mb-2">Sign-in providers</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
        Sign-in handlers are wired at startup, so credential changes take effect after the next app restart.
        Credentials supplied via deploy environment variables are never displayed here — only overrides you
        enter on this page. Leave a field blank to keep using the environment value.
    </MudAlert>

    <MudGrid Spacing="3" Class="mb-6">
        @foreach (var p in _providers)
        {
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Outlined="true" Elevation="0">
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudText Typo="Typo.subtitle1">@p.Def.DisplayName</MudText>
                        @if (p.Configured)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.CheckCircle">Configured</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.Cancel">Not configured</MudChip>
                        }
                        @if (!p.Def.Supported)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">
                                placeholder — handler not wired yet
                            </MudChip>
                        }
                    </div>

                    <MudTextField @bind-Value="p.Id" Label="Client ID" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Class="mb-2"
                                  HelperText="@($"Resolves from: {p.IdSource}")" />

                    <MudTextField @bind-Value="p.Secret" Label="Client Secret" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Class="mb-2"
                                  InputType="@(p.ShowSecret ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(p.ShowSecret ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => p.ShowSecret = !p.ShowSecret)"
                                  HelperText="@($"Resolves from: {p.SecretSource}")" />

                    <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Small" OnClick="@(() => SaveProviderAsync(p))">Save @p.Def.DisplayName</MudButton>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    @* ── API key / integration status ────────────────────────────────────── *@
    <MudText Typo="Typo.h6" Class="mb-2">API keys & integrations</MudText>
    <MudPaper Class="pa-4 mb-6" Outlined="true" Elevation="0">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Read-only — these are provided to the server via environment variables (see <code>/admin/settings</code>
            for tunables). Set them in the deploy <code>.env</code> / GitHub secrets.
        </MudText>
        @foreach (var k in _apiKeys)
        {
            <div class="d-flex align-center gap-3 mb-2">
                <MudText Typo="Typo.body2" Style="min-width:260px;">@k.Label</MudText>
                @if (k.Configured)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.CheckCircle">Configured</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.Cancel">Missing</MudChip>
                }
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family:monospace;">@k.Key</MudText>
            </div>
        }
    </MudPaper>

    @* ── Rate limits & flags (read-only summary; edit on Settings) ────────── *@
    <MudText Typo="Typo.h6" Class="mb-2">Rate limits & feature flags</MudText>
    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var c in _tunables)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                    <span style="font-family:monospace;">@c.Key</span>&nbsp;=&nbsp;<b>@c.Value</b>
                </MudChip>
            }
        </div>
        <MudButton Href="/admin/settings" StartIcon="@Icons.Material.Filled.Settings"
                   Variant="Variant.Text" Size="Size.Small">Edit in System Settings</MudButton>
    </MudPaper>
}

@code {
    private List<ProviderVm>? _providers;
    private List<(string Label, string Key, bool Configured)> _apiKeys = new();
    private List<SystemConfig> _tunables = new();

    // Server-side integration keys surfaced as configured/missing. Mirrors StatusService's probe list.
    private static readonly (string Label, string Key)[] ApiKeyDefs =
    {
        ("LLM — OpenRouter", "OPENROUTER_API_KEY"),
        ("Web search — SerpApi", "SERPAPI_KEY"),
        ("Store search — Google Places", "GOOGLE_PLACES_API_KEY"),
        ("Page reader — Context.dev", "CONTEXT_DEV_API_KEY"),
        ("Browser render — Cloudflare", "CLOUDFLARE_API_TOKEN"),
        ("Social — Apify", "APIFY_TOKEN"),
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        var providers = new List<ProviderVm>();
        foreach (var def in OAuthProviders.All)
        {
            providers.Add(new ProviderVm
            {
                Def = def,
                Id = await Config.GetAsync(def.IdSysKey) ?? string.Empty,
                Secret = await Config.GetAsync(def.SecretSysKey) ?? string.Empty,
                // IConfiguration here = appsettings + the friendly env vars mapped in Program.cs (NOT
                // SystemConfig), so this tells us whether a non-admin fallback value exists.
                EnvIdPresent = OAuthProviders.IsRealValue(Configuration[def.IdConfigKey]),
                EnvSecretPresent = OAuthProviders.IsRealValue(Configuration[def.SecretConfigKey]),
            });
        }
        _providers = providers;

        _apiKeys = ApiKeyDefs
            .Select(k => (k.Label, k.Key, Configured: Agents.Resolve(k.Key) is not null))
            .ToList();

        _tunables = (await Config.AllAsync())
            .Where(c => c.Key.StartsWith("ratelimit.") || c.Key.StartsWith("feature."))
            .OrderBy(c => c.Key)
            .ToList();
    }

    private async Task SaveProviderAsync(ProviderVm p)
    {
        // Empty values are stored as-is; the resolver treats blank/CHANGE_ME as "fall back to env".
        await Config.SetAsync(p.Def.IdSysKey, p.Id.Trim());
        await Config.SetAsync(p.Def.SecretSysKey, p.Secret.Trim());
        Snackbar.Add($"{p.Def.DisplayName} credentials saved. Restart the app for sign-in changes to take effect.",
            Severity.Success);
    }

    private sealed class ProviderVm
    {
        public required OAuthProviderDef Def { get; init; }
        public string Id { get; set; } = string.Empty;
        public string Secret { get; set; } = string.Empty;
        public bool EnvIdPresent { get; init; }
        public bool EnvSecretPresent { get; init; }
        public bool ShowSecret { get; set; }

        public bool IdConfigured => OAuthProviders.IsRealValue(Id) || EnvIdPresent;
        public bool SecretConfigured => OAuthProviders.IsRealValue(Secret) || EnvSecretPresent;
        public bool Configured => IdConfigured && SecretConfigured;

        public string IdSource => OAuthProviders.IsRealValue(Id) ? "SystemConfig (admin)"
            : EnvIdPresent ? "Environment / appsettings" : "not set";
        public string SecretSource => OAuthProviders.IsRealValue(Secret) ? "SystemConfig (admin)"
            : EnvSecretPresent ? "Environment / appsettings" : "not set";
    }
}
