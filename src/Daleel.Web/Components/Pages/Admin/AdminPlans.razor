@page "/admin/plans"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject DaleelDbContext Db
@inject ISnackbar Snackbar

<PageTitle>دليل · Admin · Plans</PageTitle>

<AdminNav />
<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4">Plan Management</MudText>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="AddPlan">New plan</MudButton>
</div>

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
    Changes apply to new billing cycles. Leave "searches/month" empty for unlimited.
</MudText>

@if (_plans is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        @foreach (var p in _plans.OrderBy(x => x.SortOrder))
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="pa-4" Outlined="true" Elevation="0">
                    <MudTextField @bind-Value="p.Name" Label="Name" Variant="Variant.Outlined" Class="mb-2" />
                    <MudNumericField T="int?" @bind-Value="p.SearchesPerMonth" Label="Searches / month (empty = unlimited)"
                                     Variant="Variant.Outlined" Class="mb-2" Clearable="true" />
                    <MudNumericField T="decimal" @bind-Value="p.PriceMonthly" Label="Price / month ($)" Format="F2"
                                     Variant="Variant.Outlined" Class="mb-2" />
                    <MudNumericField T="int" @bind-Value="p.SortOrder" Label="Sort order" Variant="Variant.Outlined" Class="mb-2" />
                    <MudSwitch T="bool" @bind-Value="p.IsActive" Color="Color.Primary" Label="Active" />
                    <MudTextField @bind-Value="p.FeaturesJson" Label="Features (JSON array)" Variant="Variant.Outlined"
                                  Lines="3" Class="mb-2" />
                    <div class="d-flex gap-2">
                        <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(() => SaveAsync(p))">Save</MudButton>
                        <MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(p))">Delete</MudButton>
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<SubscriptionPlan>? _plans;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync() => _plans = await Db.SubscriptionPlans.ToListAsync();

    private void AddPlan() => _plans?.Add(new SubscriptionPlan
    {
        Name = "New plan", SearchesPerMonth = 50, PriceMonthly = 0m, IsActive = false,
        SortOrder = (_plans.Count > 0 ? _plans.Max(p => p.SortOrder) : 0) + 1, FeaturesJson = "[]"
    });

    private async Task SaveAsync(SubscriptionPlan plan)
    {
        if (plan.Id == 0) { Db.SubscriptionPlans.Add(plan); }
        else { Db.SubscriptionPlans.Update(plan); }
        await Db.SaveChangesAsync();
        Snackbar.Add($"Saved {plan.Name}.", Severity.Success);
    }

    private async Task DeleteAsync(SubscriptionPlan plan)
    {
        if (plan.Id != 0)
        {
            Db.SubscriptionPlans.Remove(plan);
            await Db.SaveChangesAsync();
        }
        _plans?.Remove(plan);
        Snackbar.Add("Plan removed.", Severity.Info);
    }
}
