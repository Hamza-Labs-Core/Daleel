@page "/admin/plans"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@inject DaleelDbContext Db
@inject ISnackbar Snackbar
@inject IDialogService Dialogs

<PageTitle>دليل · Admin · Plans</PageTitle>

<AdminNav />
<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4">Plan Management</MudText>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="AddPlan">New plan</MudButton>
</div>

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
    Changes apply to new billing cycles. Leave "searches/month" empty for unlimited.
</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
        Couldn't load plans: @_error
        <MudButton Variant="Variant.Text" Color="Color.Error" Class="ms-2" OnClick="RetryAsync">Retry</MudButton>
    </MudAlert>
}
else if (_editors is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        @foreach (var e in _editors.OrderBy(x => x.Plan.SortOrder))
        {
            <MudItem xs="12" md="6" lg="4" @key="e">
                <MudPaper Class="pa-4" Outlined="true" Elevation="0">
                    <MudTextField @bind-Value="e.Plan.Name" Label="Name" Variant="Variant.Outlined" Class="mb-2" />
                    <MudNumericField T="int?" @bind-Value="e.Plan.MonthlyCredits" Label="Credits / month (empty = unlimited)"
                                     Variant="Variant.Outlined" Class="mb-2" Clearable="true"
                                     HelperText="Each search spends credits based on the providers it uses." />
                    <MudNumericField T="decimal" @bind-Value="e.Plan.PriceMonthly" Label="Price / month ($)" Format="F2"
                                     Variant="Variant.Outlined" Class="mb-2" />
                    <MudNumericField T="int" @bind-Value="e.Plan.SortOrder" Label="Sort order" Variant="Variant.Outlined" Class="mb-2" />
                    <MudSwitch T="bool" @bind-Value="e.Plan.IsActive" Color="Color.Primary" Label="Active" />

                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Features</MudText>
                    @if (e.Features.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-1">No features yet — add one below.</MudText>
                    }
                    @foreach (var f in e.Features)
                    {
                        <div class="d-flex align-center gap-1 mb-1" @key="f">
                            <MudTextField @bind-Value="f.Text" Placeholder="e.g. Priority support"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                            <MudTooltip Text="Remove feature">
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                                               aria-label="Remove feature"
                                               OnClick="@(() => RemoveFeature(e, f))" />
                            </MudTooltip>
                        </div>
                    }
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Text"
                               Color="Color.Primary" Class="mb-3" OnClick="@(() => AddFeature(e))">Add feature</MudButton>

                    <div class="d-flex gap-2">
                        <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(() => SaveAsync(e))">Save</MudButton>
                        <MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(e))">Delete</MudButton>
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    // Stable holder so each feature row keeps its identity across add/remove (clean Blazor re-render).
    private sealed class FeatureItem
    {
        public string Text { get; set; } = string.Empty;
    }

    // Pairs the EF entity with its decoded, editable feature list. The raw FeaturesJson is only
    // (de)serialized at the model boundary — the admin never sees or edits JSON.
    private sealed class PlanEditor
    {
        public required SubscriptionPlan Plan { get; init; }
        public List<FeatureItem> Features { get; set; } = new();
    }

    private List<PlanEditor>? _editors;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RetryAsync();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _editors = null;
        StateHasChanged();
        try
        {
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        var plans = await Db.SubscriptionPlans.ToListAsync();
        _editors = plans.Select(ToEditor).ToList();
    }

    private static PlanEditor ToEditor(SubscriptionPlan p) => new()
    {
        Plan = p,
        Features = p.GetFeatures().Select(f => new FeatureItem { Text = f }).ToList()
    };

    private void AddPlan() => _editors?.Add(ToEditor(new SubscriptionPlan
    {
        Name = "New plan", MonthlyCredits = 5000, PriceMonthly = 0m, IsActive = false,
        SortOrder = (_editors.Count > 0 ? _editors.Max(e => e.Plan.SortOrder) : 0) + 1, FeaturesJson = "[]"
    }));

    private void AddFeature(PlanEditor editor) => editor.Features.Add(new FeatureItem());

    private void RemoveFeature(PlanEditor editor, FeatureItem item) => editor.Features.Remove(item);

    private async Task SaveAsync(PlanEditor editor)
    {
        if (string.IsNullOrWhiteSpace(editor.Plan.Name))
        {
            Snackbar.Add("Plan name is required.", Severity.Warning);
            return;
        }

        try
        {
            // Fold the edited feature rows back into the JSON column (trims + drops blanks).
            editor.Plan.SetFeatures(editor.Features.Select(f => f.Text));

            if (editor.Plan.Id == 0) { Db.SubscriptionPlans.Add(editor.Plan); }
            else { Db.SubscriptionPlans.Update(editor.Plan); }
            await Db.SaveChangesAsync();

            // Re-sync the editor rows so blanks the user left are reflected after the save.
            editor.Features = editor.Plan.GetFeatures().Select(f => new FeatureItem { Text = f }).ToList();
            Snackbar.Add($"Saved {editor.Plan.Name}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't save plan: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteAsync(PlanEditor editor)
    {
        // Unsaved (new) editors can be dropped without a round-trip or a scary prompt.
        if (editor.Plan.Id == 0)
        {
            _editors?.Remove(editor);
            return;
        }

        var confirmed = await Dialogs.ShowMessageBox(
            "Delete plan?",
            $"Permanently delete the \"{editor.Plan.Name}\" plan? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed != true)
        {
            return;
        }

        try
        {
            Db.SubscriptionPlans.Remove(editor.Plan);
            await Db.SaveChangesAsync();
            _editors?.Remove(editor);
            Snackbar.Add("Plan removed.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't delete plan: {ex.Message}", Severity.Error);
        }
    }
}
