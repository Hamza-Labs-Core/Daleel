@page "/stores/all"
@inject IStoreRepository StoresRepo
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · @L["Products.Stores"]</PageTitle>

<div class="d-flex align-center mb-1">
    <MudText Typo="Typo.h4">@L["Products.Stores"]</MudText>
    <MudSpacer />
    <MudButton Href="/stores" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.TravelExplore">
        @L["Stores.Find"]
    </MudButton>
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@L["Browse.StoresSubtitle"]</MudText>

<MudTextField T="string" Value="_query" ValueChanged="OnQueryChanged" Immediate="true" Clearable="true"
              DebounceInterval="300" Placeholder="@L["Browse.SearchPlaceholder"]" Variant="Variant.Outlined"
              Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Class="mb-4" Style="max-width:420px;" />

@if (_loaded && _items.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@L["Browse.NoMatches"]</MudAlert>
}
<MudGrid Spacing="2">
    @foreach (var s in _items)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Class="daleel-card" Elevation="0" Outlined="true" Style="height:100%;">
                <MudCardContent>
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.subtitle1" dir="@Catalog.Dir(s.Name)">@s.Name</MudText>
                        @if (s.IsVerified)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Color="Color.Info" />
                        }
                    </div>
                    <div class="d-flex gap-2 mt-1 flex-wrap">
                        @if ((s.GoogleRating ?? s.Rating) is { } rating and > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">★ @rating.ToString("0.0")</MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(s.Location))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@s.Location</MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(s.Type))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@s.Type</MudChip>
                        }
                    </div>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Size="Size.Small" Href="@($"/store/{s.Id}?name={Uri.EscapeDataString(s.Name)}")"
                               StartIcon="@Icons.Material.Filled.Visibility">@L["Browse.View"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>
@if (_mayHaveMore)
{
    <div class="d-flex justify-center mt-4">
        <MudButton Variant="Variant.Outlined" OnClick="LoadMoreAsync" Disabled="_loading">@L["Browse.LoadMore"]</MudButton>
    </div>
}

@code {
    private const int PageSize = 24;

    private readonly List<Store> _items = new();
    private string? _query;
    private bool _loaded;
    private bool _loading;
    private bool _mayHaveMore;

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task OnQueryChanged(string? value)
    {
        _query = value;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _items.Clear();
        await LoadMoreAsync();
        _loaded = true;
    }

    private async Task LoadMoreAsync()
    {
        _loading = true;
        var page = await StoresRepo.SearchAsync(_query, _items.Count, PageSize);
        _items.AddRange(page);
        _mayHaveMore = page.Count == PageSize;
        _loading = false;
    }
}
