@page "/deals"
@inherits AgentPageBase
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · @L["Deals.Title"]</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@L["Deals.Title"]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @L["Deals.Subtitle"]
</MudText>

<MudPaper Class="pa-4" Elevation="0" Outlined="true">
    <div class="d-flex flex-wrap gap-3 align-center">
        <div style="min-width:240px;flex:2;">
            <MudTextField @bind-Value="_subject" Label="@L["Deals.ProductLabel"]"
                          Placeholder="e.g. iPhone 15, شاشة سامسونج"
                          Variant="Variant.Outlined" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.LocalOffer" OnKeyDown="OnKey" />
        </div>
        <div style="min-width:230px;flex:1;"><GeoSelect @bind-Value="Geo" /></div>
        <div style="min-width:230px;flex:1;"><ModelSelect @bind-Value="Model" /></div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Sell" OnClick="Run"
                   Disabled="Busy || string.IsNullOrWhiteSpace(_subject)">@L["Deals.FindDeals"]</MudButton>
    </div>
</MudPaper>

@if (Ready)
{
    <div class="mt-4"><ProviderStatusBar Keys="Keys" /></div>
}
@if (Error is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-3">@Error</MudAlert>
}
<ProgressLog Busy="Busy" Lines="LogLines" />

@if (_answer is null && !Busy && Error is null && LogLines.Count > 0)
{
    @* A search ran but produced no deals: show a clear empty state instead of blank space. *@
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-3">@L["Search.NoResults"]</MudAlert>
}

@if (_answer is not null && !Busy)
{
    var deals = _answer.Research.ShoppingResults.Where(r => r.Price is not null).ToList();

    <div class="d-flex my-3">
        <MudSpacer />
        <SaveResultButton Result="_answer" ResultType="deals" DefaultTitle="@($"Deals · {_subject}")" SearchHistoryId="LastHistoryId" />
    </div>

    <ReportView Title="@L["Deals.BestDeals"]" Text="@_answer.Summary" />

    @if (deals.Count > 0)
    {
        <div class="d-flex align-center mt-6 mb-2">
            <MudText Typo="Typo.h6">@L["Deals.Listings"] (@deals.Count)</MudText>
            <MudSpacer />
            <MudSelect T="DealSort" @bind-Value="_sort" Label="Sort" Dense="true" Variant="Variant.Outlined" Style="max-width:220px;">
                <MudSelectItem Value="DealSort.PriceAsc">Price: low → high</MudSelectItem>
                <MudSelectItem Value="DealSort.PriceDesc">Price: high → low</MudSelectItem>
                <MudSelectItem Value="DealSort.Rating">★ Rating</MudSelectItem>
                <MudSelectItem Value="DealSort.Relevance">Relevance</MudSelectItem>
            </MudSelect>
        </div>
        <MudGrid Spacing="3">
            @foreach (var r in SortDeals(deals))
            {
                <MudItem xs="12" sm="6" md="4"><ShoppingCard Result="r" /></MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3">
            @L["Deals.NoPriced"]
        </MudAlert>
    }

    <SourceChips Sources="_answer.Research.Sources" />
}

@code {
    private enum DealSort { PriceAsc, PriceDesc, Rating, Relevance }

    private string _subject = string.Empty;
    private DealSort _sort = DealSort.PriceAsc;
    private AgentAnswer? _answer;

    private IEnumerable<SearchResult> SortDeals(List<SearchResult> deals) => _sort switch
    {
        DealSort.PriceAsc => deals.OrderBy(r => r.Price!.Value.Amount),
        DealSort.PriceDesc => deals.OrderByDescending(r => r.Price!.Value.Amount),
        DealSort.Rating => deals.OrderByDescending(r => r.Rating ?? 0),
        _ => deals.OrderBy(r => r.Position ?? int.MaxValue)
    };

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Run();
        }
    }

    private async Task Run()
    {
        if (string.IsNullOrWhiteSpace(_subject))
        {
            return;
        }

        _answer = null;
        await Store.SetAsync("geo", Geo);
        await Store.SetAsync("model", Model);
        var query = $"current deals, discounts and promotions for {_subject}";
        await RunAsync(
            async (agent, ct) => _answer = await agent.AskAsync(query, Geo, ct),
            () => _answer is null ? null : new SearchHistoryEntry
            {
                Query = _subject,
                QueryType = "deals",
                ResultSummary = _answer.Summary
            });
    }

    protected override Task OnReadyAsync()
    {
        if (!string.IsNullOrWhiteSpace(Q))
        {
            _subject = Q!;
        }

        if (!string.IsNullOrWhiteSpace(GeoParam))
        {
            Geo = GeoParam!;
        }

        return Task.CompletedTask;
    }

    [SupplyParameterFromQuery] private string? Q { get; set; }
    [SupplyParameterFromQuery(Name = "geo")] private string? GeoParam { get; set; }
}
