@page "/forgot-password"

@* Placeholder. Self-service password reset needs an email sender (SMTP/provider) wired up first;
   until then this just points users back to sign-in. Renders interactively under MainLayout. *@

<PageTitle>دليل · Forgot password</PageTitle>

<div class="d-flex justify-center mt-8">
    <MudPaper Class="pa-8 text-center" Elevation="0" Outlined="true" Style="max-width:460px;width:100%;border-radius:18px;">
        <div class="daleel-logo mb-2" style="font-size:2rem;">دليل · Daleel</div>
        <MudText Typo="Typo.h5" Class="mb-2">إعادة تعيين كلمة المرور · Reset password</MudText>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-4">
            Password reset by email is coming soon. For now, contact support if you can't get into your account.
        </MudAlert>
        <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
            Back to sign in
        </MudButton>
    </MudPaper>
</div>
