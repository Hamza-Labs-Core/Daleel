@page "/saved"
@attribute [Authorize]
@inject ICurrentUser CurrentUser
@inject ISavedResultRepository SavedRepo
@inject ISystemConfigService Config
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · Saved</PageTitle>

<div class="d-flex align-center mb-1">
    <MudText Typo="Typo.h4">@L["Saved.Title"]</MudText>
    <MudSpacer />
    @if (_items.Count > 0 && _exportEnabled)
    {
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportAllAsync">
            Export all (JSON)
        </MudButton>
    }
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Bookmarked reports, re-rendered from their saved data — no re-running required.
</MudText>

@if (_ready && !_authenticated)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        <MudText>Sign in to save your searches.</MudText>
        <MudButton Href="/login" data-enhance-nav="false" Variant="Variant.Text" Color="Color.Primary" Class="mt-2">Sign in</MudButton>
    </MudAlert>
}
else if (_authenticated)
{
    @if (_items.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Nothing saved yet. Run a search and click <b>Save</b> on any result.
        </MudAlert>
    }
    else
    {
        <div class="d-flex align-center gap-3 mb-3 flex-wrap">
            <MudTextField T="string" @bind-Value="_search" Immediate="true" Clearable="true"
                          Placeholder="@L["Saved.SearchPlaceholder"]" Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Style="max-width:320px;" />
            <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection" SelectedValue="_typeFilter"
                        SelectedValueChanged="@((string? v) => _typeFilter = v)" CheckMark="true">
                @foreach (var t in _types)
                {
                    <MudChip T="string" Value="@t" Variant="Variant.Outlined" Color="Color.Primary">@TypeLabel(t)</MudChip>
                }
            </MudChipSet>
        </div>
        @if (Filtered.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@L["Saved.NoMatches"]</MudAlert>
        }
        <MudGrid Spacing="3">
            @foreach (var item in Filtered)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="daleel-card" Elevation="0" Outlined="true" Style="height:100%;">
                        <MudCardContent>
                            <div class="d-flex align-center gap-2 mb-1">
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@item.ResultType</MudChip>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@item.CreatedAt.LocalDateTime.ToString("g")</MudText>
                            </div>
                            <MudText Typo="Typo.subtitle1" dir="@Catalog.Dir(item.Title)">@item.Title</MudText>
                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" dir="@Catalog.Dir(item.Notes)">@item.Notes</MudText>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Visibility"
                                       OnClick="@(() => ViewAsync(item))">View</MudButton>
                            @if (_exportEnabled)
                            {
                                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Download"
                                           OnClick="@(() => ExportOneAsync(item))">JSON</MudButton>
                            }
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteAsync(item))" />
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    private string? _userId;
    private bool _ready;
    private bool _authenticated;
    private bool _exportEnabled = true;
    private List<SavedResult> _items = new();
    private string? _search;
    private string? _typeFilter;

    /// <summary>Distinct saved types, for the filter chips (only types the user actually has).</summary>
    private List<string> _types = new();

    /// <summary>Client-side filter: type chip + text over title/notes/type. The list is already small
    /// (per-user, capped for free users), so no repo round-trip.</summary>
    private IReadOnlyList<SavedResult> Filtered =>
        _items.Where(i => _typeFilter is null || string.Equals(i.ResultType, _typeFilter, StringComparison.OrdinalIgnoreCase))
              .Where(i => string.IsNullOrWhiteSpace(_search) ||
                          i.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                          (i.Notes?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                          i.ResultType.Contains(_search, StringComparison.OrdinalIgnoreCase))
              .ToList();

    private string TypeLabel(string t) => t switch
    {
        "product" or "ask" or "compare" => L["Products.Items"],
        "stores" => L["Products.Stores"],
        "brand" => L["Products.Brands"],
        _ => t
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _userId = await CurrentUser.GetUserIdAsync();
        _authenticated = _userId is not null;
        _exportEnabled = await Config.GetBoolAsync("feature.export_enabled", true);
        if (_authenticated)
        {
            await ReloadAsync();
        }

        _ready = true;
        StateHasChanged();
    }

    private async Task ReloadAsync()
    {
        if (_userId is null)
        {
            return;
        }

        _items = (await SavedRepo.ListAsync(_userId)).ToList();
        _types = _items.Select(i => i.ResultType).Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t, StringComparer.Ordinal).ToList();
    }

    private async Task ViewAsync(SavedResult item)
    {
        var parameters = new DialogParameters<SavedResultDialogHost> { { x => x.Saved, item } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        await Dialogs.ShowAsync<SavedResultDialogHost>(item.Title, parameters, options);
    }

    private async Task DeleteAsync(SavedResult item)
    {
        if (_userId is null)
        {
            return;
        }

        await SavedRepo.DeleteAsync(_userId, item.Id);
        Snackbar.Add("Deleted.", Severity.Success);
        await ReloadAsync();
        StateHasChanged();
    }

    private async Task ExportOneAsync(SavedResult item)
    {
        if (!_exportEnabled)
        {
            return;
        }

        var name = Slug(item.Title) + ".json";
        await JS.InvokeVoidAsync("daleel.download", name, item.ResultJson, "application/json");
    }

    private async Task ExportAllAsync()
    {
        if (!_exportEnabled)
        {
            return;
        }

        var export = _items.Select(i => new
        {
            i.Title, i.ResultType, i.Notes, i.CreatedAt,
            Result = System.Text.Json.JsonSerializer.Deserialize<object>(i.ResultJson)
        });
        var json = System.Text.Json.JsonSerializer.Serialize(export,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("daleel.download", "daleel-saved-results.json", json, "application/json");
    }

    private static string Slug(string s)
    {
        var clean = new string(s.Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray());
        return string.IsNullOrWhiteSpace(clean) ? "saved-result" : clean.Trim('-').ToLowerInvariant();
    }
}
