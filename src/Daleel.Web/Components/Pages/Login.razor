@page "/login"
@using System.ComponentModel.DataAnnotations
@using Daleel.Web.Data
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IAnalyticsService Analytics
@inject NavigationManager Nav

@* Static SSR (App.razor renders /login without a render mode) so the EditForm below posts back to
   this page in a real HTTP request — that's the only context where SignInManager can write the auth
   cookie. Uses the themed MainLayout like the rest of the site; the text inputs are framework
   <InputText> (MudBlazor fields don't round-trip in static form posts) styled to the dark theme. *@

<PageTitle>دليل · Sign in</PageTitle>

<div class="d-flex justify-center mt-8">
    <MudPaper Class="pa-8" Elevation="0" Outlined="true" Style="max-width:460px;width:100%;border-radius:18px;">
        <div class="text-center mb-4">
            <div class="daleel-logo" style="font-size:2rem;">دليل · Daleel</div>
            <MudText Typo="Typo.h5" Class="mt-2">تسجيل الدخول · Sign in</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Sign in to keep your search history and saved results.
            </MudText>
        </div>

        <AuthorizeView>
            <Authorized>
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    You are already signed in as @(context.User.Identity?.Name).
                </MudAlert>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
                    Go to Daleel
                </MudButton>
            </Authorized>
            <NotAuthorized>
                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@_error</MudAlert>
                }

                <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login" Context="editContext">
                    <DataAnnotationsValidator />

                    <label class="daleel-field-label" for="login-email">Email</label>
                    <InputText id="login-email" class="daleel-field" type="email" autocomplete="username"
                               @bind-Value="Input.Email" placeholder="you@example.com" />
                    <ValidationMessage For="() => Input.Email" />

                    <label class="daleel-field-label" for="login-password">Password</label>
                    <InputText id="login-password" class="daleel-field" type="password" autocomplete="current-password"
                               @bind-Value="Input.Password" placeholder="Your password" />
                    <ValidationMessage For="() => Input.Password" />

                    <div class="d-flex justify-end mt-2">
                        <MudLink Href="/forgot-password" Typo="Typo.body2">Forgot password?</MudLink>
                    </div>

                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true" Class="mt-4">
                        Sign in
                    </MudButton>
                </EditForm>

                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                    New to Daleel? <MudLink Href="/register">Create a free account</MudLink>
                </MudText>
            </NotAuthorized>
        </AuthorizeView>
    </MudPaper>
</div>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm] private InputModel Input { get; set; } = new();
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private string? _error;

    private async Task LoginUser()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);

        // Identical message whether the email is unknown or the password is wrong — never reveal which
        // accounts exist.
        if (user is null)
        {
            _error = "Invalid email or password.";
            return;
        }

        if (user.IsDisabled)
        {
            _error = "This account has been disabled. Contact support if you think this is a mistake.";
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(
            user.UserName!, Input.Password, isPersistent: true, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            user.LastActiveAt = DateTime.UtcNow;
            await UserManager.UpdateAsync(user);
            await Analytics.RecordLoginAsync(user.Id, "Password", HttpContext.Connection.RemoteIpAddress?.ToString());
            // NavigateTo on a static page issues a 302 carrying the freshly-set auth cookie.
            Nav.NavigateTo(Local(ReturnUrl), forceLoad: true);
            return;
        }

        _error = result.IsLockedOut
            ? "This account is locked out. Please try again later."
            : "Invalid email or password.";
    }

    /// <summary>Coerces a return URL to a safe local path; rejects open-redirect forms.</summary>
    private static string Local(string? returnUrl) =>
        !string.IsNullOrWhiteSpace(returnUrl)
        && returnUrl.StartsWith('/')
        && !returnUrl.StartsWith("//", StringComparison.Ordinal)
        && !returnUrl.StartsWith("/\\", StringComparison.Ordinal)
            ? returnUrl
            : "/";

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;
    }
}
