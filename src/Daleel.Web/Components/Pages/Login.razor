@page "/login"
@using Microsoft.AspNetCore.Authentication
@inject IAuthenticationSchemeProvider SchemeProvider

<PageTitle>دليل · Sign in</PageTitle>

<div class="d-flex justify-center mt-8">
    <MudPaper Class="pa-8" Elevation="0" Outlined="true" Style="max-width:460px;width:100%;border-radius:18px;">
        <div class="text-center mb-4">
            <div class="daleel-logo" style="font-size:2rem;">دليل · Daleel</div>
            <MudText Typo="Typo.h5" Class="mt-2">تسجيل الدخول · Sign in</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Sign in to keep your search history and saved results.
            </MudText>
        </div>

        @if (Error is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@ErrorText</MudAlert>
        }

        <AuthorizeView>
            <Authorized>
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    You are already signed in as @(context.User.Identity?.Name).
                </MudAlert>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
                    Go to Daleel
                </MudButton>
            </Authorized>
            <NotAuthorized>
                @if (_providers.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="text-center">
                        <MudText Typo="Typo.subtitle2">Sign-in is coming soon</MudText>
                        <MudText Typo="Typo.body2" Class="mt-1">
                            تسجيل الدخول قريباً — We're putting the finishing touches on secure sign-in.
                            Check back shortly to create your account.
                        </MudText>
                    </MudAlert>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var p in _providers)
                        {
                            <MudButton Href="@SignInHref(p.Scheme)" rel="nofollow"
                                       Variant="Variant.Outlined" Size="Size.Large" FullWidth="true"
                                       StartIcon="@Icon(p.Scheme)">
                                Continue with @p.Display
                            </MudButton>
                        }
                    </div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                        New to Daleel? <MudLink Href="/register">Create a free account</MudLink>
                    </MudText>
                }
            </NotAuthorized>
        </AuthorizeView>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private readonly List<(string Scheme, string Display)> _providers = new();

    protected override async Task OnInitializedAsync()
    {
        // Only schemes that were actually registered (i.e. configured) show up here.
        var all = await SchemeProvider.GetAllSchemesAsync();
        foreach (var s in all.Where(s => !string.IsNullOrEmpty(s.DisplayName)
                                         && !s.Name.StartsWith("Identity.", StringComparison.Ordinal)))
        {
            _providers.Add((s.Name, s.DisplayName!));
        }
    }

    private string SignInHref(string scheme)
    {
        var target = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
        return $"/auth/signin/{Uri.EscapeDataString(scheme)}?returnUrl={Uri.EscapeDataString(target)}";
    }

    private string ErrorText => Error switch
    {
        "external" => "The provider did not return a login. Please try again.",
        "lockedout" => "This account is locked out.",
        "disabled" => "This account has been disabled. Contact support if you think this is a mistake.",
        "create" => "We couldn't create your account. Please try a different provider.",
        _ => "Sign-in failed. Please try again."
    };

    private static string Icon(string scheme) => scheme switch
    {
        "Google" => Icons.Custom.Brands.Google,
        "Microsoft" => Icons.Custom.Brands.MicrosoftWindows,
        "Twitter" => Icons.Custom.Brands.Twitter,
        "GitHub" => Icons.Custom.Brands.GitHub,
        "Facebook" => Icons.Custom.Brands.Facebook,
        _ => Icons.Material.Filled.Login
    };
}
