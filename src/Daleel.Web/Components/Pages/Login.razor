@page "/login"
@attribute [StaticSsrPage]
@layout Daleel.Web.Components.Layout.AuthLayout
@* Static SSR (flagged [StaticSsrPage]; App.razor renders it without a render mode) so the plain HTML
   form below makes a real HTTP POST to /auth/login. That endpoint — not this page, not the circuit —
   calls SignInManager and writes the auth cookie, which is the only context where the Set-Cookie header
   write is safe. Rendering static also guarantees <AntiforgeryToken /> emits a valid token. *@
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · Sign in</PageTitle>

<div class="d-flex justify-center mt-8">
    <MudPaper Class="pa-8" Elevation="0" Outlined="true" Style="max-width:460px;width:100%;border-radius:18px;">
        <div class="text-center mb-4">
            <div class="daleel-logo" style="font-size:2rem;">دليل · Daleel</div>
            <MudText Typo="Typo.h5" Class="mt-2">@L["Nav.Login"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Sign in to keep your search history and saved results.
            </MudText>
        </div>

        <AuthorizeView>
            <Authorized>
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    You are already signed in as @(context.User.Identity?.Name).
                </MudAlert>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
                    Go to Daleel
                </MudButton>
            </Authorized>
            <NotAuthorized>
                @if (ErrorMessage is not null)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@ErrorMessage</MudAlert>
                }

                <form method="post" action="/auth/login">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                    <label class="daleel-field-label" for="login-email">Email</label>
                    <input id="login-email" name="email" class="daleel-field" type="email" required
                           autocomplete="username" placeholder="you@example.com" />

                    <label class="daleel-field-label" for="login-password">Password</label>
                    <input id="login-password" name="password" class="daleel-field" type="password" required
                           autocomplete="current-password" placeholder="Your password" />

                    <div class="d-flex justify-end mt-2">
                        <MudLink Href="/forgot-password" Typo="Typo.body2">Forgot password?</MudLink>
                    </div>

                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true" Class="mt-4">
                        Sign in
                    </MudButton>
                </form>

                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                    New to Daleel? <MudLink Href="/register">Create a free account</MudLink>
                </MudText>
            </NotAuthorized>
        </AuthorizeView>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    // /auth/login redirects back here with ?error=<code> on failure; map the code to a message. Unknown
    // email and wrong password both surface as the same "invalid" — never reveal which accounts exist.
    private string? ErrorMessage => Error switch
    {
        "invalid" => "Invalid email or password.",
        "disabled" => "This account has been disabled. Contact support if you think this is a mistake.",
        "lockedout" => "This account is locked out. Please try again later.",
        _ => null,
    };
}
