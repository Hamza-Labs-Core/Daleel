@page "/monitor"
@attribute [Authorize]
@inherits AgentPageBase
@inject MonitorService Monitors
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> L

<PageTitle>دليل · @L["Nav.Monitor"]</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@L["Monitor.Title"]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @L["Monitor.Subtitle"]
</MudText>

<MudGrid Spacing="3">
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudText Typo="Typo.h6" Class="mb-3">@L["Monitor.NewMonitor"]</MudText>
            <MudTextField @bind-Value="_keyword" Label="@L["Monitor.KeywordLabel"]"
                          Placeholder="@L["Monitor.KeywordPlaceholder"]" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Tag" Class="mb-3" />
            <GeoSelect @bind-Value="Geo" />
            <MudSelect T="int" @bind-Value="_interval" Label="@L["Monitor.IntervalLabel"]" Dense="true"
                       Variant="Variant.Outlined" Class="mt-3"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Schedule">
                <MudSelectItem T="int" Value="15">Every 15 min</MudSelectItem>
                <MudSelectItem T="int" Value="30">Every 30 min</MudSelectItem>
                <MudSelectItem T="int" Value="60">Hourly</MudSelectItem>
                <MudSelectItem T="int" Value="360">Every 6 hours</MudSelectItem>
                <MudSelectItem T="int" Value="1440">Daily</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="AddMonitor"
                       Disabled="string.IsNullOrWhiteSpace(_keyword)">@L["Monitor.AddMonitor"]</MudButton>
        </MudPaper>

        @if (Ready)
        {
            <div class="mt-3"><ProviderStatusBar Keys="Keys" /></div>
        }
    </MudItem>

    <MudItem xs="12" md="8">
        <MudText Typo="Typo.h6" Class="mb-2">@L["Monitor.ActiveMonitors"] (@_monitors.Count)</MudText>
        @if (_monitors.Count == 0)
        {
            <MudPaper Class="pa-6 text-center" Elevation="0" Outlined="true">
                <MudIcon Icon="@Icons.Material.Outlined.Radar" Size="Size.Large" Color="Color.Secondary" />
                <MudText Color="Color.Secondary">No monitors yet — create one on the left.</MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="2">
                @foreach (var m in _monitors)
                {
                    <MudItem xs="12">
                        <MudPaper Class="pa-3 daleel-card" Elevation="0" Outlined="true">
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <MudIcon Icon="@(m.Status == MonitorStatus.Active ? Icons.Material.Filled.PlayCircle : Icons.Material.Filled.PauseCircle)"
                                         Color="@(m.Status == MonitorStatus.Active ? Color.Success : Color.Warning)" />
                                <MudText Typo="Typo.subtitle1" dir="@Catalog.Dir(m.Keyword)">@m.Keyword</MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@Catalog.ResolveGeo(m.Geo).Flag @Catalog.ResolveGeo(m.Geo).Name</MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Schedule">@FormatInterval(m.IntervalMinutes)</MudChip>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@L["Monitor.MatchCount", m.MatchCount]</MudChip>
                                <MudSpacer />
                                <MudTooltip Text="Run now">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                                   OnClick="@(() => RunNow(m.Id))" Disabled="_running == m.Id" />
                                </MudTooltip>
                                <MudTooltip Text="@(m.Status == MonitorStatus.Active ? "Pause" : "Resume")">
                                    <MudIconButton Icon="@(m.Status == MonitorStatus.Active ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                                                   Size="Size.Small" OnClick="@(() => ToggleMonitor(m.Id))" />
                                </MudTooltip>
                                <MudTooltip Text="Delete">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => RemoveMonitor(m.Id))" />
                                </MudTooltip>
                            </div>
                            @if (m.LastRunAt is { } last)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Last run @last.LocalDateTime.ToString("g")</MudText>
                            }
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }

        <MudText Typo="Typo.h6" Class="mt-6 mb-2">@L["Monitor.ResultsFeed"] (@_feed.Count)</MudText>
        @if (_feed.Count == 0)
        {
            <MudText Color="Color.Secondary" Typo="Typo.body2">No matches yet. Run a monitor to populate the feed.</MudText>
        }
        else
        {
            <MudTimeline TimelinePosition="TimelinePosition.Start">
                @foreach (var hit in _feed.Take(50))
                {
                    <MudTimelineItem Color="@SentimentColor(hit.Sentiment)" Size="Size.Small">
                        <MudText Typo="Typo.body2" dir="@Catalog.Dir(hit.Text)">@Trim(hit.Text, 260)</MudText>
                        <div class="d-flex gap-2 align-center mt-1 flex-wrap">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Tag">@hit.Keyword</MudChip>
                            @if (!string.IsNullOrWhiteSpace(hit.Source))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@hit.Source</MudText>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Secondary">· @hit.MatchedAt.LocalDateTime.ToString("g")</MudText>
                            @if (!string.IsNullOrWhiteSpace(hit.Url))
                            {
                                <MudLink Href="@hit.Url" Target="_blank" Typo="Typo.caption">open</MudLink>
                            }
                        </div>
                    </MudTimelineItem>
                }
            </MudTimeline>
        }
    </MudItem>
</MudGrid>

@code {
    private string _keyword = string.Empty;
    private int _interval = 60;
    private string? _running;
    private string? _userId;

    // Per-user snapshots, refreshed after every mutation. The service is a process-wide singleton,
    // so these are filtered to the signed-in user — never the whole tenant's monitors/feed.
    private IReadOnlyList<MonitorDefinition> _monitors = Array.Empty<MonitorDefinition>();
    private IReadOnlyList<MonitorHit> _feed = Array.Empty<MonitorHit>();

    // AgentPageBase resolves auth on first render, then calls OnReadyAsync — load the owner here.
    protected override async Task OnReadyAsync()
    {
        // The page is [Authorize]-gated, so a user id is always present by the time we get here.
        _userId = await CurrentUser.GetUserIdAsync();
        Refresh();
    }

    private void Refresh()
    {
        if (_userId is null)
        {
            return;
        }

        _monitors = Monitors.MonitorsFor(_userId);
        _feed = Monitors.FeedFor(_userId);
    }

    private void AddMonitor()
    {
        if (string.IsNullOrWhiteSpace(_keyword) || _userId is null)
        {
            return;
        }

        Monitors.Add(_userId, _keyword, Geo, _interval);
        Snackbar.Add(L["Monitor.Added", _keyword, Catalog.ResolveGeo(Geo).Name], Severity.Success);
        _keyword = string.Empty;
        Refresh();
    }

    private void ToggleMonitor(string id)
    {
        if (_userId is null) return;
        Monitors.Toggle(_userId, id);
        Refresh();
    }

    private void RemoveMonitor(string id)
    {
        if (_userId is null) return;
        Monitors.Remove(_userId, id);
        Refresh();
    }

    private async Task RunNow(string id)
    {
        if (_userId is null) return;
        _running = id;
        try
        {
            var count = await Monitors.RunOnceAsync(_userId, id);
            if (count == -1)
            {
                Snackbar.Add(L["Monitor.RunUnavailable"], Severity.Warning);
            }
            else
            {
                var word = count == 1 ? "match" : "matches";
                Snackbar.Add($"{count} new {word} found.", count > 0 ? Severity.Success : Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Run failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _running = null;
            Refresh();
        }
    }

    private static Color SentimentColor(Sentiment s) => s switch
    {
        Sentiment.Positive => Color.Success,
        Sentiment.Negative => Color.Error,
        _ => Color.Default
    };

    private static string FormatInterval(int minutes)
    {
        if (minutes == 60)
        {
            return "hourly";
        }

        if (minutes == 1440)
        {
            return "daily";
        }

        return minutes >= 60 ? $"{minutes / 60}h" : $"{minutes}m";
    }

    private static string Trim(string s, int max) => s.Length > max ? s[..max] + "…" : s;
}
