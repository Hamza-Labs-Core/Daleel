@* Host document. MudBlazor drives styling; Cairo gives crisp Arabic glyphs, Roboto the Latin UI. *@
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture;
    var dir = culture.TextInfo.IsRightToLeft ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@culture.TwoLetterISOLanguageName" dir="@dir">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <meta name="theme-color" content="#0b0f19" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="app.css" />
    @* No Daleel.Web.styles.css link: this app has zero component-scoped (.razor.css) stylesheets —
       all styling comes from MudBlazor + the global app.css — so the SDK's scoped-CSS bundle is never
       emitted and linking it only yields a 404. If a *.razor.css file is ever added, re-add:
       <link rel="stylesheet" href="Daleel.Web.styles.css" /> *@
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />

    @* Custom reconnection card — hidden by default. boot.js retries the circuit silently and only adds
       the .daleel-reconnect-show class here after every retry has failed, so users never see the old
       "Attempting to connect…" flash during normal navigation. *@
    <div id="daleel-reconnect">
        <div class="daleel-reconnect-card">
            <div class="daleel-reconnect-title">@(_rtl ? "انقطع الاتصال بالخادم" : "Connection lost")</div>
            <div class="daleel-reconnect-text">
                @(_rtl
                    ? "تعذّر الوصول إلى الخادم بعد عدة محاولات."
                    : "We couldn't reach the server after several attempts.")
            </div>
            <div class="daleel-reconnect-actions">
                <button id="daleel-reconnect-retry" type="button" class="daleel-reconnect-btn">
                    @(_rtl ? "إعادة المحاولة" : "Try again")
                </button>
                <a href="/status" class="daleel-reconnect-link">@(_rtl ? "حالة النظام" : "Check status")</a>
            </div>
        </div>
    </div>

    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="daleel.js"></script>
    @* autostart=false lets boot.js call Blazor.start() with our silent reconnection handler. *@
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script src="boot.js"></script>
</body>

</html>

@code {
    // App.razor is the only component guaranteed to render statically (it's the host document), so it
    // picks a render mode per page here. Everything is InteractiveServer — that is what makes the
    // layout's drawer toggle, theme switch and menus live — EXCEPT pages flagged [StaticSsrPage] (the
    // auth pages /login, /register, /logout). Those render static so their <AntiforgeryToken /> form
    // posts work; the posts target raw /auth/* endpoints (see AuthEndpoints) where the cookie write
    // happens in a real HTTP request, never a streaming circuit.
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    // The host document is static SSR, so the reconnection card (which lives outside the Blazor circuit)
    // can't be localized via IStringLocalizer at runtime — read the request culture directly instead.
    private static bool _rtl => System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;

    // Decide static-vs-interactive from the MATCHED PAGE COMPONENT TYPE, not the request path. Blazor's
    // router resolves that type and stamps it onto the endpoint as ComponentTypeMetadata, so the signal
    // survives a reverse proxy rewriting Request.Path — the failure mode that made the old path check
    // wrongly render /login as InteractiveServer behind Caddy, streaming the response and crashing the
    // cookie write with "Headers are read-only, response has already started".
    private IComponentRenderMode? PageRenderMode
    {
        get
        {
            var pageType = HttpContext.GetEndpoint()?
                .Metadata.GetMetadata<Microsoft.AspNetCore.Components.Endpoints.ComponentTypeMetadata>()?
                .Type;
            var isStatic = pageType?.IsDefined(typeof(StaticSsrPageAttribute), inherit: false) == true;
            return isStatic ? null : InteractiveServer;
        }
    }
}
