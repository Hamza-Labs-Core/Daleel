@* Product-search display. The product list is the ONLY primary surface — the research behind it
   (stores, brands, reviews, mentions) attaches to each product card instead of trailing the grid
   as "Also found" sections. When a search returns no products at all, the secondary content is
   shown directly so the page is never empty. Brand cards drill into the product list pre-filtered
   to that brand. *@
@inject IStringLocalizer<SharedResource> L

@if (Result.ProductCount > 0)
{
    @* PRIMARY — the product grid (cards → detail dialog with price comparison + reviews). *@
    <ProductListings Result="Result" InitialBrand="@_brandFilter" />
}
else if (HasSecondary)
{
    @* No distinct product models — surface whatever we did find so the search isn't a dead end. *@
    @if (Result.StoreCount > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Store" Class="mr-1" />@L["Products.Stores"] (@Result.StoreCount)
        </MudText>
        <StoreCards Stores="Result.Stores" />
    }
    @if (Result.BrandCount > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2 mt-4">
            <MudIcon Icon="@Icons.Material.Filled.Verified" Class="mr-1" />@L["Products.Brands"] (@Result.BrandCount)
        </MudText>
        <BrandCards Brands="Result.Brands" OnViewProducts="DrillToBrand" />
    }
    @if (Result.HasUserReviews)
    {
        <MudText Typo="Typo.h6" Class="mb-2 mt-4">
            <MudIcon Icon="@Icons.Material.Filled.RateReview" Class="mr-1" />@L["Products.Reviews"] (@Result.UserReviewCount)
        </MudText>
        <UserReviewList Result="Result" />
    }
    @if (Result.ArticleCount > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2 mt-4">
            <MudIcon Icon="@Icons.Material.Filled.Article" Class="mr-1" />@L["Results.RelatedArticles"] (@Result.ArticleCount)
        </MudText>
        <ReviewList Reviews="Result.Reviews" />
    }
}
else
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
        @string.Format(L["Results.NoneInCountry"], Result.Country)
    </MudAlert>
}

@code {
    [Parameter, EditorRequired] public ProductSearchResult Result { get; set; } = default!;

    /// <summary>Brand the product list is currently filtered to (set by drilling in from a brand card).</summary>
    private string? _brandFilter;

    /// <summary>Whether there's any non-product content (stores / brands / reviews / articles) to show.</summary>
    private bool HasSecondary =>
        Result.StoreCount > 0 || Result.BrandCount > 0 || Result.HasUserReviews || Result.ArticleCount > 0;

    private void DrillToBrand(string brand)
    {
        // Filter the (already-primary) product list to this brand; ProductListings re-reads
        // InitialBrand on parameter change.
        _brandFilter = brand;
        StateHasChanged();
    }
}
