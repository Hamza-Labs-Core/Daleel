@* Adaptive product-search display. Shows only the buckets that have results, as tabs, and
   opens on whichever bucket is largest. A single populated bucket renders directly (no tabs).
   Brand cards drill down into the Products tab pre-filtered to that brand. *@

@if (TabCount == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
        No local products, stores, or brands were found for this search in @Result.Country.
    </MudAlert>
}
else if (TabCount == 1)
{
    @* One bucket only — render its dedicated layout without tab chrome. *@
    @RenderBucket(LargestBucket)
}
else
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_active" Class="mb-3">
        @if (Result.ProductCount > 0)
        {
            <MudTabPanel Text="@($"Products ({Result.ProductCount})")" Icon="@Icons.Material.Filled.ShoppingBag">
                <div class="pt-3">@RenderProducts()</div>
            </MudTabPanel>
        }
        @if (Result.StoreCount > 0)
        {
            <MudTabPanel Text="@($"Stores ({Result.StoreCount})")" Icon="@Icons.Material.Filled.Store">
                <div class="pt-3"><StoreCards Stores="Result.Stores" /></div>
            </MudTabPanel>
        }
        @if (Result.BrandCount > 0)
        {
            <MudTabPanel Text="@($"Brands ({Result.BrandCount})")" Icon="@Icons.Material.Filled.Verified">
                <div class="pt-3"><BrandCards Brands="Result.Brands" OnViewProducts="DrillToBrand" /></div>
            </MudTabPanel>
        }
        @if (Result.ReviewCount > 0)
        {
            <MudTabPanel Text="@($"Reviews ({Result.ReviewCount})")" Icon="@Icons.Material.Filled.Article">
                <div class="pt-3"><ReviewList Reviews="Result.Reviews" /></div>
            </MudTabPanel>
        }
    </MudTabs>
}

@code {
    [Parameter, EditorRequired] public ProductSearchResult Result { get; set; } = default!;

    private int _active;
    private string? _brandFilter;

    // Tab order matches the panel order above: Products, Stores, Brands, Reviews.
    private bool[] Present => new[]
    {
        Result.ProductCount > 0, Result.StoreCount > 0, Result.BrandCount > 0, Result.ReviewCount > 0
    };

    private int[] Counts => new[] { Result.ProductCount, Result.StoreCount, Result.BrandCount, Result.ReviewCount };

    private int TabCount => Present.Count(p => p);

    private int LargestBucket
    {
        get
        {
            var counts = Counts;
            var best = 0;
            for (var i = 1; i < counts.Length; i++)
            {
                if (counts[i] > counts[best]) best = i;
            }
            return best;
        }
    }

    protected override void OnParametersSet()
    {
        // Open on the largest bucket — translate its bucket index into the visible-tab index.
        var target = LargestBucket;
        _active = Present.Take(target).Count(p => p);
    }

    private void DrillToBrand(string brand)
    {
        _brandFilter = brand;
        // Switch to the Products tab (index 0 when products are present).
        _active = 0;
    }

    private RenderFragment RenderProducts() => @<ProductListings Result="Result" InitialBrand="@_brandFilter" />;

    private RenderFragment RenderBucket(int bucket) => bucket switch
    {
        1 => @<StoreCards Stores="Result.Stores" />,
        2 => @<BrandCards Brands="Result.Brands" OnViewProducts="DrillToBrand" />,
        3 => @<ReviewList Reviews="Result.Reviews" />,
        _ => RenderProducts()
    };
}
