@* Brand directory: one card per brand with its official site, how many models it covers,
   and a drill-down into that brand's products. *@
<MudGrid Spacing="3">
    @foreach (var b in Brands)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Class="daleel-card" Elevation="0" Outlined="true" Style="height:100%;">
                <MudCardContent>
                    <div class="d-flex align-center gap-2">
                        @if (!string.IsNullOrWhiteSpace(b.LogoUrl))
                        {
                            <SafeImage Src="@b.LogoUrl" Alt="@b.Name" Style="height:32px;width:32px;object-fit:contain;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Info" />
                        }
                        <MudText Typo="Typo.h6">@b.Name</MudText>
                    </div>
                    <div class="d-flex align-center gap-2 mt-1" style="flex-wrap:wrap;">
                        @if (b.ListingCount > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @b.ListingCount @(b.ListingCount == 1 ? "model" : "models") in this market
                            </MudText>
                        }
                        @if (b.PriceRange is { } range)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                     Icon="@Icons.Material.Filled.Sell">@range</MudChip>
                        }
                    </div>

                    @if (b.Models.Count > 0)
                    {
                        <div class="d-flex align-center gap-1 mt-1" style="flex-wrap:wrap;">
                            @foreach (var model in b.Models)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                         Class="ma-0" dir="@Catalog.Dir(model)">@model</MudChip>
                            }
                        </div>
                    }

                    @if (b.Reputation is { HasSignal: true })
                    {
                        <div class="mt-1"><BrandReputationView Reputation="b.Reputation" Compact="true" /></div>
                        <BrandReputationView Reputation="b.Reputation" Compact="false" />
                    }
                </MudCardContent>
                <MudCardActions>
                    @if (b.ListingCount > 0)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ShoppingBag"
                                   OnClick="@(() => OnViewProducts.InvokeAsync(b.Name))">View products</MudButton>
                    }
                    @if (!string.IsNullOrWhiteSpace(b.Url))
                    {
                        <MudButton Href="@b.Url" Target="_blank" Size="Size.Small" Variant="Variant.Text"
                                   StartIcon="@Icons.Material.Filled.OpenInNew">Official site</MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<BrandInfo> Brands { get; set; } = Array.Empty<BrandInfo>();
    [Parameter] public EventCallback<string> OnViewProducts { get; set; }
}
