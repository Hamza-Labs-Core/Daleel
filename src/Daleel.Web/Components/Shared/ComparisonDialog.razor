@* Side-by-side comparison of 2–4 models. The actual per-spec table (schema-aware rows, best-value
   highlighting, N/A for missing specs) lives in the shared <ComparisonTable>, so this dialog and the
   full-page /compare view render identical numbers. *@
@using Daleel.Core.Intelligence
@inject NavigationManager Nav

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Compare" Class="mr-2" />Compare products
            @if (!Schema.IsEmpty)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                         Class="ml-2">@Schema.ProductType</MudChip>
            }
        </MudText>
    </TitleContent>
    <DialogContent>
        <ComparisonTable Items="Items" Schema="Schema" />
    </DialogContent>
    <DialogActions>
        @* Discovery path to the full-page /compare (otherwise reachable only by URL): prefill it with the
           two items being compared so the dedicated page isn't orphaned behind a deep link. *@
        <MudButton StartIcon="@Icons.Material.Filled.OpenInFull" OnClick="OpenFullComparison">Open full comparison</MudButton>
        <MudSpacer />
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public IReadOnlyList<ProductModel> Items { get; set; } = Array.Empty<ProductModel>();

    /// <summary>The product-type-aware schema for this search; empty falls back to the spec union.</summary>
    [Parameter] public ProductSchema Schema { get; set; } = ProductSchema.General;

    private void Close() => MudDialog.Close();

    private void OpenFullComparison()
    {
        var names = Items.Select(i => i.Name).Where(n => !string.IsNullOrWhiteSpace(n)).Take(2).ToList();
        // /compare reads the "A vs B" form via its Q query param (same shape History deep-links use).
        var url = names.Count == 2
            ? $"/compare?q={Uri.EscapeDataString($"{names[0]} vs {names[1]}")}"
            : "/compare";

        MudDialog.Close();
        Nav.NavigateTo(url);
    }
}
