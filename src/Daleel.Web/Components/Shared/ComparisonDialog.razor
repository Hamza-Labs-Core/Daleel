@* Side-by-side comparison of 2–4 models: lowest price, sources, condition, specs.
   The cheapest column is highlighted as best value. *@

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Compare" Class="mr-2" />Compare products
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="overflow-x:auto;">
            <MudSimpleTable Dense="true" Bordered="true" Style="min-width:480px;">
                <thead>
                    <tr>
                        <th></th>
                        @foreach (var m in Items)
                        {
                            <th style="@HeaderStyle(m)">
                                <MudText Typo="Typo.subtitle2" dir="@Catalog.Dir(m.Name)">@m.Name</MudText>
                                @if (IsCheapest(m))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                             Icon="@Icons.Material.Filled.Savings">Best value</MudChip>
                                }
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Lowest price</strong></td>
                        @foreach (var m in Items)
                        {
                            <td style="@HeaderStyle(m)">
                                @if (m.LowestPrice is { } p && m.LowestOffer?.Currency is { } c)
                                {
                                    <MudText Color="Color.Primary" Typo="Typo.body1" Style="font-weight:600;">@(new Money(p, c).ToDisplay())</MudText>
                                }
                                else { <span>—</span> }
                            </td>
                        }
                    </tr>
                    <tr>
                        <td><strong>Sellers</strong></td>
                        @foreach (var m in Items)
                        {
                            <td>@m.SellerCount</td>
                        }
                    </tr>
                    @foreach (var key in SpecKeys)
                    {
                        <tr>
                            <td><strong>@Humanize(key)</strong></td>
                            @foreach (var m in Items)
                            {
                                <td>@(m.Specs.TryGetValue(key, out var v) ? v : "—")</td>
                            }
                        </tr>
                    }
                    <tr>
                        <td><strong>Buy</strong></td>
                        @foreach (var m in Items)
                        {
                            <td>
                                @if (m.LowestOffer?.Url is { Length: > 0 } url)
                                {
                                    <MudButton Href="@url" Target="_blank" Size="Size.Small" Variant="Variant.Filled"
                                               Color="Color.Primary" StartIcon="@Icons.Material.Filled.ShoppingCart">Buy</MudButton>
                                }
                                else { <span>—</span> }
                            </td>
                        }
                    </tr>
                </tbody>
            </MudSimpleTable>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public IReadOnlyList<ProductModel> Items { get; set; } = Array.Empty<ProductModel>();

    private IReadOnlyList<string> SpecKeys =>
        Items.SelectMany(i => i.Specs.Keys).Distinct(StringComparer.OrdinalIgnoreCase).ToList();

    private decimal? MinPrice => Items.Where(i => i.LowestPrice is not null).Select(i => i.LowestPrice).DefaultIfEmpty(null).Min();

    private bool IsCheapest(ProductModel m) => MinPrice is { } min && m.LowestPrice == min;

    private string HeaderStyle(ProductModel m) =>
        IsCheapest(m) ? "background:var(--mud-palette-success-hover);" : string.Empty;

    private static string Humanize(string key) =>
        string.Join(' ', key.Replace('_', ' ').Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(w => char.ToUpperInvariant(w[0]) + w[1..]));

    private void Close() => MudDialog.Close();
}
