@* Shown on a visitor's first search when we couldn't auto-detect their market — so we ask rather
   than silently assuming one. The chosen market key is returned to the caller, which persists it. *@
@inject IStringLocalizer<SharedResource> L

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">@L["Market.Prompt"]</MudText>
        <GeoSelect Value="@_geo" ValueChanged="@(v => _geo = v)" />
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm">@L["Market.Confirm"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    /// <summary>Pre-selected market (a sensible regional default until the user changes it).</summary>
    [Parameter] public string Initial { get; set; } = "jordan";

    private string _geo = "jordan";

    protected override void OnInitialized() => _geo = string.IsNullOrWhiteSpace(Initial) ? "jordan" : Initial;

    private void Confirm() => Dialog.Close(DialogResult.Ok(_geo));
}
