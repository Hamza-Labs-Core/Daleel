@* Polished, animated search-progress UI. ONE always-visible vertical stepper of a handful of vague,
   shopper-facing phases (Understanding → Scanning → Gathering → Details → Weighing → Ready), with a
   proportional bar and a *live detail line* under each phase. Driven entirely by the encoded progress
   strings streamed from the pipeline — each message decodes into a SearchProgressSignal (step + key +
   args), maps onto its display phase (see PhaseMap), and is localized in the viewer's culture. The
   latest message for a phase becomes its detail line, so the user sees warm, non-technical hints of
   what's happening now (e.g. "Comparing prices for the top picks…") without ever exposing the
   machinery — no provider names, no models, no scraping, no caches. The stepper itself is the whole
   narrative; there's no separate feed and nothing behind an expander. See SearchProgressSignal. *@
@inject IStringLocalizer<SharedResource> L

<MudPaper Class="pa-3 pa-sm-4 mb-3 daleel-card daleel-progress" Outlined="true" Elevation="0" aria-live="polite">

    @* ── Header: pulsing dot + current stage + step counter + cancel ───────────────── *@
    <div class="d-flex align-center gap-2 gap-sm-3 mb-2 mb-sm-3 daleel-progress-head">
        @if (Active)
        {
            <span class="daleel-status-pulse"></span>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
        }
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                 Icon="@Steps[_current].Icon" Class="daleel-stage-chip">
            @L[Steps[_current].LabelKey]
        </MudChip>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="daleel-step-counter" Color="Color.Secondary">
            @L["Progress.StepCount", _current + 1, Steps.Length] · @_percent%
        </MudText>
        @if (OnCancel.HasDelegate)
        {
            <MudButton Size="Size.Small" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop"
                       Class="daleel-cancel-btn" OnClick="OnCancel">@L["Search.Cancel"]</MudButton>
        }
    </div>

    @* ── Proportional progress bar (sits high so the percentage above always has meaning) ── *@
    <MudProgressLinear Color="Color.Primary" Rounded="true" Value="@_percent"
                       Class="daleel-progress-bar mb-3" Style="height:6px;"
                       aria-label="@L["Progress.StepCount", _current + 1, Steps.Length]" />

    @* ── Always-visible vertical stepper: every stage, with its live detail line ─────── *@
    <div class="daleel-stepper-v" role="list">
        @for (var i = 0; i < Steps.Length; i++)
        {
            // Capture per-iteration locals. `i` is a single shared loop variable, so any RenderFragment
            // (e.g. a component's child content) closing over it would read i == Steps.Length after the
            // loop and throw IndexOutOfRangeException. These locals are safe to capture.
            var step = Steps[i];
            var state = StateOf(i);
            var detail = _detail[i];
            var showSpinner = state == "active" && Active;
            <div class="daleel-step-row daleel-step-v @state" role="listitem">
                <div class="daleel-step-icon">
                    @if (state == "done")
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="daleel-step-check" />
                    }
                    else if (showSpinner)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary"
                                             Style="width:18px;height:18px;" />
                    }
                    else
                    {
                        <MudIcon Icon="@step.Icon" Size="Size.Small" />
                    }
                </div>
                <div class="daleel-step-v-body">
                    <MudText Typo="Typo.body2" Class="daleel-step-row-label">@L[step.LabelKey]</MudText>
                    @* The live detail line — the most recent real event for this stage. Shown when we have
                       one; the active stage's line carries the dir of its (possibly Arabic) subject. *@
                    @if (!string.IsNullOrWhiteSpace(detail))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Class="daleel-step-detail" dir="@Catalog.Dir(detail!)">@detail</MudText>
                    }
                </div>
            </div>
        }
    </div>
</MudPaper>

@code {
    /// <summary>The raw progress strings streamed so far (encoded signals and/or plain lines).</summary>
    [Parameter] public IReadOnlyList<string> Messages { get; set; } = Array.Empty<string>();

    /// <summary>Whether the search is still running (controls the active-step glow vs. a settled view).</summary>
    [Parameter] public bool Active { get; set; } = true;

    /// <summary>Invoked when the user hits Cancel. When unset, the Cancel button is hidden.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    private int _current;       // index into Steps of the furthest stage reached
    private int _percent;       // progress-bar fill (0–100)
    // The latest localized detail line per stage, e.g. _detail[FindingStores] = "Looking up Amazon…".
    // Null/empty for stages that haven't reported anything specific yet.
    private string?[] _detail = Array.Empty<string?>();

    // The user-facing phases. Deliberately vague: they describe what the search is doing *for the
    // shopper*, never how — no providers, models, scraping, caches or named third-party services leak
    // here. Several internal pipeline stages fold into one phase (see PhaseMap), so the stepper stays
    // short and calm instead of narrating the machinery. Order matches execution, so it only moves forward.
    private readonly StepDef[] Steps =
    {
        new(Icons.Material.Filled.Search,        "Progress.Step.Analyzing"),  // Understanding your search
        new(Icons.Material.Filled.TravelExplore, "Progress.Step.Web"),        // Scanning the market
        new(Icons.Material.Filled.ShoppingBag,   "Progress.Step.Extract"),    // Gathering your options
        new(Icons.Material.Filled.FactCheck,     "Progress.Step.Profiles"),   // Digging into the details
        new(Icons.Material.Filled.Balance,       "Progress.Step.Compare"),    // Weighing your options
        new(Icons.Material.Filled.CheckCircle,   "Progress.Step.Done"),       // Ready
    };

    // Maps each internal SearchStep (the wire value streamed from the pipeline — never renumbered, see
    // SearchProgressSignal) onto its display phase above. BuildingProfiles + FindingStores share the
    // "details" phase, and the retired cache-check stage folds into "understanding".
    private static readonly int[] PhaseMap = { 0, 0, 1, 2, 3, 3, 4, 5 };

    private static int PhaseOf(SearchStep step) => PhaseMap[Math.Clamp((int)step, 0, PhaseMap.Length - 1)];

    private readonly record struct StepDef(string Icon, string LabelKey);

    // The visual state of step i. When the search has settled (not Active) every step reads as done so
    // the final view is a clean all-green list rather than a frozen mid-run snapshot.
    private string StateOf(int i)
        => !Active || i < _current ? "done" : i == _current ? "active" : "pending";

    // Recompute step + per-stage detail from the message list on every render trigger. Cheap (≤ a few
    // dozen lines) and keeps this component a pure projection of its inputs — no event wiring of its own.
    protected override void OnParametersSet()
    {
        var reached = 0;
        var detail = new string?[Steps.Length];

        foreach (var msg in Messages)
        {
            if (SearchProgressSignal.TryDecode(msg, out var sig))
            {
                var phase = PhaseOf(sig.Step);
                reached = Math.Max(reached, phase);
                var text = Localize(sig);
                // Latest message for a phase wins — that's the real-time "what's happening now" line.
                if (!string.IsNullOrWhiteSpace(text)) detail[phase] = text;
            }
            // Plain (non-encoded) lines are the agent's own diagnostics; they don't belong to a stage and
            // are no longer surfaced — the stepper's per-stage detail is the user-facing narrative.
        }

        _detail = detail;
        _current = Math.Clamp(reached, 0, Steps.Length - 1);
        // +1 so the very first stage already shows a sliver of fill; Done lands on a full bar.
        _percent = (int)Math.Round((_current + 1) / (double)Steps.Length * 100);
    }

    // Resolve a signal's text in the viewer's culture. An arg of the form "$Resource.Key" is itself a
    // resource key (e.g. the query-type noun) and is localized before being formatted into the line.
    private string Localize(SearchProgressSignal sig)
    {
        if (sig.Args.Count == 0)
        {
            return L[sig.Key];
        }

        var args = new object[sig.Args.Count];
        for (var i = 0; i < sig.Args.Count; i++)
        {
            var a = sig.Args[i];
            args[i] = a.Length > 0 && a[0] == '$' ? L[a[1..]].Value : a;
        }
        return L[sig.Key, args];
    }
}
