@* Small modal that captures a title + optional notes before bookmarking a result. *@

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_title" Label="Title · العنوان" Variant="Variant.Outlined"
                      Immediate="true" MaxLength="300" Class="mb-3" />
        <MudTextField @bind-Value="_notes" Label="Notes · ملاحظات (optional)" Variant="Variant.Outlined"
                      Lines="3" AutoGrow="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">إلغاء · Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Bookmark"
                   Disabled="string.IsNullOrWhiteSpace(_title)" OnClick="Submit">
            حفظ · Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    /// <summary>Pre-filled title (usually the query the result came from).</summary>
    [Parameter] public string DefaultTitle { get; set; } = string.Empty;

    private string _title = string.Empty;
    private string? _notes;

    protected override void OnInitialized() => _title = DefaultTitle;

    private void Submit() => Dialog.Close(DialogResult.Ok(new SaveDetails(_title.Trim(), _notes)));

    private void Cancel() => Dialog.Cancel();

    /// <summary>The values the user confirmed in the dialog.</summary>
    public sealed record SaveDetails(string Title, string? Notes);
}
