@* Shows product/brand images by default — blurring inappropriate ones is the job of the HaramBlur
   browser extension we recommend, not the app. Users who still want app-side blur can opt in via the
   Settings toggle (img.blur), and per-domain "trust" choices live in localStorage. *@
@inject BrowserStore Store

@if (string.IsNullOrWhiteSpace(Src))
{
    @* nothing to show *@
}
else if (_revealed)
{
    @* referrerpolicy="no-referrer": we hot-link product/brand images straight from their source, and many
       marketplace/CDN hosts serve a 403 to cross-origin hot-links (referer-based hotlink protection). Sending
       no Referer defeats that check, so far more external product shots actually load instead of breaking. *@
    <img src="@Src" alt="@Alt" class="@Class" style="@Style" loading="lazy" referrerpolicy="no-referrer" />
}
else
{
    <div class="safe-image-wrap @Class" style="@Style">
        <img src="@Src" alt="@Alt" class="safe-image-blur" loading="lazy" referrerpolicy="no-referrer" />
        <div class="safe-image-overlay">
            <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Color="Color.Surface" />
            <MudText Typo="Typo.caption" Style="color:#fff;">Image hidden</MudText>
            <div class="d-flex gap-1 mt-1">
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="Reveal">Show image</MudButton>
                @if (_domain is not null)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" Style="color:#fff;"
                               OnClick="TrustDomain">Trust source</MudButton>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string? Src { get; set; }
    [Parameter] public string? Alt { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    // Visible from the very first render — the image must show without depending on a later client round-trip.
    // OnAfterRenderAsync only ever moves us the *other* way (visible → blurred) for users who opted into
    // app-side blur. Starting hidden and revealing in OnAfterRenderAsync would fail closed: that callback
    // never runs during prerender/static SSR and not at all without JS interop, so every image would be
    // stuck behind the "Image hidden" overlay. Defaulting to shown fails open, matching "images by default".
    private bool _revealed = true;
    private string? _domain;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // App-side blur is opt-in (img.blur = "1"); when it's off — the default — the image already shows
        // and there is nothing to do. Reading localStorage needs JS interop, so this only runs client-side.
        var blurOn = (await Store.GetAsync("img.blur") ?? "0") != "0";
        if (!blurOn)
        {
            return;
        }

        _domain = ExtractDomain(Src);
        var trusted = await TrustedDomainsAsync();
        var hide = _domain is null || !trusted.Contains(_domain);
        if (hide && _revealed)
        {
            _revealed = false;
            StateHasChanged();
        }
    }

    private void Reveal() => _revealed = true;

    private async Task TrustDomain()
    {
        if (_domain is null)
        {
            return;
        }

        var trusted = await TrustedDomainsAsync();
        if (!trusted.Contains(_domain))
        {
            trusted.Add(_domain);
            await Store.SetAsync("img.trusted", string.Join(",", trusted));
        }

        _revealed = true;
    }

    private async Task<List<string>> TrustedDomainsAsync()
    {
        var raw = await Store.GetAsync("img.trusted") ?? string.Empty;
        return raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private static string? ExtractDomain(string? url) =>
        Uri.TryCreate(url, UriKind.Absolute, out var uri) ? uri.Host : null;
}
