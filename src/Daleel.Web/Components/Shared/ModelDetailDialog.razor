@* "Details & prices" for a model straight from the search results. All content rendering lives in
   ModelDetailBody (shared with the full /product page so the two surfaces can't drift); this wrapper
   only adds the dialog chrome and the jump to the dedicated page, which re-reads from the database. *@
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@L["Products.Details"]</MudText>
    </TitleContent>
    <DialogContent>
        <ModelDetailBody Model="_model" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="ViewFullDetails" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.OpenInFull">View Full Details</MudButton>
        <MudButton OnClick="Close">@L["Common.Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter, EditorRequired] public ProductModel Model { get; set; } = default!;
    [Parameter] public string Geo { get; set; } = "jordan";

    private ProductModel _model = default!;

    protected override void OnInitialized() => _model = Model;

    // Close the dialog and open the dedicated full page for this model. Routing is by the model's
    // stable id; the human name (which reconstructs the DB lookup key) and geo travel as params.
    private void ViewFullDetails()
    {
        var query = string.IsNullOrWhiteSpace(_model.Model) ? _model.Name : $"{_model.Brand} {_model.Model}".Trim();
        MudDialog.Close();
        Nav.NavigateTo($"/product/{_model.Id}?name={Uri.EscapeDataString(query)}&geo={Uri.EscapeDataString(Geo)}");
    }

    private void Close() => MudDialog.Close();
}
