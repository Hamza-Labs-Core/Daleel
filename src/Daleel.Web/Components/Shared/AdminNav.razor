@* Tab strip shared across the admin pages. Labels are localized (English / Arabic) via the catalogue. *@
@inject IStringLocalizer<SharedResource> L
<MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-4 d-flex flex-wrap gap-1">
    <MudButton Href="/admin" StartIcon="@Icons.Material.Filled.Dashboard" Size="Size.Small">@L["Admin.Nav.Dashboard"]</MudButton>
    <MudButton Href="/admin/users" StartIcon="@Icons.Material.Filled.People" Size="Size.Small">@L["Admin.Nav.Users"]</MudButton>
    <MudButton Href="/admin/plans" StartIcon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Small">@L["Admin.Nav.Plans"]</MudButton>
    <MudButton Href="/admin/analytics" StartIcon="@Icons.Material.Filled.QueryStats" Size="Size.Small">@L["Admin.Nav.Analytics"]</MudButton>
    <MudButton Href="/admin/usage" StartIcon="@Icons.Material.Filled.Insights" Size="Size.Small">@L["Admin.Nav.Usage"]</MudButton>
    <MudButton Href="/admin/providers" StartIcon="@Icons.Material.Filled.Receipt" Size="Size.Small">@L["Admin.Nav.Providers"]</MudButton>
    <MudButton Href="/admin/timeline" StartIcon="@Icons.Material.Filled.Timeline" Size="Size.Small">@L["Admin.Nav.Timeline"]</MudButton>
    <MudButton Href="/admin/workflows" StartIcon="@Icons.Material.Filled.AccountTree" Size="Size.Small">@L["Admin.Nav.Workflows"]</MudButton>
    <MudButton Href="/admin/data" StartIcon="@Icons.Material.Filled.Storage" Size="Size.Small">@L["Admin.Nav.Data"]</MudButton>
    <MudButton Href="/admin/cleardata" StartIcon="@Icons.Material.Filled.DeleteSweep" Size="Size.Small">@L["Admin.Nav.ClearData"]</MudButton>
    <MudButton Href="/admin/moderation" StartIcon="@Icons.Material.Filled.Shield" Size="Size.Small">@L["Admin.Nav.Moderation"]</MudButton>
    <MudButton Href="/admin/filtered" StartIcon="@Icons.Material.Filled.FilterAlt" Size="Size.Small">@L["Admin.Nav.Filtered"]</MudButton>
    <MudButton Href="/admin/images" StartIcon="@Icons.Material.Filled.Image" Size="Size.Small">@L["Admin.Nav.Images"]</MudButton>
    <MudButton Href="/admin/brands" StartIcon="@Icons.Material.Filled.BrandingWatermark" Size="Size.Small">@L["Admin.Nav.Brands"]</MudButton>
    <MudButton Href="/admin/stores" StartIcon="@Icons.Material.Filled.Store" Size="Size.Small">@L["Admin.Nav.Stores"]</MudButton>
    <MudButton Href="/admin/queues" StartIcon="@Icons.Material.Filled.Queue" Size="Size.Small">@L["Admin.Nav.Queues"]</MudButton>
    <MudButton Href="/admin/credentials" StartIcon="@Icons.Material.Filled.Key" Size="Size.Small">@L["Admin.Nav.Credentials"]</MudButton>
    <MudButton Href="/admin/api" StartIcon="@Icons.Material.Filled.Api" Size="Size.Small">@L["Admin.Nav.Api"]</MudButton>
    <MudButton Href="/admin/settings" StartIcon="@Icons.Material.Filled.Settings" Size="Size.Small">@L["Admin.Nav.Settings"]</MudButton>
</MudPaper>
