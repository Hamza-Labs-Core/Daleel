@* A single aggregated product model: image, name, lowest price across all its sources,
   how many sellers carry it, deal flag, a Details button and an optional compare checkbox. *@
@inject IStringLocalizer<SharedResource> L
@inject Daleel.Web.Services.IRelevanceFeedbackService Feedback
@inject Daleel.Web.Services.ICurrentUser CurrentUser
@inject ISnackbar Snackbar

<MudCard Class="daleel-card" Elevation="0" Outlined="true" Style="height:100%;display:flex;flex-direction:column;">
    <div style="height:150px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--mud-palette-background-grey);">
        @if (!string.IsNullOrWhiteSpace(Model.DisplayImageUrl))
        {
            <SafeImage Src="@Model.DisplayImageUrl" Alt="@Model.Name" Style="max-height:150px;max-width:100%;object-fit:contain;" />
        }
        else
        {
            @* No image available for this model — show a neutral placeholder so the grid stays even
               and the card doesn't collapse to a ragged height. *@
            <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Style="opacity:0.35;" />
        }
    </div>

    <MudCardContent Class="flex-grow-1">
        <div class="d-flex align-center justify-space-between mb-1" style="gap:8px;">
            @if (Model.LowestOffer is { } lo)
            {
                @* When the offer carries the store's own site, the seller chip links to it —
                   same affordance as the View button (new tab), visual style unchanged. *@
                @if (lo.StoreUrl is { Length: > 0 } storeUrl)
                {
                    <a href="@storeUrl" target="_blank" rel="noopener" style="text-decoration:none;">
                        <SourceBadge SourceType="lo.SourceType" Source="@lo.Source" />
                    </a>
                }
                else
                {
                    <SourceBadge SourceType="lo.SourceType" Source="@lo.Source" />
                }
            }
            @if (ShowCompare)
            {
                <MudCheckBox T="bool" Value="Selected" ValueChanged="OnToggleCompare" Dense="true"
                             Size="Size.Small" Disabled="@(!Selected && !CanSelectMore)" Label="@L["Products.Compare"]" />
            }
        </div>

        @* Search results are cached language-agnostically, and an Arabic-first market (e.g. Jordan) yields
           Arabic product/brand names even under an English UI. Route names through TranslatedText so they
           are translated to the current UI language at display time — cache-first and best-effort, a
           transparent pass-through when no DeepL key is set or the text already matches the UI language. *@
        <TranslatedText Text="@(Daleel.Core.Models.HtmlText.Strip(Model.Name) ?? Model.Name)" Typo="Typo.body1" Style="font-weight:500;line-height:1.3;" />

        @if (!string.IsNullOrWhiteSpace(BrandLine))
        {
            <TranslatedText Text="@BrandLine" Typo="Typo.caption" Color="Color.Secondary" />
        }

        @if (Model.BrandReputation is { HasSignal: true })
        {
            <div class="mt-1"><BrandReputationView Reputation="Model.BrandReputation" Compact="true" /></div>
        }

        @if (Model.Rating is { } rating)
        {
            @* Product-level buyer rating aggregated across this model's listings — distinct from the
               brand-reputation chip above (that's the BRAND in-market; this is THIS product). The
               tooltip is the user-visible disambiguation between the two star scores. *@
            <div class="d-flex align-center gap-1 mt-1" title="@L["ModelCard.ProductRating"]">
                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                <MudText Typo="Typo.caption">@rating.ToString("0.0")@(Model.RatingCount is { } rc ? $" ({rc:n0})" : "")</MudText>
            </div>
        }

        <div class="d-flex align-center gap-2 mt-2" style="flex-wrap:wrap;">
            @if (Model.LowestOffer is { Price: not null } lowest && lowest.Currency is { } cur)
            {
                @if (lowest.IsIndicative)
                {
                    @* A POTENTIAL price (parsed loosely from a page/snippet): shown with ≈ and leading to
                       the store to verify — never presented as a firm quote. *@
                    <MudText Typo="Typo.h6" Color="Color.Secondary"
                             title="@L["ModelCard.PriceOnSite"]">≈ @(new Money(lowest.Price!.Value, cur).ToDisplay())</MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6" Color="Color.Primary">@L["ModelCard.From"] @(new Money(lowest.Price!.Value, cur).ToDisplay())</MudText>
                }
            }
            else
            {
                @* No numeric price could be read from any of this model's seller pages — the store
                   link is the price source. Kept honest: never invent or estimate a number here. *@
                <MudText Typo="Typo.body2" Color="Color.Secondary"
                         title="@L["ModelCard.PriceOnSiteHint"]">@L["ModelCard.PriceOnSite"]</MudText>
            }

            @if (Model.Offers.Any(o => o.IsDeal))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">@L["ModelCard.Sale"]</MudChip>
            }
        </div>

        @* Deliberately nothing more here: reviews, mentions, brand links, pros/cons and the review
           summary all live on the detail surfaces ("Details & prices" dialog and the /product page).
           The card stays compact and NOTHING on it expands. *@
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
            <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Small" />
            @Model.SellerCount @(Model.SellerCount == 1 ? L["ModelCard.Seller"] : L["Products.Sellers"])
        </MudText>
    </MudCardContent>

    <MudCardActions>
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Info" OnClick="OnDetailsClicked">@L["Products.Details"]</MudButton>
        @if (Model.LowestOffer?.Url is { Length: > 0 } url)
        {
            <MudButton Href="@url" Target="_blank" Size="Size.Small" Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.OpenInNew">@L["Products.View"]</MudButton>
        }
        @if (!string.IsNullOrWhiteSpace(Query))
        {
            <MudSpacer />
            <MudTooltip Text="@(_flagged ? "Flagged as not relevant" : "Not relevant to your search?")">
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Flag"
                               Color="@(_flagged ? Color.Warning : Color.Default)"
                               Disabled="_flagged" OnClick="OnFlagNotRelevant" />
            </MudTooltip>
        }
    </MudCardActions>
</MudCard>

@code {
    [Parameter, EditorRequired] public ProductModel Model { get; set; } = default!;
    [Parameter] public bool ShowCompare { get; set; } = true;
    [Parameter] public bool Selected { get; set; }
    [Parameter] public bool CanSelectMore { get; set; } = true;
    [Parameter] public EventCallback<bool> SelectedChanged { get; set; }
    [Parameter] public EventCallback OnDetails { get; set; }

    /// <summary>"Brand · Model" — the sub-caption under the name; empty when neither is set.</summary>
    private string BrandLine =>
        string.Join(" · ", new[] { Model.Brand, Model.Model }.Where(s => !string.IsNullOrWhiteSpace(s)));

    private Task OnToggleCompare(bool value) => SelectedChanged.InvokeAsync(value);
    private Task OnDetailsClicked() => OnDetails.InvokeAsync();

    // Relevancy feedback ("not relevant"): only shown when the card knows its originating query.
    [Parameter] public string? Query { get; set; }
    [Parameter] public string? Geo { get; set; }
    [Parameter] public string? Target { get; set; }

    private bool _flagged;

    private async Task OnFlagNotRelevant()
    {
        if (_flagged || string.IsNullOrWhiteSpace(Query))
        {
            return;
        }

        var userId = await CurrentUser.GetUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId))
        {
            Snackbar.Add("Sign in to flag results.", Severity.Info);
            return;
        }

        await Feedback.RecordAsync(Model, Query!, Target, Geo, reason: null, userId);
        _flagged = true;
        Snackbar.Add("Thanks — we'll use that to improve future searches.", Severity.Success);
    }
}
