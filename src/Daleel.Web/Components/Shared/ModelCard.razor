@* A single aggregated product model: image, name, lowest price across all its sources,
   how many sellers carry it, deal flag, a Details button and an optional compare checkbox. *@
@inject IStringLocalizer<SharedResource> L

<MudCard Class="daleel-card" Elevation="0" Outlined="true" Style="height:100%;display:flex;flex-direction:column;">
    <div style="height:150px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--mud-palette-background-grey);">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <SafeImage Src="@Model.ImageUrl" Alt="@Model.Name" Style="max-height:150px;max-width:100%;object-fit:contain;" />
        }
        else
        {
            @* No image available for this model — show a neutral placeholder so the grid stays even
               and the card doesn't collapse to a ragged height. *@
            <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Style="opacity:0.35;" />
        }
    </div>

    <MudCardContent Class="flex-grow-1">
        <div class="d-flex align-center justify-space-between mb-1" style="gap:8px;">
            @if (Model.LowestOffer is { } lo)
            {
                <SourceBadge SourceType="lo.SourceType" Source="@lo.Source" />
            }
            @if (ShowCompare)
            {
                <MudCheckBox T="bool" Value="Selected" ValueChanged="OnToggleCompare" Dense="true"
                             Size="Size.Small" Disabled="@(!Selected && !CanSelectMore)" Label="@L["Products.Compare"]" />
            }
        </div>

        <MudText Typo="Typo.body1" dir="@Catalog.Dir(Model.Name)" Style="font-weight:500;line-height:1.3;">
            @Model.Name
        </MudText>

        @if (!string.IsNullOrWhiteSpace(Model.Brand) || !string.IsNullOrWhiteSpace(Model.Model))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @string.Join(" · ", new[] { Model.Brand, Model.Model }.Where(s => !string.IsNullOrWhiteSpace(s)))
            </MudText>
        }

        @if (Model.BrandReputation is { HasSignal: true })
        {
            <div class="mt-1"><BrandReputationView Reputation="Model.BrandReputation" Compact="true" /></div>
        }

        <div class="d-flex align-center gap-2 mt-2" style="flex-wrap:wrap;">
            @if (Model.LowestPrice is { } price && Model.LowestOffer?.Currency is { } cur)
            {
                <MudText Typo="Typo.h6" Color="Color.Primary">@L["ModelCard.From"] @(new Money(price, cur).ToDisplay())</MudText>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["ModelCard.PriceOnSite"]</MudText>
            }

            @if (Model.Offers.Any(o => o.IsDeal))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">@L["ModelCard.Sale"]</MudChip>
            }
        </div>

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
            <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Small" />
            @Model.SellerCount @(Model.SellerCount == 1 ? L["ModelCard.Seller"] : L["Products.Sellers"])
        </MudText>

        @if (!string.IsNullOrWhiteSpace(Model.ReviewSummary))
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block" Style="font-style:italic;"
                     dir="@Catalog.Dir(Model.ReviewSummary!)">“@Model.ReviewSummary”</MudText>
        }

        @if (Model.Pros.Count > 0)
        {
            <MudList T="string" Dense="true" Class="mt-1 pa-0">
                @foreach (var pro in Model.Pros.Take(2))
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.ThumbUp" IconColor="Color.Success"
                                 Class="pa-0">
                        <MudText Typo="Typo.caption" dir="@Catalog.Dir(pro)">@pro</MudText>
                    </MudListItem>
                }
            </MudList>
        }
    </MudCardContent>

    <MudCardActions>
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Info" OnClick="OnDetailsClicked">@L["Products.Details"]</MudButton>
        @if (Model.LowestOffer?.Url is { Length: > 0 } url)
        {
            <MudButton Href="@url" Target="_blank" Size="Size.Small" Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.OpenInNew">@L["Products.View"]</MudButton>
        }
    </MudCardActions>
</MudCard>

@code {
    [Parameter, EditorRequired] public ProductModel Model { get; set; } = default!;
    [Parameter] public bool ShowCompare { get; set; } = true;
    [Parameter] public bool Selected { get; set; }
    [Parameter] public bool CanSelectMore { get; set; } = true;
    [Parameter] public EventCallback<bool> SelectedChanged { get; set; }
    [Parameter] public EventCallback OnDetails { get; set; }

    private Task OnToggleCompare(bool value) => SelectedChanged.InvokeAsync(value);
    private Task OnDetailsClicked() => OnDetails.InvokeAsync();
}
