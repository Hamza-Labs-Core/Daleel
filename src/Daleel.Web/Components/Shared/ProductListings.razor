@* Products tab: filter/sort bar, model grid (one card per model, aggregating all its
   price sources), pre-grouped comparison tiers, and a 2–4 model compare flow. *@
@inject IDialogService Dialogs
@inject IStringLocalizer<SharedResource> L

<MudPaper Class="pa-3 mb-3" Outlined="true" Elevation="0">
    <div class="d-flex align-center mb-2">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">@Result.Models.Count @L["Results.ModelsLabel"]</MudText>
        <MudSpacer />
        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Success"
                 Icon="@Icons.Material.Filled.Place">@string.Format(L["Results.AllLocalTo"], Result.Country)</MudChip>
    </div>

    <MudGrid Spacing="2" Class="align-end">
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="Brand" Label="@L["Filter.Brand"]" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@AllValue">@L["ProductFilters.AllBrands"]</MudSelectItem>
                @foreach (var b in _brands)
                {
                    <MudSelectItem T="string" Value="@b">@b</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="SourceType" Label="@L["Filter.Source"]" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@AllValue">@L["ProductFilters.AllSources"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("marketplace")">@L["ProductFilters.Marketplaces"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("brand")">@L["ProductFilters.BrandSites"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("store")">@L["Products.Stores"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="Condition" Label="@L["Filter.Condition"]" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@AllValue">@L["ProductFilters.Any"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("new")">@L["Filter.New"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("used")">@L["Filter.Used"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("refurbished")">@L["Filter.Refurbished"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="Sort" Label="@L["Filter.SortBy"]" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@("relevance")">@L["Filter.Relevance"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("price_asc")">@L["Filter.PriceLowHigh"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("price_desc")">@L["Filter.PriceHighLow"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("sellers")">@L["ProductFilters.MostSellers"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <div class="d-flex align-center gap-2">
                <MudNumericField T="decimal?" @bind-Value="MinPrice" Label="@L["Filter.MinPrice"]" Variant="Variant.Text"
                                 Margin="Margin.Dense" Clearable="true" HideSpinButtons="true" />
                <MudNumericField T="decimal?" @bind-Value="MaxPrice" Label="@L["Filter.MaxPrice"]" Variant="Variant.Text"
                                 Margin="Margin.Dense" Clearable="true" HideSpinButtons="true" />
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" Class="d-flex align-center justify-end">
            <MudText Typo="Typo.caption" Color="Color.Secondary">@string.Format(L["Results.NofMShown"], _filtered.Count, Result.Models.Count)</MudText>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (Result.Marketplaces.Count > 0)
{
    <div class="d-flex align-center gap-2 mb-3" style="flex-wrap:wrap;">
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Products.BrowseAllOn"]</MudText>
        @foreach (var m in Result.Marketplaces.Where(m => !string.IsNullOrWhiteSpace(m.Url)).Take(8))
        {
            <MudButton Href="@m.Url" Target="_blank" Size="Size.Small" Variant="Variant.Outlined"
                       Color="Color.Success" StartIcon="@Icons.Material.Filled.Storefront">@m.Name</MudButton>
        }
    </div>
}

@if (_filtered.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">@L["Results.NoMatch"]</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var (idx, model) in _pageItems)
        {
            <MudItem xs="12" sm="6" md="4" @key="model">
                <ModelCard Model="model"
                           Query="@Result.Query"
                           Geo="@Result.Geo"
                           Target="@FlagTarget"
                           Selected="@_selected.Contains(idx)"
                           CanSelectMore="@(_selected.Count < MaxCompare)"
                           SelectedChanged="@(v => ToggleCompare(idx, v))"
                           OnDetails="@(() => OpenDetails(model))" />
            </MudItem>
        }
    </MudGrid>

    @* Numbered pagination (with prev/next and first/last) so a 100+ item grid stays scannable.
       Hidden for a single page. Compare selection is keyed by the model's ORIGINAL index, so
       selections survive page flips. *@
    @if (_pageCount > 1)
    {
        <div class="d-flex justify-center mt-4">
            <MudPagination Count="_pageCount" Selected="_page" SelectedChanged="OnPageChanged"
                           ShowFirstButton="true" ShowLastButton="true" BoundaryCount="1" MiddleCount="3" />
        </div>
    }
}

@if (Result.Comparisons.Count > 0)
{
    <MudExpansionPanels Class="mt-4" Elevation="0">
        <MudExpansionPanel Text="@L["Results.PreGrouped"]">
            <MudGrid Spacing="2">
                @foreach (var group in Result.Comparisons)
                {
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3" Outlined="true" Elevation="0" Style="height:100%;">
                            <MudText Typo="Typo.subtitle1" Color="Color.Primary">@group.Category</MudText>
                            @if (!string.IsNullOrWhiteSpace(group.Recommendation))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@group.Recommendation</MudText>
                            }
                            <MudList T="string" Dense="true" Class="mt-2">
                                @foreach (var item in group.Items)
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.ChevronRight"
                                                 Href="@item.Url" Target="_blank">
                                        <MudText Typo="Typo.body2" dir="@Catalog.Dir(item.Name)">
                                            @item.Name @(item.AsMoney is { } mm ? $"— {mm.ToDisplay()}" : "")
                                        </MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@if (_selected.Count > 0)
{
    <MudPaper Class="pa-2 px-4" Elevation="6"
              Style="position:sticky;bottom:80px;z-index:5;border-radius:24px;display:flex;align-items:center;gap:12px;width:fit-content;margin:16px auto 0;">
        <MudText Typo="Typo.body2">@string.Format(L["Results.NSelected"], _selected.Count)</MudText>
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Compare" Disabled="@(_selected.Count < 2)"
                   OnClick="OpenComparison">@L["Products.Compare"]</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ClearCompare">@L["Results.Clear"]</MudButton>
    </MudPaper>
}

@code {
    [Parameter, EditorRequired] public ProductSearchResult Result { get; set; } = default!;

    /// <summary>The relevance target a "not relevant" flag records against — the classified product type,
    /// else the raw query (matches the relevance gate's own target).</summary>
    private string FlagTarget => Result.Schema.IsEmpty ? Result.Query : Result.Schema.ProductType;

    /// <summary>Optional brand to pre-filter by (set when drilling in from the Brands tab).</summary>
    [Parameter] public string? InitialBrand { get; set; }

    /// <summary>The page to open on (1-based). Lets a host deep-link a specific page via the URL
    /// (e.g. the /search/{id}?page=N result view). Defaults to 1.</summary>
    [Parameter] public int InitialPage { get; set; } = 1;

    /// <summary>Raised (with the new 1-based page) when the user flips pages, so a host page can
    /// reflect it in the URL + title. When no host handles it, pagination stays purely in-component.</summary>
    [Parameter] public EventCallback<int> PageChanged { get; set; }

    private const string AllValue = "__all__";
    private const int MaxCompare = 4;

    /// <summary>Cards per page: 4 rows of the md 3-column grid.</summary>
    private const int PageSize = 12;

    private string _brand = AllValue;
    private string _sourceType = AllValue;
    private string _condition = AllValue;
    private string _sort = "relevance";
    private decimal? _minPrice;
    private decimal? _maxPrice;
    private readonly HashSet<int> _selected = new();

    private List<string> _brands = new();
    private List<(int Index, ProductModel Model)> _indexed = new();

    // Cached filtered/sorted view. Recomputed only when a filter input actually changes (via the
    // property setters below) or when the Result parameter changes — never per render. Reading it from
    // markup is then O(1), so unrelated re-renders (e.g. toggling a compare checkbox) stay cheap. PERF-2.
    private List<(int Index, ProductModel Model)> _filtered = new();

    // Current page (1-based) over _filtered, and the cached slice the grid renders. A filter change
    // resets to page 1 (the old page may no longer exist); a page flip just re-slices.
    private int _page = 1;
    private int _pageCount = 1;
    private List<(int Index, ProductModel Model)> _pageItems = new();

    // Filter/sort inputs are exposed as properties so the bound MudBlazor controls trigger a single
    // recompute on change instead of the markup re-running the LINQ pipeline on every render. A filter
    // change also snaps back to page 1 — the current page may not exist in the narrowed list.
    private string Brand { get => _brand; set { if (_brand != value) { _brand = value; OnFilterChanged(); } } }
    private string SourceType { get => _sourceType; set { if (_sourceType != value) { _sourceType = value; OnFilterChanged(); } } }
    private string Condition { get => _condition; set { if (_condition != value) { _condition = value; OnFilterChanged(); } } }
    private string Sort { get => _sort; set { if (_sort != value) { _sort = value; OnFilterChanged(); } } }
    private decimal? MinPrice { get => _minPrice; set { if (_minPrice != value) { _minPrice = value; OnFilterChanged(); } } }
    private decimal? MaxPrice { get => _maxPrice; set { if (_maxPrice != value) { _maxPrice = value; OnFilterChanged(); } } }

    private void OnFilterChanged()
    {
        _page = 1;
        Recompute();
    }

    // The Result last seen by OnParametersSet: page 1 is forced only when a genuinely NEW result
    // arrives (fresh search, or the background enrichment streaming a refreshed result) — a parent
    // re-render passing the SAME Result must not yank the user off the page they're browsing.
    private ProductSearchResult? _lastResult;

    // The InitialPage last applied, so a parent re-render passing the SAME page doesn't yank the user
    // off the page they flipped to internally — only a genuine URL/page change re-syncs.
    private int _lastInitialPage = 1;

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(_lastResult, Result))
        {
            // A genuinely new result opens on the host-requested page (deep-link ?page=N), else page 1.
            _lastResult = Result;
            _page = InitialPage;
        }
        else if (InitialPage != _lastInitialPage)
        {
            // Same result, URL page changed (deep-link navigation / back-forward) — follow it.
            _page = InitialPage;
        }
        _lastInitialPage = InitialPage;

        if (!string.IsNullOrWhiteSpace(InitialBrand))
        {
            _brand = InitialBrand!;
        }

        _indexed = Result.Models.Select((m, i) => (i, m)).ToList();
        _brands = Result.Models
            .Select(m => m.Brand)
            .Where(b => !string.IsNullOrWhiteSpace(b))
            .Select(b => b!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(b => b)
            .ToList();

        Recompute();
    }

    private void Recompute()
    {
        IEnumerable<(int Index, ProductModel Model)> q = _indexed;

        if (_brand != AllValue)
            q = q.Where(x => string.Equals(x.Model.Brand, _brand, StringComparison.OrdinalIgnoreCase));

        if (_sourceType != AllValue)
            q = q.Where(x => x.Model.Offers.Any(o => MatchesSourceType(o.SourceType)));

        if (_condition != AllValue)
            q = q.Where(x => x.Model.Offers.Any(o => string.Equals(o.Condition, _condition, StringComparison.OrdinalIgnoreCase)));

        // Sort/filter by the DISPLAYED price (LowestOffer's — exact preferred over indicative), so
        // the grid order always matches the figures on the cards. Keying off LowestPrice (min over
        // ALL offers incl. loosely-parsed ones) would order a "From 500" card above a "From 490" one.
        if (_minPrice is { } min)
            q = q.Where(x => x.Model.DisplayPrice is { } p && p >= min);

        if (_maxPrice is { } max)
            q = q.Where(x => x.Model.DisplayPrice is { } p && p <= max);

        q = _sort switch
        {
            "price_asc" => q.OrderBy(x => x.Model.DisplayPrice ?? decimal.MaxValue),
            "price_desc" => q.OrderByDescending(x => x.Model.DisplayPrice ?? decimal.MinValue),
            "sellers" => q.OrderByDescending(x => x.Model.SellerCount),
            _ => q
        };

        _filtered = q.ToList();
        RepageInternal();
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        RepageInternal();
        _lastInitialPage = _page; // keep in sync so the host's URL update doesn't re-trigger a reset
        if (PageChanged.HasDelegate)
        {
            await PageChanged.InvokeAsync(_page);
        }
    }

    /// <summary>Recomputes the page count (clamping the current page) and the rendered slice.</summary>
    private void RepageInternal()
    {
        _pageCount = Math.Max(1, (_filtered.Count + PageSize - 1) / PageSize);
        _page = Math.Clamp(_page, 1, _pageCount);
        _pageItems = _filtered.Skip((_page - 1) * PageSize).Take(PageSize).ToList();
    }

    private bool MatchesSourceType(ResultType type) => _sourceType switch
    {
        "marketplace" => type is ResultType.Marketplace or ResultType.ProductListing,
        "brand" => type is ResultType.BrandPage,
        "store" => type is ResultType.StorePage,
        _ => true
    };

    private void ToggleCompare(int index, bool selected)
    {
        if (selected)
        {
            if (_selected.Count < MaxCompare) _selected.Add(index);
        }
        else
        {
            _selected.Remove(index);
        }
    }

    private void ClearCompare() => _selected.Clear();

    private Task OpenDetails(ProductModel model)
    {
        var parameters = new DialogParameters<ModelDetailDialog>
        {
            { x => x.Model, model },
            { x => x.Geo, Result.Geo }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        return Dialogs.ShowAsync<ModelDetailDialog>(model.Name, parameters, options);
    }

    private Task OpenComparison()
    {
        var items = _selected.OrderBy(i => i).Select(i => Result.Models[i]).ToList();
        // Pass the product-type-aware schema so the table leads with the specs that matter for
        // this category (BTU/energy for ACs, RAM/storage for phones) instead of an arbitrary union.
        var parameters = new DialogParameters<ComparisonDialog>
        {
            { x => x.Items, items },
            { x => x.Schema, Result.Schema }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        return Dialogs.ShowAsync<ComparisonDialog>(L["Results.CompareProducts"], parameters, options);
    }
}
