@* Products tab: filter/sort bar, model grid (one card per model, aggregating all its
   price sources), pre-grouped comparison tiers, and a 2–4 model compare flow. *@
@inject IDialogService Dialogs

<MudPaper Class="pa-3 mb-3" Outlined="true" Elevation="0">
    <div class="d-flex align-center mb-2">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">@Result.Models.Count models · المنتجات</MudText>
        <MudSpacer />
        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Success"
                 Icon="@Icons.Material.Filled.Place">All local to @Result.Country</MudChip>
    </div>

    <MudGrid Spacing="2" Class="align-end">
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="Brand" Label="Brand" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@AllValue">All brands</MudSelectItem>
                @foreach (var b in _brands)
                {
                    <MudSelectItem T="string" Value="@b">@b</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="SourceType" Label="Source" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@AllValue">All sources</MudSelectItem>
                <MudSelectItem T="string" Value="@("marketplace")">Marketplaces</MudSelectItem>
                <MudSelectItem T="string" Value="@("brand")">Brand sites</MudSelectItem>
                <MudSelectItem T="string" Value="@("store")">Stores</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="Condition" Label="Condition" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@AllValue">Any</MudSelectItem>
                <MudSelectItem T="string" Value="@("new")">New</MudSelectItem>
                <MudSelectItem T="string" Value="@("used")">Used</MudSelectItem>
                <MudSelectItem T="string" Value="@("refurbished")">Refurbished</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudSelect T="string" @bind-Value="Sort" Label="Sort by" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@("relevance")">Relevance</MudSelectItem>
                <MudSelectItem T="string" Value="@("price_asc")">Price: low → high</MudSelectItem>
                <MudSelectItem T="string" Value="@("price_desc")">Price: high → low</MudSelectItem>
                <MudSelectItem T="string" Value="@("sellers")">Most sellers</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <div class="d-flex align-center gap-2">
                <MudNumericField T="decimal?" @bind-Value="MinPrice" Label="Min price" Variant="Variant.Text"
                                 Margin="Margin.Dense" Clearable="true" HideSpinButtons="true" />
                <MudNumericField T="decimal?" @bind-Value="MaxPrice" Label="Max price" Variant="Variant.Text"
                                 Margin="Margin.Dense" Clearable="true" HideSpinButtons="true" />
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" Class="d-flex align-center justify-end">
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_filtered.Count of @Result.Models.Count shown</MudText>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (Result.Marketplaces.Count > 0)
{
    <div class="d-flex align-center gap-2 mb-3" style="flex-wrap:wrap;">
        <MudText Typo="Typo.body2" Color="Color.Secondary">Browse all on:</MudText>
        @foreach (var m in Result.Marketplaces.Where(m => !string.IsNullOrWhiteSpace(m.Url)).Take(8))
        {
            <MudButton Href="@m.Url" Target="_blank" Size="Size.Small" Variant="Variant.Outlined"
                       Color="Color.Success" StartIcon="@Icons.Material.Filled.Storefront">@m.Name</MudButton>
        }
    </div>
}

@if (_filtered.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">No products match the current filters.</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var (idx, model) in _filtered)
        {
            <MudItem xs="12" sm="6" md="4" @key="model">
                <ModelCard Model="model"
                           Selected="@_selected.Contains(idx)"
                           CanSelectMore="@(_selected.Count < MaxCompare)"
                           SelectedChanged="@(v => ToggleCompare(idx, v))"
                           OnDetails="@(() => OpenDetails(model))" />
            </MudItem>
        }
    </MudGrid>
}

@if (Result.Comparisons.Count > 0)
{
    <MudExpansionPanels Class="mt-4" Elevation="0">
        <MudExpansionPanel Text="Pre-grouped comparison: budget · mid-range · premium">
            <MudGrid Spacing="2">
                @foreach (var group in Result.Comparisons)
                {
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3" Outlined="true" Elevation="0" Style="height:100%;">
                            <MudText Typo="Typo.subtitle1" Color="Color.Primary">@group.Category</MudText>
                            @if (!string.IsNullOrWhiteSpace(group.Recommendation))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@group.Recommendation</MudText>
                            }
                            <MudList T="string" Dense="true" Class="mt-2">
                                @foreach (var item in group.Items)
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.ChevronRight"
                                                 Href="@item.Url" Target="_blank">
                                        <MudText Typo="Typo.body2" dir="@Catalog.Dir(item.Name)">
                                            @item.Name @(item.AsMoney is { } mm ? $"— {mm.ToDisplay()}" : "")
                                        </MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@if (_selected.Count > 0)
{
    <MudPaper Class="pa-2 px-4" Elevation="6"
              Style="position:sticky;bottom:80px;z-index:5;border-radius:24px;display:flex;align-items:center;gap:12px;width:fit-content;margin:16px auto 0;">
        <MudText Typo="Typo.body2">@_selected.Count selected</MudText>
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Compare" Disabled="@(_selected.Count < 2)"
                   OnClick="OpenComparison">Compare</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ClearCompare">Clear</MudButton>
    </MudPaper>
}

@code {
    [Parameter, EditorRequired] public ProductSearchResult Result { get; set; } = default!;

    /// <summary>Optional brand to pre-filter by (set when drilling in from the Brands tab).</summary>
    [Parameter] public string? InitialBrand { get; set; }

    private const string AllValue = "__all__";
    private const int MaxCompare = 4;

    private string _brand = AllValue;
    private string _sourceType = AllValue;
    private string _condition = AllValue;
    private string _sort = "relevance";
    private decimal? _minPrice;
    private decimal? _maxPrice;
    private readonly HashSet<int> _selected = new();

    private List<string> _brands = new();
    private List<(int Index, ProductModel Model)> _indexed = new();

    // Cached filtered/sorted view. Recomputed only when a filter input actually changes (via the
    // property setters below) or when the Result parameter changes — never per render. Reading it from
    // markup is then O(1), so unrelated re-renders (e.g. toggling a compare checkbox) stay cheap. PERF-2.
    private List<(int Index, ProductModel Model)> _filtered = new();

    // Filter/sort inputs are exposed as properties so the bound MudBlazor controls trigger a single
    // recompute on change instead of the markup re-running the LINQ pipeline on every render.
    private string Brand { get => _brand; set { if (_brand != value) { _brand = value; Recompute(); } } }
    private string SourceType { get => _sourceType; set { if (_sourceType != value) { _sourceType = value; Recompute(); } } }
    private string Condition { get => _condition; set { if (_condition != value) { _condition = value; Recompute(); } } }
    private string Sort { get => _sort; set { if (_sort != value) { _sort = value; Recompute(); } } }
    private decimal? MinPrice { get => _minPrice; set { if (_minPrice != value) { _minPrice = value; Recompute(); } } }
    private decimal? MaxPrice { get => _maxPrice; set { if (_maxPrice != value) { _maxPrice = value; Recompute(); } } }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(InitialBrand))
        {
            _brand = InitialBrand!;
        }

        _indexed = Result.Models.Select((m, i) => (i, m)).ToList();
        _brands = Result.Models
            .Select(m => m.Brand)
            .Where(b => !string.IsNullOrWhiteSpace(b))
            .Select(b => b!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(b => b)
            .ToList();

        Recompute();
    }

    private void Recompute()
    {
        IEnumerable<(int Index, ProductModel Model)> q = _indexed;

        if (_brand != AllValue)
            q = q.Where(x => string.Equals(x.Model.Brand, _brand, StringComparison.OrdinalIgnoreCase));

        if (_sourceType != AllValue)
            q = q.Where(x => x.Model.Offers.Any(o => MatchesSourceType(o.SourceType)));

        if (_condition != AllValue)
            q = q.Where(x => x.Model.Offers.Any(o => string.Equals(o.Condition, _condition, StringComparison.OrdinalIgnoreCase)));

        if (_minPrice is { } min)
            q = q.Where(x => x.Model.LowestPrice is { } p && p >= min);

        if (_maxPrice is { } max)
            q = q.Where(x => x.Model.LowestPrice is { } p && p <= max);

        q = _sort switch
        {
            "price_asc" => q.OrderBy(x => x.Model.LowestPrice ?? decimal.MaxValue),
            "price_desc" => q.OrderByDescending(x => x.Model.LowestPrice ?? decimal.MinValue),
            "sellers" => q.OrderByDescending(x => x.Model.SellerCount),
            _ => q
        };

        _filtered = q.ToList();
    }

    private bool MatchesSourceType(ResultType type) => _sourceType switch
    {
        "marketplace" => type is ResultType.Marketplace or ResultType.ProductListing,
        "brand" => type is ResultType.BrandPage,
        "store" => type is ResultType.StorePage,
        _ => true
    };

    private void ToggleCompare(int index, bool selected)
    {
        if (selected)
        {
            if (_selected.Count < MaxCompare) _selected.Add(index);
        }
        else
        {
            _selected.Remove(index);
        }
    }

    private void ClearCompare() => _selected.Clear();

    private Task OpenDetails(ProductModel model)
    {
        var parameters = new DialogParameters<ModelDetailDialog>
        {
            { x => x.Model, model },
            { x => x.Geo, Result.Geo }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        return Dialogs.ShowAsync<ModelDetailDialog>(model.Name, parameters, options);
    }

    private Task OpenComparison()
    {
        var items = _selected.OrderBy(i => i).Select(i => Result.Models[i]).ToList();
        var parameters = new DialogParameters<ComparisonDialog> { { x => x.Items, items } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        return Dialogs.ShowAsync<ComparisonDialog>("Compare products", parameters, options);
    }
}
