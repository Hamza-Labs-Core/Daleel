@* Sends unauthenticated visitors to the login page, preserving where they were headed. *@
@inject NavigationManager Nav

@code {
    protected override void OnInitialized()
    {
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        Nav.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: false);
    }
}
