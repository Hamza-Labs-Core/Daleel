@* OpenRouter model picker with a short note per model. ToStringFunc maps the model id (e.g.
   "anthropic/claude-sonnet-4") to its friendly label so the closed select shows "Claude Sonnet 4". *@
<MudSelect T="string" Value="Value" ValueChanged="OnChanged" Label="@Label"
           ToStringFunc="@(id => Catalog.Models.FirstOrDefault(m => m.Id == id)?.Label ?? id)"
           Dense="true" Variant="Variant.Outlined" Adornment="Adornment.Start"
           AdornmentIcon="@Icons.Material.Filled.Memory" AnchorOrigin="Origin.BottomCenter">
    @foreach (var model in Catalog.Models)
    {
        <MudSelectItem T="string" Value="@model.Id">
            <div class="d-flex flex-column">
                <MudText Typo="Typo.body2">@model.Label</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@model.Note</MudText>
            </div>
        </MudSelectItem>
    }
</MudSelect>

@code {
    [Parameter] public string Value { get; set; } = Catalog.DefaultModel;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Model · النموذج";

    private Task OnChanged(string value)
    {
        Value = value;
        return ValueChanged.InvokeAsync(value);
    }
}
