@* Anonymous landing page. Shown to signed-out visitors in place of the search UI (see Home.razor).
   All copy is localized via the shared catalogue so it follows the EN/AR culture, and the layout is
   mobile-first (single column on xs, fanning out to 2–3 columns from sm/md up). MudRTLProvider in the
   layout mirrors everything for Arabic automatically. *@
@inject IStringLocalizer<SharedResource> L

<!-- ╔═══════════════════════════ HERO ═══════════════════════════╗ -->
@* The brand wordmark lives in the top app bar, so the hero leads straight with the value
   proposition rather than repeating a standalone logo. *@
<section class="daleel-landing-hero">
    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
             Icon="@Icons.Material.Filled.ShoppingBag" Class="mb-4">@L["Landing.Hero.Badge"]</MudChip>

    <MudText Typo="Typo.h3" Align="Align.Center" Class="daleel-landing-title mt-2">
        @L["Landing.Hero.Title"]
    </MudText>

    <MudText Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Secondary" Class="daleel-landing-lede mx-auto mt-3">
        @L["Landing.Hero.Subtitle"]
    </MudText>

    <div class="d-flex flex-wrap justify-center gap-3 mt-6">
        <MudButton Href="/register" data-enhance-nav="false" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   EndIcon="@Icons.Material.Filled.ArrowForward">@L["Landing.Hero.GetStarted"]</MudButton>
        <MudButton Href="/login" data-enhance-nav="false" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Login">@L["Landing.Hero.SignIn"]</MudButton>
    </div>

    <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Class="d-block mt-4">
        @L["Landing.Hero.NoCard"]
    </MudText>
</section>

<!-- ╔═════════════════════════ FEATURES ═════════════════════════╗ -->
<section class="daleel-landing-section">
    <div class="text-center mb-8">
        <MudText Typo="Typo.h4">@L["Landing.Features.Title"]</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="daleel-landing-lede mx-auto mt-2">
            @L["Landing.Features.Subtitle"]
        </MudText>
    </div>

    <MudGrid Spacing="4" Justify="Justify.Center">
        @foreach (var f in _features)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Outlined="true" Elevation="0" Class="daleel-card daleel-feature-card pa-6">
                    <div class="daleel-feature-icon" style="@($"color:{f.Tint};background:rgba(var({f.TintRgb}),.12);")">
                        <MudIcon Icon="@f.Icon" Size="Size.Large" />
                    </div>
                    <MudText Typo="Typo.h6" Class="mt-4">@f.Title</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">@f.Desc</MudText>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</section>

<!-- ╔════════════════════════ CTA BAND ══════════════════════════╗ -->
<section class="daleel-landing-section">
    <MudPaper Elevation="0" Class="daleel-cta-band pa-8 text-center">
        <MudText Typo="Typo.h4" Class="daleel-cta-title">@L["Landing.Cta.Title"]</MudText>
        <MudText Typo="Typo.body1" Class="daleel-cta-sub mx-auto mt-2">@L["Landing.Cta.Subtitle"]</MudText>
        <div class="d-flex flex-wrap justify-center gap-3 mt-6">
            <MudButton Href="/register" data-enhance-nav="false" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       EndIcon="@Icons.Material.Filled.ArrowForward">@L["Landing.Cta.Register"]</MudButton>
            <MudButton Href="/login" data-enhance-nav="false" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Large">
                @L["Landing.Cta.Login"]
            </MudButton>
        </div>
    </MudPaper>
</section>

@code {
    private sealed record Feature(string Icon, string Title, string Desc, string Tint, string TintRgb);

    // CSS palette vars + their *-rgb companions (MudBlazor emits both) let the icon use a solid colour
    // over a soft 12%-alpha wash of the same hue.
    private Feature[] _features => new[]
    {
        new Feature(Icons.Material.Filled.TravelExplore, L["Landing.Feature.Search.Title"],     L["Landing.Feature.Search.Desc"],     "var(--mud-palette-primary)",   "--mud-palette-primary-rgb"),
        new Feature(Icons.Material.Filled.Balance,       L["Landing.Feature.Compare.Title"],    L["Landing.Feature.Compare.Desc"],    "var(--mud-palette-secondary)", "--mud-palette-secondary-rgb"),
        new Feature(Icons.Material.Filled.Reviews,       L["Landing.Feature.Reputation.Title"], L["Landing.Feature.Reputation.Desc"], "var(--mud-palette-info)",      "--mud-palette-info-rgb"),
        new Feature(Icons.Material.Filled.LocalOffer,    L["Landing.Feature.Deals.Title"],      L["Landing.Feature.Deals.Desc"],      "var(--mud-palette-warning)",   "--mud-palette-warning-rgb"),
        new Feature(Icons.Material.Filled.Translate,     L["Landing.Feature.Bilingual.Title"],  L["Landing.Feature.Bilingual.Desc"],  "var(--mud-palette-primary)",   "--mud-palette-primary-rgb"),
    };
}
